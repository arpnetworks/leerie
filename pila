#!/usr/bin/env bash
# pila — entry point for the Pila orchestrator.
# After install: `pila "your task description"` from any git repo.
# Direct git-clone: `/path/to/pila/pila "your task description"`,
# or symlink this file onto your PATH manually.
#
# pila runs inside a container — see docs/IMPLEMENTATION.md §0.5
# "Container shape" and docs/DESIGN.md §6. This launcher:
#   1. Resolves its own location (walking symlinks).
#   2. Fast path: `--version` answers without a container so the installer's
#      smoke test runs the moment the symlink is in place.
#   3. Per-OS preflight: verifies a working container runtime.
#   4. Builds the pila image once per version, reuses thereafter.
#   5. Translates --inspect-dir paths into bind-mounts.
#   6. Execs nerdctl run with the full mount table, adapting TTY flags
#      ([-it] vs [-i]) to whether the launcher itself has a TTY.
set -euo pipefail

# --- resolve symlinks ----------------------------------------------------
# The curl|bash installer symlinks this script into ~/.local/bin/pila, but
# the Dockerfile + orchestrator source live alongside the real launcher under
# $PILA_HOME (default ~/.pila). readlink -f isn't portable to BSD/macOS, so
# walk by hand. (Same loop as the pre-container launcher — contract preserved.)
SRC="${BASH_SOURCE[0]}"
hops=0
while [ -L "$SRC" ]; do
  hops=$((hops + 1))
  if [ "$hops" -gt 20 ]; then
    echo "pila: refusing to resolve symlink chain deeper than 20 hops at $SRC" >&2
    exit 1
  fi
  TARGET="$(readlink "$SRC")"
  case "$TARGET" in
    /*) SRC="$TARGET" ;;
    *)  SRC="$(cd -P "$(dirname "$SRC")" && pwd)/$TARGET" ;;
  esac
done
PILA_REPO="$(cd -P "$(dirname "$SRC")" && pwd)"
USER_REPO="$(pwd -P)"

# Image tag = pila:<version>. Version comes from plugin.json (single source of
# truth — same one `pila --version` reads). The launcher only needs the value
# for tagging, so a minimal extractor avoids needing python/jq at this stage.
PILA_VERSION="$(awk -F'"' '/"version"/ {print $4; exit}' \
                  "$PILA_REPO/.claude-plugin/plugin.json" 2>/dev/null || echo dev)"
IMAGE_TAG="pila:$PILA_VERSION"

# --- fast paths that don't need the container ----------------------------
# `pila --version` should answer immediately without spinning up a container
# — used by the installer's end-to-end smoke test and by anyone who just
# wants to check what's installed.
#
# `--help` is NOT short-circuited: forwarding it through the container makes
# the orchestrator's argparse render the full flag list (worker model
# overrides, telemetry knobs, etc.), which a launcher-side summary would
# silently truncate. The first --help pays a one-time image-build cost; every
# subsequent invocation reuses the cached image and starts in ~2s.

# --- _resolve_fly_machine_id_from_run_dir -------------------------------
# Read fly_machine_id from a run's host-side sidecar. Tries
# fly-machine.json first, then run.json — mirrors the resolution order
# in scripts/remote/attach.sh so the `--stop`/`--kill`/`--finalize`
# fast-paths also work during the in-flight bootstrap window (when the
# host has fly-machine.json but no run.json yet — DESIGN §6 Detached
# orchestrator (remote mode)).
#
# Echoes the machine id to stdout, empty string on miss. Used by
# `_kill_bootstrap_minimal_run_json` and the verbs below.
_resolve_fly_machine_id_from_run_dir() {
  local run_dir="$1"
  local candidate
  for candidate in "$run_dir/fly-machine.json" "$run_dir/run.json"; do
    if [ -f "$candidate" ]; then
      python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    mid = d.get("fly_machine_id")
    print(mid if mid else "")
except Exception:
    pass
' "$candidate"
      return 0
    fi
  done
  return 0
}

# --- _ensure_run_json --------------------------------------------------
# If run_dir has fly-machine.json but no run.json, bootstrap a minimal
# run.json so subsequent `update_run_json` writes (paused_at,
# killed_at, etc.) have a file to merge into. Idempotent.
_ensure_run_json() {
  local run_dir="$1"
  local sidecar="$run_dir/run.json"
  if [ -f "$sidecar" ]; then
    return 0
  fi
  local fmj="$run_dir/fly-machine.json"
  if [ ! -f "$fmj" ]; then
    return 1
  fi
  python3 -c '
import json, sys
fmj = sys.argv[1]
sidecar = sys.argv[2]
try:
    d = json.load(open(fmj))
except Exception:
    d = {}
out = {
    "fly_machine_id": d.get("fly_machine_id"),
}
with open(sidecar, "w") as f:
    json.dump(out, f, indent=2)
    f.write("\n")
' "$fmj" "$sidecar"
}

case "${1:-}" in
  --version)
    echo "pila $PILA_VERSION"
    exit 0
    ;;
  --attach)
    # Fast-path: open a PTY into a running/paused Fly Machine.
    # (DESIGN §6 *Interactive attach over PTY in remote mode*.)
    # Routed before any runtime preflight — attach doesn't need a
    # local container, only flyctl + WireGuard reachability.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    exec "$PILA_REPO/scripts/remote/attach.sh" "$@"
    ;;
  --re-seed)
    # Fast-path: re-rsync the host's working tree into a paused/running
    # Fly Machine. (Phase 4: mid-run re-rsync correction.) Runs before
    # runtime preflight since it doesn't need a local container.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    _re_seed_run_id=""
    _re_seed_force=0
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --force) _re_seed_force=1; shift ;;
        --*) echo "pila: unknown --re-seed flag: $1" >&2; exit 1 ;;
        *)
          if [ -z "$_re_seed_run_id" ]; then _re_seed_run_id="$1"; shift
          else echo "pila: unexpected --re-seed arg: $1" >&2; exit 1
          fi
          ;;
      esac
    done
    if [ -z "$_re_seed_run_id" ]; then
      echo "pila: --re-seed requires a <run-id>" >&2
      echo "  Usage: pila --re-seed <run-id> [--force]" >&2
      exit 1
    fi
    export PILA_RUN_ID="$_re_seed_run_id"
    [ "$_re_seed_force" = "1" ] && export PILA_RE_SEED_FORCE=1
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/remote/provision.sh"
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/remote/seed-repo.sh"
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/remote/re-seed.sh"
    re_seed
    exit $?
    ;;
  --stop)
    # Fast-path: explicit pause of a remote run (DESIGN §6 *The user-
    # visible verb surface*). Reads fly_machine_id from the run sidecar
    # and calls stop_machine. Resumable via --resume.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    _stop_run_id="${1:-}"
    if [ -z "$_stop_run_id" ]; then
      echo "pila: --stop requires a <run-id>" >&2
      echo "  Usage: pila --stop <run-id>" >&2
      exit 1
    fi
    _stop_run_dir="$USER_REPO/.pila/runs/$_stop_run_id"
    if [ ! -d "$_stop_run_dir" ]; then
      echo "pila: --stop: no run dir at $_stop_run_dir" >&2
      echo "  Check 'pila --list' for active runs." >&2
      exit 1
    fi
    # Source provision.sh FIRST — it resets PILA_MACHINE_ID="" at
    # load time (intended for provision_machine's create flow). Sourcing
    # after setting PILA_MACHINE_ID would clobber our resolver result.
    FLY_APP="${PILA_FLY_APP:-pila}"
    export FLY_APP
    export PILA_RUN_ID="$_stop_run_id"
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/remote/provision.sh"
    require_flyctl || exit 1
    # Try fly-machine.json first (in-flight bootstrap case), then
    # run.json — matches scripts/remote/attach.sh's resolution order.
    PILA_MACHINE_ID="$(_resolve_fly_machine_id_from_run_dir "$_stop_run_dir")"
    if [ -z "$PILA_MACHINE_ID" ]; then
      echo "pila: --stop: $_stop_run_id has no fly_machine_id (was it a local run?)" >&2
      exit 1
    fi
    export PILA_MACHINE_ID
    # Bootstrap a minimal run.json if only fly-machine.json exists, so
    # update_run_json has a file to merge paused_at into.
    _ensure_run_json "$_stop_run_dir" || true
    _stop_sidecar="$_stop_run_dir/run.json"
    echo "[pila] --stop: pausing machine $PILA_MACHINE_ID (run $PILA_RUN_ID)" >&2
    stop_machine
    update_run_json "$_stop_sidecar" \
      paused_at "$(iso_now)" \
      pause_reason "user-requested" \
      fly_machine_id "$PILA_MACHINE_ID" || true
    echo "[pila] --stop: paused. Resume via: pila --resume --run-id $PILA_RUN_ID --runtime fly" >&2
    exit 0
    ;;
  --kill)
    # Fast-path: explicit destroy of a remote run's machine (DESIGN §6
    # *The user-visible verb surface*). Confirmation prompt unless --force.
    # NOT resumable afterwards — sets killed_at on the sidecar.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    _kill_run_id=""
    _kill_machine_id=""
    _kill_force=0
    _kill_app=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --force) _kill_force=1; shift ;;
        --machine-id) _kill_machine_id="$2"; shift 2 ;;
        --machine-id=*) _kill_machine_id="${1#--machine-id=}"; shift ;;
        --app) _kill_app="$2"; shift 2 ;;
        --app=*) _kill_app="${1#--app=}"; shift ;;
        --*) echo "pila: unknown --kill flag: $1" >&2; exit 1 ;;
        *)
          if [ -z "$_kill_run_id" ]; then _kill_run_id="$1"; shift
          else echo "pila: unexpected --kill arg: $1" >&2; exit 1
          fi
          ;;
      esac
    done
    [ -n "${PILA_FORCE_KILL:-}" ] && _kill_force=1
    FLY_APP="${_kill_app:-${PILA_FLY_APP:-pila}}"
    export FLY_APP
    _kill_run_dir=""
    _kill_sidecar=""
    if [ -n "$_kill_run_id" ]; then
      _kill_run_dir="$USER_REPO/.pila/runs/$_kill_run_id"
      if [ ! -d "$_kill_run_dir" ] && [ -z "$_kill_machine_id" ]; then
        echo "pila: --kill: no run dir at $_kill_run_dir" >&2
        echo "  Pass --machine-id <id> to destroy an orphan machine without a sidecar." >&2
        exit 1
      fi
      if [ -d "$_kill_run_dir" ] && [ -z "$_kill_machine_id" ]; then
        # Try fly-machine.json first (in-flight bootstrap case), then
        # run.json — matches scripts/remote/attach.sh's resolution order.
        _kill_machine_id="$(_resolve_fly_machine_id_from_run_dir "$_kill_run_dir")"
      fi
    fi
    if [ -z "$_kill_machine_id" ]; then
      echo "pila: --kill: no fly_machine_id found." >&2
      echo "  Usage: pila --kill <run-id> [--force]" >&2
      echo "  Orphan: pila --kill --machine-id <id> [--app <app>]" >&2
      exit 1
    fi
    if [ "$_kill_force" != "1" ]; then
      # D3: context-aware confirmation label. When the user invoked the
      # orphan path (machine-id only, no run-id), asking for the run-id
      # is confusing — they have no run-id, only a machine-id.
      if [ -n "$_kill_run_id" ]; then
        _kill_prompt_target="$_kill_run_id"
        _kill_prompt_label="run-id"
      else
        _kill_prompt_target="$_kill_machine_id"
        _kill_prompt_label="machine-id"
      fi
      printf "This will destroy machine %s (run %s). Type the %s to confirm: " \
        "$_kill_machine_id" "$_kill_prompt_target" "$_kill_prompt_label" >&2
      read -r _kill_confirm
      if [ "$_kill_confirm" != "$_kill_prompt_target" ]; then
        echo "pila: --kill: confirmation mismatch; aborted." >&2
        exit 1
      fi
    fi
    # Source provision.sh BEFORE setting PILA_MACHINE_ID — it resets
    # PILA_MACHINE_ID="" at load time, which would clobber our value.
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/remote/provision.sh"
    require_flyctl || exit 1
    PILA_MACHINE_ID="$_kill_machine_id"
    export PILA_MACHINE_ID
    echo "[pila] --kill: destroying machine $PILA_MACHINE_ID" >&2
    destroy_machine
    # Bootstrap run.json from fly-machine.json if needed (in-flight
    # kill before classify) so killed_at + fly_machine_id are recorded
    # host-side for forensics. Note: a bootstrap-id killed run does NOT
    # appear in `pila --list` because `discover_runs` requires
    # state.json (which only the orchestrator writes); the run.json
    # written here is for audit-trail purposes only. Non-bootstrap kills
    # already have state.json from a prior fetch_branch or local run,
    # so they do appear in --list with status=killed-remote.
    if [ -n "$_kill_run_dir" ] && [ -d "$_kill_run_dir" ]; then
      _ensure_run_json "$_kill_run_dir" || true
      _kill_sidecar="$_kill_run_dir/run.json"
      if [ -f "$_kill_sidecar" ]; then
        update_run_json "$_kill_sidecar" \
          killed_at "$(iso_now)" \
          fly_machine_id "$_kill_machine_id" || true
      fi
    fi
    echo "[pila] --kill: destroyed. Run is no longer resumable." >&2
    exit 0
    ;;
  --finalize)
    # Fast-path: post-detach finalization (DESIGN §6 *Detached
    # orchestrator (remote mode)*). The detached orchestrator ran on the
    # Fly Machine; the launcher couldn't synchronously call fetch_branch
    # because it no longer waits for orchestrator exit. This verb runs
    # the post-orchestrator block: fetch_branch + push + gh pr create.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    _fin_run_id="${1:-}"
    if [ -z "$_fin_run_id" ]; then
      echo "pila: --finalize requires a <run-id>" >&2
      echo "  Usage: pila --finalize <run-id>" >&2
      exit 1
    fi
    _fin_run_dir="$USER_REPO/.pila/runs/$_fin_run_id"
    if [ ! -d "$_fin_run_dir" ]; then
      echo "pila: --finalize: no run dir at $_fin_run_dir" >&2
      exit 1
    fi
    # Short-circuit if already finalized (only possible once run.json
    # exists, i.e. after fetch_branch has run at least once).
    _fin_sidecar="$_fin_run_dir/run.json"
    if [ -f "$_fin_sidecar" ]; then
      _already="$(python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    print("yes" if d.get("pushed_at") else "")
except Exception:
    pass
' "$_fin_sidecar")"
      if [ -n "$_already" ]; then
        echo "[pila] --finalize: run $_fin_run_id is already pushed; nothing to do." >&2
        exit 0
      fi
    fi
    FLY_APP="${PILA_FLY_APP:-pila}"
    export FLY_APP PILA_RUN_ID="$_fin_run_id"
    # Source provision.sh BEFORE setting PILA_MACHINE_ID — provision.sh
    # resets PILA_MACHINE_ID="" at load time and would clobber our value.
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/remote/provision.sh"
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/remote/fetch-branch.sh"
    require_flyctl || exit 1
    # Try fly-machine.json first (in-flight bootstrap case), then
    # run.json — matches scripts/remote/attach.sh's resolution order.
    PILA_MACHINE_ID="$(_resolve_fly_machine_id_from_run_dir "$_fin_run_dir")"
    if [ -z "$PILA_MACHINE_ID" ]; then
      echo "pila: --finalize: $_fin_run_id has no fly_machine_id" >&2
      exit 1
    fi
    export PILA_MACHINE_ID
    echo "[pila] --finalize: streaming completed run from machine $PILA_MACHINE_ID" >&2
    if ! fetch_branch; then
      echo "pila: error: fetch_branch failed" >&2
      exit 1
    fi
    # fetch_branch sets PILA_REMOTE_RUN_ID to the discovered final run-id
    # (which may differ from $_fin_run_id if the user passed a bootstrap
    # id). Use the discovered id to locate the run dir host-side.
    _fetched_run_id="${PILA_REMOTE_RUN_ID:-$_fin_run_id}"
    _fetched_run_dir="$USER_REPO/.pila/runs/$_fetched_run_id"
    if [ ! -d "$_fetched_run_dir" ]; then
      echo "pila: error: fetch_branch succeeded but $_fetched_run_dir missing" >&2
      exit 1
    fi
    # Detect --no-verify from $@ for consistency with normal post-run path.
    NO_VERIFY_PUSH=false
    for _a in "$@"; do
      [ "$_a" = "--no-verify" ] && NO_VERIFY_PUSH=true
    done
    export NO_VERIFY_PUSH
    # shellcheck disable=SC1091
    . "$PILA_REPO/scripts/host-finalize.sh"
    host_finalize "$_fetched_run_dir"
    exit $?
    ;;
esac

# --- platform preflight --------------------------------------------------
OS="$(uname -s)"

print_install_hint() {
  case "$OS" in
    Darwin)
      if ! command -v brew >/dev/null 2>&1; then
        cat >&2 <<'EOF'

You need Homebrew first (pila uses brew to install Colima):
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

Or see https://brew.sh/ for alternatives.

After installing Homebrew, re-run pila — it will auto-install Colima.
EOF
      else
        cat >&2 <<'EOF'

Install on macOS:
  brew install colima
  colima start --runtime containerd --mount-type virtiofs
  # nerdctl shim is auto-installed by pila on first run; or manually:
  #   colima nerdctl install

(brew install nerdctl does NOT work on macOS — the nerdctl binary requires
a Linux kernel. Colima ships nerdctl inside its VM and installs a host-side
shim that proxies to it.)

See docs/INSTALL.md for details.
EOF
      fi
      ;;
    Linux)
      cat >&2 <<'EOF'

Install on Linux:
  # Debian/Ubuntu:
  sudo apt-get install -y containerd
  # then install nerdctl from upstream:
  #   https://github.com/containerd/nerdctl/releases
  # Or distro packages where available (Arch: pacman -S nerdctl).
  sudo systemctl enable --now containerd

See docs/INSTALL.md for rootless mode and other distros.
EOF
      ;;
    *)
      echo "pila: unsupported OS: $OS (need macOS or Linux)" >&2
      ;;
  esac
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "pila: missing required command: $1" >&2
    print_install_hint
    exit 1
  }
}

# --- runtime auto-install opt-out --------------------------------------
# Same flag/env shape as scripts/install.sh: --no-runtime-install on the
# CLI or PILA_NO_RUNTIME_INSTALL=1 in the env disables auto-install. We
# don't shift the flag off $@ — the orchestrator's argparse rejects
# unknown flags, so we just consume it before the orchestrator sees it
# (in the REWRITTEN_ARGS pass-through below).
case "${PILA_NO_RUNTIME_INSTALL:-}" in
  1|true|TRUE|yes|YES) NO_RUNTIME_INSTALL=true ;;
  *)                   NO_RUNTIME_INSTALL=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--no-runtime-install" ]; then
    NO_RUNTIME_INSTALL=true
  fi
done

# --- remote image auto-publish opt-out ---------------------------------
# Same shape: --no-auto-publish on the CLI or PILA_NO_AUTO_PUBLISH=1 in the
# env disables ensure_image() for the remote (Fly) path. The orchestrator
# never sees this flag — it's consumed in REWRITTEN_ARGS below.
case "${PILA_NO_AUTO_PUBLISH:-}" in
  1|true|TRUE|yes|YES) NO_AUTO_PUBLISH=true ;;
  *)                   NO_AUTO_PUBLISH=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--no-auto-publish" ]; then
    NO_AUTO_PUBLISH=true
  fi
done

# --- auto re-seed on --resume (Phase 4) --------------------------------
# Default behaviour: when resuming a paused remote run, automatically
# re-rsync the host's dirty set before re-exec'ing the orchestrator.
# --no-re-seed opts out (rate-limit auto-resume case where nothing changed).
# --force bypasses the safety check that refuses to clobber machine-side
# uncommitted edits.
NO_RE_SEED=false
RE_SEED_FORCE=false
for arg in "$@"; do
  case "$arg" in
    --no-re-seed) NO_RE_SEED=true ;;
    --force)      RE_SEED_FORCE=true ;;
  esac
done

# --- extract --run-id (passed through to orchestrator) -----------------
# The launcher needs the run-id early in the RUNTIME=fly branch so the
# remote provision step can write fly_machine_id to the sidecar
# (DESIGN §6 Remote pause-on-failure). We don't shift the arg off $@ —
# it's still forwarded via REWRITTEN_ARGS to the orchestrator's argparse.
PILA_RUN_ID=""
_prev=""
for arg in "$@"; do
  if [ "$_prev" = "--run-id" ]; then
    PILA_RUN_ID="$arg"
  fi
  case "$arg" in
    --run-id=*) PILA_RUN_ID="${arg#--run-id=}" ;;
  esac
  _prev="$arg"
done
export PILA_RUN_ID

# --- runtime-mode knob ---------------------------------------------------
# Resolves RUNTIME=local|fly. Precedence: CLI --runtime > PILA_RUNTIME env
# > pila.toml `runtime` key > default `local`. Mirrors the orchestrator's
# resolve_runtime() (pila.py) so the launcher routes correctly before the
# container starts.
#
# Backward-compat aliases: --remote / PILA_REMOTE / pila.toml `remote=true`
# map to RUNTIME=fly. The --remote flag is consumed here and not forwarded;
# --runtime is NOT consumed — it flows through REWRITTEN_ARGS to the
# orchestrator's own argparse.
RUNTIME=local
# Precedence (lowest → highest): default → legacy-toml → canonical-toml →
# legacy-env → canonical-env → CLI.  TOML is resolved first so env overrides it.
if [ -f "$USER_REPO/pila.toml" ]; then
  # legacy: remote = true
  toml_remote="$(awk '/^[[:space:]]*remote[[:space:]]*=/ {
                        gsub(/^[[:space:]]*remote[[:space:]]*=[[:space:]]*/, "", $0);
                        gsub(/^"|"$/, "", $0);
                        print; exit
                      }' "$USER_REPO/pila.toml" 2>/dev/null || true)"
  case "${toml_remote:-}" in
    1|true|TRUE|yes|YES) RUNTIME=fly ;;
  esac
  # canonical: runtime = local|fly
  toml_runtime="$(awk '/^[[:space:]]*runtime[[:space:]]*=/ {
                         gsub(/^[[:space:]]*runtime[[:space:]]*=[[:space:]]*/, "", $0);
                         gsub(/^"|"$/, "", $0);
                         print; exit
                       }' "$USER_REPO/pila.toml" 2>/dev/null || true)"
  case "${toml_runtime:-}" in
    local|fly) RUNTIME="${toml_runtime}" ;;
    "")        : ;;
    *)
      echo "pila: pila.toml: runtime=${toml_runtime} is not one of local|fly" >&2
      exit 1
      ;;
  esac
fi
# env alias (legacy) — overrides TOML
case "${PILA_REMOTE:-}" in
  1|true|TRUE|yes|YES) RUNTIME=fly ;;
esac
# env (canonical) — overrides TOML and legacy env alias
case "${PILA_RUNTIME:-}" in
  local|fly) RUNTIME="${PILA_RUNTIME}" ;;
  "")        : ;;
  *)
    echo "pila: PILA_RUNTIME=${PILA_RUNTIME} is not one of local|fly" >&2
    exit 1
    ;;
esac
# CLI (highest priority) — scanned before REWRITTEN_ARGS loop below.
# --remote sets RUNTIME=fly (legacy). --runtime=VALUE / --runtime VALUE set
# RUNTIME directly and also flow through to the orchestrator.
for arg in "$@"; do
  case "$arg" in
    --remote)           RUNTIME=fly ;;
    --runtime=local)    RUNTIME=local ;;
    --runtime=fly)      RUNTIME=fly ;;
    --runtime=*)
      echo "pila: --runtime=${arg#--runtime=} is not one of local|fly" >&2
      exit 1
      ;;
  esac
done
# Handle the two-argument form --runtime VALUE.
prev_was_runtime=false
for arg in "$@"; do
  if $prev_was_runtime; then
    case "$arg" in
      local|fly) RUNTIME="$arg" ;;
      *)
        echo "pila: --runtime $arg is not one of local|fly" >&2
        exit 1
        ;;
    esac
    prev_was_runtime=false
    continue
  fi
  if [ "$arg" = "--runtime" ]; then
    prev_was_runtime=true
  fi
done
# Maintain backward-compat REMOTE alias consumed downstream.
REMOTE=false
[ "$RUNTIME" = "fly" ] && REMOTE=true

# DRY_RUN is referenced by scripts/runtime-install.sh; default to false
# in the launcher (the launcher has no --dry-run flag — that's install.sh).
DRY_RUN=false

# Source the shared runtime-install helpers. PILA_REPO points at the
# pila install directory (where scripts/ lives) — already resolved at
# the top of this script via the symlink walk.
if [ -f "$PILA_REPO/scripts/runtime-install.sh" ]; then
  # shellcheck disable=SC1091
  . "$PILA_REPO/scripts/runtime-install.sh"
fi

# Colima/containerd preflight is only needed for local nerdctl invocations.
# Skip entirely when RUNTIME=fly (or any future non-local runtime).
if [ "$RUNTIME" = "local" ]; then
case "$OS" in
  Darwin)
    # Auto-install Colima if missing, with a TTY guard. The brew install
    # step may prompt for sudo; in plugin mode (no TTY) the prompt would
    # hang. Mirror the pattern at line ~135 (nerdctl-shim install).
    if ! command -v colima >/dev/null 2>&1; then
      if [ "$NO_RUNTIME_INSTALL" = "true" ]; then
        echo "pila: Colima is missing (auto-install skipped via --no-runtime-install)." >&2
        print_install_hint
        exit 1
      fi
      if [ -t 0 ]; then
        echo "[pila] Colima is missing — installing now (one-time; may prompt for sudo)..." >&2
        if ! runtime_install_macos; then
          print_install_hint
          exit 1
        fi
      else
        echo "pila: Colima is not installed and we have no terminal to" >&2
        echo "  prompt for sudo / brew install. Run pila once from a" >&2
        echo "  terminal so the one-time install can complete:" >&2
        echo "    pila --version" >&2
        echo "  Or install Colima manually:" >&2
        echo "    brew install colima" >&2
        exit 1
      fi
    fi
    # Don't auto-start Colima — if the user has an existing setup with
    # dockerd we'd clobber their preference. Give a clear hint instead.
    if ! colima status >/dev/null 2>&1; then
      echo "pila: Colima VM is not running." >&2
      echo "  Start it with:  colima start --runtime containerd --mount-type virtiofs" >&2
      exit 1
    fi
    # nerdctl reaches containerd via Colima's host-side shim
    # (`colima nerdctl install`). The install writes to /usr/local/bin
    # (root-owned on macOS) via `sudo`, which prompts interactively. In
    # plugin mode (no TTY) the sudo prompt blocks forever; detect and bail
    # with a clear hint instead of hanging.
    if ! command -v nerdctl >/dev/null 2>&1; then
      if [ -t 0 ]; then
        echo "[pila] installing host-side nerdctl shim (one-time; may prompt for sudo)..." >&2
        if ! colima nerdctl install >&2; then
          echo "pila: failed to install nerdctl shim — run 'colima nerdctl install' manually" >&2
          exit 1
        fi
      else
        echo "pila: nerdctl shim is not installed and we have no terminal to run sudo." >&2
        echo "  Run this once from a terminal, then re-invoke /pila:" >&2
        echo "    colima nerdctl install" >&2
        exit 1
      fi
    fi
    if ! nerdctl info >/dev/null 2>&1; then
      echo "pila: nerdctl cannot reach the container runtime." >&2
      echo "  Ensure Colima was started with --runtime containerd:" >&2
      echo "    colima stop && colima start --runtime containerd --mount-type virtiofs" >&2
      exit 1
    fi
    # Colima auto-shares only paths under /Users/$USER by default. If any
    # bind mount we're about to make falls outside, the mount silently
    # appears empty inside the container. Warn early.
    USER_HOME_PREFIX="/Users/$(id -un)"
    check_under_home() {
      case "$1" in
        "$USER_HOME_PREFIX"|"$USER_HOME_PREFIX"/*) return 0 ;;
        *)
          echo "pila: warning — '$1' is outside $USER_HOME_PREFIX" >&2
          echo "  and may appear empty in the container. Add it to Colima's" >&2
          echo "  mount list: edit ~/.colima/default/colima.yaml's 'mounts:'" >&2
          echo "  section, then 'colima restart'." >&2
          return 1
          ;;
      esac
    }
    check_under_home "$USER_REPO" || true
    check_under_home "$PILA_REPO" || true
    ;;
  Linux)
    # Auto-install nerdctl + containerd if missing, with a TTY guard.
    # `sudo apt-get install` etc. would hang in plugin mode without TTY.
    if ! command -v nerdctl >/dev/null 2>&1; then
      if [ "$NO_RUNTIME_INSTALL" = "true" ]; then
        echo "pila: nerdctl is missing (auto-install skipped via --no-runtime-install)." >&2
        print_install_hint
        exit 1
      fi
      if [ -t 0 ]; then
        echo "[pila] nerdctl is missing — installing containerd + nerdctl (one-time; may prompt for sudo)..." >&2
        if ! runtime_install_linux; then
          print_install_hint
          exit 1
        fi
      else
        echo "pila: nerdctl is not installed and we have no terminal to" >&2
        echo "  prompt for sudo. Run pila once from a terminal so the" >&2
        echo "  one-time install can complete:" >&2
        echo "    pila --version" >&2
        exit 1
      fi
    fi
    if ! nerdctl info >/dev/null 2>&1; then
      echo "pila: nerdctl cannot reach containerd." >&2
      echo "  Ensure containerd is running:  systemctl status containerd" >&2
      echo "  For rootless mode see docs/INSTALL.md." >&2
      exit 1
    fi
    ;;
  *)
    echo "pila: unsupported OS: $OS" >&2
    print_install_hint
    exit 1
    ;;
esac
fi  # end RUNTIME=local preflight

# --- host preflight: git repo + gh + jq ---------------------------------
# These checks moved out of the orchestrator (DESIGN §6 *Finalization*).
# The launcher does the host-side push + PR after the container exits,
# so the auth state needs to be valid on the host BEFORE we spin up the
# container. Fast-fail with actionable messages.
#
# `--no-push` shortcuts the gh + origin checks (the launcher will skip
# the host-side finalize entirely). The flag is also passed through to
# the orchestrator so phase_finalize knows not to do its own bookkeeping.
NO_PUSH=false
for arg in "$@"; do
  case "$arg" in
    --no-push) NO_PUSH=true ;;
  esac
done
case "${PILA_NO_PUSH:-}" in
  1|true|TRUE|yes|YES) NO_PUSH=true ;;
esac

# 1. cwd is a git repo (orchestrator's old check at pila.py:7652).
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "pila: error: not inside a git repository" >&2
  exit 1
fi

# 2. origin remote present (required for `git push`). Skipped under
#    --no-push. We do NOT preflight `gh auth status` or even check `gh`
#    presence here — both are needed only at PR-creation time, and
#    `gh pr create` failure is non-fatal (the run branch is already
#    pushed; the user can open the PR manually with the printed retry
#    command). Preflighting gh auth surfaced false-positives without
#    catching anything the post-push failure path doesn't handle.
if [ "$NO_PUSH" = "false" ]; then
  if ! git remote get-url origin >/dev/null 2>&1; then
    echo "pila: error: this repository has no \`origin\` remote — finalize cannot" >&2
    echo "  push without one. Add one with \`git remote add origin <url>\` or pass" >&2
    echo "  \`--no-push\`." >&2
    exit 1
  fi
fi

# 3. jq is needed for the host-side finalize to read run.json /
#    state.json. Hard-fail on macOS (brew install jq) and Linux (distro
#    package manager); we use jq for the body composition + state writes.
if [ "$NO_PUSH" = "false" ] && ! command -v jq >/dev/null 2>&1; then
  echo "pila: error: \`jq\` not found on PATH." >&2
  case "$OS" in
    Darwin) echo "  Install with: brew install jq" >&2 ;;
    Linux)  echo "  Install with your distro package manager (apt install jq / dnf install jq / pacman -S jq)." >&2 ;;
  esac
  echo "  Or pass --no-push to skip the host-side finalize." >&2
  exit 1
fi

# --- build image if not present (one-time, ~60-120s) --------------------
if ! nerdctl image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  echo "[pila] building container image (one-time; ~60-120s)..." >&2
  nerdctl build \
    --build-arg HOST_UID="$(id -u)" \
    --build-arg HOST_GID="$(id -g)" \
    -t "$IMAGE_TAG" \
    "$PILA_REPO"
fi

# --- translate --inspect-dir paths into bind-mounts ---------------------
# Each --inspect-dir path points at a host-absolute directory the
# inspect-bucket workers need read access to (--add-dir under the hood).
# Bind-mount each one read-only at /inspect/<basename> and rewrite the arg
# so the in-container view matches. Paths from PILA_INSPECT_DIRS (colon-sep)
# and pila.toml's inspect_dirs (comma-sep) need the same treatment — we
# resolve them on the host and emit --inspect-dir CLI flags. PILA_INSPECT_DIRS
# is cleared inside the container so resolve_inspect_dirs() picks up only
# our rewritten CLI flags.
INSPECT_MOUNTS=()
REWRITTEN_ARGS=()
INSPECT_NAMES=()

collect_inspect_path() {
  local host_path expanded resolved base mount_target user_repo_resolved
  host_path="$1"
  # Expand leading ~ — `cd` won't on its own.
  case "$host_path" in
    "~")   expanded="$HOME" ;;
    "~/"*) expanded="$HOME/${host_path#~/}" ;;
    *)     expanded="$host_path" ;;
  esac
  resolved="$(cd -P "$expanded" 2>/dev/null && pwd)" || {
    echo "pila: --inspect-dir path not found: $host_path" >&2
    exit 1
  }
  # If the path is inside $USER_REPO it's already visible at /work/<sub>,
  # so a second mount under /inspect/ would be redundant. Warn and skip.
  user_repo_resolved="$(cd -P "$USER_REPO" && pwd)"
  case "$resolved" in
    "$user_repo_resolved"|"$user_repo_resolved"/*)
      # Quote $user_repo_resolved inside ${...#...} so bash strips a literal
      # prefix instead of treating the value as a glob pattern (shellcheck
      # SC2295). Paths typically lack glob metachars, but the cost of
      # defensiveness is one quote-pair.
      local rel="${resolved#"$user_repo_resolved"}"
      echo "pila: --inspect-dir '$host_path' is inside the repo; skipping redundant mount" >&2
      REWRITTEN_ARGS+=(--inspect-dir "/work${rel}")
      return 0
      ;;
  esac
  base="$(basename "$resolved")"
  # Disambiguate basename collisions (e.g. two paths both named "src") by
  # appending a numeric suffix. Use [[ ]] for glob-style membership test;
  # surround with spaces so adjacent words don't match a substring.
  local existing=" ${INSPECT_NAMES[*]:-} "
  local candidate="$base"
  local i=2
  while [[ "$existing" == *" $candidate "* ]]; do
    candidate="$base-$i"
    i=$((i + 1))
  done
  base="$candidate"
  mount_target="/inspect/$base"
  INSPECT_NAMES+=("$base")
  INSPECT_MOUNTS+=(-v "$resolved:$mount_target:ro")
  REWRITTEN_ARGS+=(--inspect-dir "$mount_target")
}

# Pre-pass: PILA_INSPECT_DIRS env (colon-separated).
if [ -n "${PILA_INSPECT_DIRS:-}" ]; then
  OIFS="$IFS"; IFS=":"
  for p in $PILA_INSPECT_DIRS; do
    [ -z "$p" ] || collect_inspect_path "$p"
  done
  IFS="$OIFS"
fi
# Pre-pass: pila.toml inspect_dirs key (comma-separated).
# The orchestrator's resolve_inspect_dirs() precedence is CLI > env > TOML,
# so once we emit --inspect-dir CLI flags here, the in-container TOML pass
# is bypassed. Best-effort parse: awk-grep the simple key=value form.
if [ -f "$USER_REPO/pila.toml" ]; then
  toml_dirs="$(awk -F= '/^[[:space:]]*inspect_dirs[[:space:]]*=/ {
                          gsub(/^[[:space:]]*inspect_dirs[[:space:]]*=[[:space:]]*/, "", $0);
                          gsub(/^"|"$/, "", $0);
                          print; exit
                        }' "$USER_REPO/pila.toml" 2>/dev/null || true)"
  if [ -n "$toml_dirs" ]; then
    OIFS="$IFS"; IFS=","
    for p in $toml_dirs; do
      # Trim whitespace.
      p="$(printf '%s' "$p" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      [ -z "$p" ] || collect_inspect_path "$p"
    done
    IFS="$OIFS"
  fi
fi
# Main pass: rewrite --inspect-dir in $@. The orchestrator's argparse
# declares only --inspect-dir (no -i alias — see pila.py:6079), so we
# intercept exactly that one form and let everything else flow through.
prev_was_inspect=false
for arg in "$@"; do
  if $prev_was_inspect; then
    collect_inspect_path "$arg"
    prev_was_inspect=false
    continue
  fi
  case "$arg" in
    --inspect-dir)
      prev_was_inspect=true
      ;;
    --inspect-dir=*)
      collect_inspect_path "${arg#--inspect-dir=}"
      ;;
    --no-runtime-install)
      # Launcher-only flag; consumed by the runtime preflight above.
      # The orchestrator's argparse doesn't know it.
      ;;
    --no-auto-publish)
      # Launcher-only flag; consumed by ensure_image() in the remote path.
      ;;
    --no-re-seed)
      # Launcher-only flag (Phase 4); consumed by the auto-re-seed-on-resume
      # block. The orchestrator's argparse doesn't know it.
      ;;
    --force)
      # Launcher-only flag (Phase 4); bypasses re_seed's safety check.
      ;;
    --remote)
      # Launcher-only flag (legacy alias for --runtime fly); consumed by
      # the runtime-mode knob above. The orchestrator's argparse doesn't know it.
      ;;
    *)
      REWRITTEN_ARGS+=("$arg")
      ;;
  esac
done

# --- assemble auth/config mounts ----------------------------------------
# Per-container config isolation. The shared host ~/.claude.json is a
# documented corruption race (anthropics/claude-code issues #28847,
# #29217, #29395, #40226 — all open). Each container gets its own copy
# of every claude/git/ssh/gpg config file it needs, staged on the host
# in a per-run scratch dir and mounted at the default in-container
# paths. Container sees normal locations; no shared host state to race.
AUTH_MOUNTS=()

if [ ! -d "$HOME/.claude" ]; then
  echo "pila: $HOME/.claude not found — run \`claude\` at least once first" >&2
  exit 1
fi
if [ ! -f "$HOME/.claude.json" ]; then
  echo "pila: $HOME/.claude.json not found — run \`claude\` at least once first" >&2
  exit 1
fi

# Scratch dir lives under ~/.cache/pila/ (not $TMPDIR) so Colima's
# default mount config auto-shares it on macOS — $TMPDIR resolves to
# /var/folders/... on Darwin, which is outside the /Users/$USER share
# Colima exposes by default, and the bind mount would silently appear
# empty inside the container. Linux is unaffected (any host path is
# nerdctl-mountable) but the ~/.cache/pila/ home keeps the launcher
# uniform across platforms and matches the existing cache-dir
# convention used for mise / pnpm / pip / go / cargo (see below).
mkdir -p "$HOME/.cache/pila"
STAGE="$(mktemp -d "$HOME/.cache/pila/cfg-XXXXXX")"

# -- .claude.json: copy with projects[] stripped. --
# The projects[] block stores prior-session per-project state
# (lastSessionId, lastCost, MCP allowlists). Stripping it gives the
# worker a clean slate on /work as a brand-new project.
python3 - "$HOME/.claude.json" "$STAGE/.claude.json" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
d.pop("projects", None)
json.dump(d, open(sys.argv[2], "w"))
PY

# -- .claude/: copy with prior-session / history / bulk dirs skipped. --
# Blacklist (not whitelist) so a newly-added capability dir Anthropic
# ships in a future release rides along by default. Update this list
# only when something *bulky and session-shaped* lands.
mkdir "$STAGE/.claude"
CLAUDE_SKIP=(
  history.jsonl     # global prompt history (22+ MB)
  projects          # per-project session transcripts
  sessions          # session metadata
  tasks plans todos # prior-session task state
  file-history      # per-session file-edit snapshots
  paste-cache       # per-session paste tracking
  shell-snapshots   # per-shell snapshots
  session-env       # per-session env snapshots
  telemetry         # CLI telemetry (we own our own)
  stats-cache.json  # per-session stats cache
  debug             # debug dumps
  downloads         # downloaded files
  backups           # .claude.json backups (we own our copy)
  chrome            # Chrome integration state
  ralph-state       # plugin state from prior sessions
  .last-cleanup     # cleanup marker (regenerates)
)
if command -v rsync >/dev/null 2>&1; then
  EXCLUDES=()
  for s in "${CLAUDE_SKIP[@]}"; do EXCLUDES+=(--exclude="$s"); done
  rsync -a "${EXCLUDES[@]}" --exclude='settings.json.*' \
    "$HOME/.claude/" "$STAGE/.claude/"
else
  cp -aR "$HOME/.claude/." "$STAGE/.claude/"
  for s in "${CLAUDE_SKIP[@]}"; do
    rm -rf "$STAGE/.claude/$s"
  done
  rm -f "$STAGE"/.claude/settings.json.*
fi

# -- macOS-only: extract OAuth credentials from Keychain. --
# On macOS the CLI stores its OAuth token in the Keychain (service
# `Claude Code-credentials`), not in a file. The Linux CLI reads the
# same JSON from ~/.claude/.credentials.json, so writing the Keychain
# blob to that path inside the container's staged .claude/ makes the
# Linux file-based code path work transparently on both platforms.
#
# MUST run AFTER the .claude/ copy above, otherwise the rsync would
# overwrite the credentials file.
#
# `security find-generic-password -w` succeeds silently when the
# caller is in the user's login session (which `./pila` always is);
# outside that (SSH-without-tty, daemons) it would prompt or fail.
# Best-effort: if extraction fails, fall back to the legacy
# CLAUDE_CODE_OAUTH_TOKEN env-var bridge so workers still authenticate.
if [ "$OS" = "Darwin" ]; then
  if security find-generic-password -s "Claude Code-credentials" \
       -w >"$STAGE/.claude/.credentials.json" 2>/dev/null && \
     [ -s "$STAGE/.claude/.credentials.json" ]; then
    chmod 600 "$STAGE/.claude/.credentials.json"
  else
    rm -f "$STAGE/.claude/.credentials.json"
    if [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
      AUTH_MOUNTS+=(-e "CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN")
    else
      echo "pila: note — could not extract Claude credentials from Keychain." >&2
      echo "  Export CLAUDE_CODE_OAUTH_TOKEN in your shell, or grant the launcher" >&2
      echo "  Keychain access (the prompt that pops up the first time)." >&2
    fi
  fi
fi

# -- ~/.git* dotfiles + XDG ~/.config/git/. --
# Copy every host-side ~/.git* sibling that exists (.gitconfig,
# .gitconfig.local, .gitignore_global, .gitignore, .git-credentials)
# plus the XDG config dir. Each lands in $STAGE at the path that maps
# to its default in-container location.
for f in "$HOME"/.git*; do
  [ -e "$f" ] || continue
  cp -aR "$f" "$STAGE/"
done
if [ -d "$HOME/.config/git" ]; then
  mkdir -p "$STAGE/.config"
  cp -aR "$HOME/.config/git" "$STAGE/.config/"
fi

# -- ~/.netrc, ~/.ssh/, ~/.gnupg/ (auth/signing material). --
# Workers may need to push (SSH), authenticate over HTTPS (.netrc),
# or sign commits (GPG). Colima runs the VM on the same machine the
# host user already controls, so the trust boundary doesn't widen by
# exposing these to a container that user already owns. Exposure is
# per-container and the staging dir is reaped on exit. CRITICAL:
# filter out sockets and ephemeral runtime files — the agent sockets
# (S.gpg-agent, ssh-agent's UNIX sockets) are host-bound, can't be
# `cp -a`'d cleanly, and aren't reachable from inside the container.
if [ -f "$HOME/.netrc" ]; then
  cp -a "$HOME/.netrc" "$STAGE/.netrc"
fi
if [ -d "$HOME/.ssh" ]; then
  mkdir -p "$STAGE/.ssh"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a \
      --exclude='agent' --exclude='S.*' --exclude='*.sock' \
      "$HOME/.ssh/" "$STAGE/.ssh/"
  else
    cp -aR "$HOME/.ssh/." "$STAGE/.ssh/"
    rm -rf "$STAGE/.ssh/agent"
    find "$STAGE/.ssh" -name 'S.*' -delete 2>/dev/null
    find "$STAGE/.ssh" -name '*.sock' -delete 2>/dev/null
  fi
  chmod 700 "$STAGE/.ssh"
fi
if [ -d "$HOME/.gnupg" ]; then
  mkdir -p "$STAGE/.gnupg"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --exclude='S.*' --exclude='*.sock' \
      "$HOME/.gnupg/" "$STAGE/.gnupg/"
  else
    cp -aR "$HOME/.gnupg/." "$STAGE/.gnupg/"
    find "$STAGE/.gnupg" -name 'S.*' -delete 2>/dev/null
    find "$STAGE/.gnupg" -name '*.sock' -delete 2>/dev/null
  fi
  chmod 700 "$STAGE/.gnupg"
fi

# -- Mount each staged file/dir at its default in-container path. --
# Files mount as files; dirs mount as dirs. The container sees the
# normal default paths — no env-var redirection needed.
AUTH_MOUNTS+=(-v "$STAGE/.claude.json:/home/pila/.claude.json")
AUTH_MOUNTS+=(-v "$STAGE/.claude:/home/pila/.claude")
for relpath in .gitconfig .gitconfig.local .gitignore \
               .gitignore_global .git-credentials .netrc; do
  if [ -e "$STAGE/$relpath" ]; then
    AUTH_MOUNTS+=(-v "$STAGE/$relpath:/home/pila/$relpath")
  fi
done
if [ -d "$STAGE/.config/git" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.config/git:/home/pila/.config/git")
fi
if [ -d "$STAGE/.ssh" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.ssh:/home/pila/.ssh")
fi
if [ -d "$STAGE/.gnupg" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.gnupg:/home/pila/.gnupg")
fi

# Best-effort host cleanup. Container is --rm; its writes inside the
# mounts vanish with the container. This removes the host scratch.
trap 'rm -rf "$STAGE"' EXIT

# --- finalize-phase auth is host-side now -------------------------------
# Previous versions of pila bind-mounted ~/.config/gh, ~/.git-credentials,
# ~/.ssh, and $SSH_AUTH_SOCK into the container so finalize could push
# and open a PR. After DESIGN §6 *Finalization* moved that step to the
# host launcher (post-container-exit), those mounts are no longer
# necessary — git/gh/ssh run with the host's own auth state, where they
# already work. The host preflight above verified gh auth + origin.

# --- per-repo dependency caches (DESIGN §6½, IMPLEMENTATION §0.5) -------
# Five host-side cache dirs survive across runs so:
#   - mise doesn't re-install Node 20.11.0 every time the user runs pila
#     against a repo with .nvmrc: 20.11.0,
#   - pnpm / pip / Go / Cargo installs hit warm caches.
# Created lazily (mkdir -p) on every pila invocation — cheap on existing
# dirs, free of failure modes on first run.
# Concurrency-safety per cache is documented in IMPLEMENTATION §0.5;
# pip's pattern (warm once serially in phase_provision, hit cached
# wheels in parallel from worktree replays) is documented in DESIGN §6½.
mkdir -p "$HOME/.cache/pila/mise-data" \
         "$HOME/.cache/pila/pnpm-store" \
         "$HOME/.cache/pila/pip" \
         "$HOME/.cache/pila/go-mod" \
         "$HOME/.cache/pila/cargo"

CACHE_MOUNTS=(
  -v "$HOME/.cache/pila/mise-data:/home/pila/.local/share/mise"
  -v "$HOME/.cache/pila/pnpm-store:/home/pila/.cache/pila/pnpm-store"
  -v "$HOME/.cache/pila/pip:/home/pila/.cache/pila/pip"
  -v "$HOME/.cache/pila/go-mod:/home/pila/.cache/pila/go-mod"
  -v "$HOME/.cache/pila/cargo:/home/pila/.cache/pila/cargo"
  # pnpm reads its store path from `npm_config_store_dir` (or `store-dir`
  # in .npmrc, or `--store-dir` CLI). There is no `PNPM_STORE_PATH`; a
  # prior version of this file set that and pnpm silently ignored it,
  # falling back to ~/.local/share/pnpm/store inside the container —
  # which is NOT bind-mounted, so every run paid full registry cost.
  -e "npm_config_store_dir=/home/pila/.cache/pila/pnpm-store"
  -e "PIP_CACHE_DIR=/home/pila/.cache/pila/pip"
  -e "GOMODCACHE=/home/pila/.cache/pila/go-mod"
  -e "CARGO_HOME=/home/pila/.cache/pila/cargo"
)
# MISE_DATA_DIR / MISE_SYSTEM_DATA_DIR are baked into the image as ENV
# (Dockerfile) so the resolver and mount target are stable across
# launcher invocations. Not user-tunable here.

# --- remote: resolve Fly.io image tag -----------------------------------
# FLY_IMAGE_TAG is the registry-tagged image that will be launched as a
# Fly Machine. It is only resolved when REMOTE=true so the local path
# does not pay the version-lookup cost.
resolve_fly_image_tag() {
  local fly_app region version tag
  fly_app="${PILA_FLY_APP:-pila}"
  region="${FLY_REGION:-iad}"
  version="$PILA_VERSION"
  tag="registry.fly.io/$fly_app:$version"
  # Allow the caller to override the full tag via env.
  echo "${PILA_FLY_IMAGE:-$tag}"
}

# --- remote: ensure published image -------------------------------------
# Closes the operator-step gap where the first remote run fails because
# the registry tag wasn't built/pushed yet. Strategy: cache positive hits
# in ~/.cache/pila/published-tags.txt; on miss, invoke build-push.sh
# --push (which is idempotent at the registry — pushing an already-
# present manifest just no-ops the layers). The cache is a *positive*
# list only, so a manual `flyctl image` deletion is self-healing.
#
# Skipped entirely when NO_AUTO_PUBLISH=true (the operator manages
# publishes themselves and accepts the manifest-not-found failure mode).
ensure_image() {
  local tag="$1" cache_dir cache_file
  cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/pila"
  cache_file="$cache_dir/published-tags.txt"
  if [ -f "$cache_file" ] && grep -Fxq "$tag" "$cache_file" 2>/dev/null; then
    return 0
  fi
  local build_push="$PILA_REPO/scripts/remote/build-push.sh"
  if [ ! -x "$build_push" ]; then
    echo "pila: error: $build_push not found or not executable" >&2
    return 1
  fi
  local fly_app="${PILA_FLY_APP:-pila}"
  echo "[pila] remote: ensuring image $tag is published (cache miss)" >&2
  if ! "$build_push" --app "$fly_app" --push; then
    echo "pila: error: build-push.sh failed; remote run cannot proceed" >&2
    return 1
  fi
  mkdir -p "$cache_dir"
  printf '%s\n' "$tag" >> "$cache_file"
  return 0
}

# --- run -----------------------------------------------------------------
container_rc=0
if [ "$RUNTIME" = "fly" ]; then
  # --- remote execution path (Fly.io Machines) -------------------------
  # provision.sh implements the machine create → started → destroy-on-exit
  # lifecycle — the remote equivalent of `nerdctl run --rm`.
  # Sourcing it brings provision_machine() and destroy_machine() into scope
  # and registers an EXIT/INT/TERM trap after the machine starts so no
  # Ctrl-C or crash can leak a machine.
  #
  # seed-auth.sh seeds Claude config + git identity so `claude -p` workers can
  # authenticate and commit. seed-repo.sh provides two-channel repo seeding:
  # git clone --filter=blob:none for the committed bulk, then rsync of the local
  # dirty set via flyctl machine exec tar. Orchestration inside the machine
  # follows after both seedings succeed.
  echo "[pila] remote: starting Fly.io machine (--runtime fly / PILA_RUNTIME=fly / pila.toml runtime=fly)" >&2

  # Preflight: ensure flyctl is on PATH and authenticated. require_flyctl
  # in lib.sh handles auto-install on first --runtime fly use (parallels
  # the local-runtime auto-install in scripts/install.sh). Respects
  # --no-runtime-install / PILA_NO_RUNTIME_INSTALL=1 (falls back to
  # hint+exit). Must run before ensure_image (which uses flyctl to push)
  # and before any other remote script is sourced.
  # shellcheck disable=SC1091
  . "$PILA_REPO/scripts/remote/lib.sh"
  if ! require_flyctl; then
    exit 1
  fi

  # Generate a bootstrap run-id host-side if the user did not pass --run-id.
  # The orchestrator runs detached on the Fly Machine and the launcher's
  # tail needs to know which orchestrator.log path to follow *before* the
  # orchestrator has produced any output. The bootstrap id matches today's
  # orchestrator-side pre-classification pattern (`_bootstrap-<6hex>`); the
  # orchestrator will rename the dir to a category-prefixed final id at the
  # end of phase_classify (State.rename_to). The launcher's tail wrapper
  # handles the rename by polling for the final id afterwards. See DESIGN
  # §6 *Detached orchestrator (remote mode)*.
  if [ -z "$PILA_RUN_ID" ]; then
    PILA_RUN_ID="_bootstrap-$(python3 -c "import secrets; print(secrets.token_hex(3))")"
    export PILA_RUN_ID
    # Append --run-id to REWRITTEN_ARGS so the orchestrator inside the
    # machine uses the same id (matches the --resume --run-id plumbing).
    REWRITTEN_ARGS+=("--run-id" "$PILA_RUN_ID")
  fi

  FLY_IMAGE_TAG="$(resolve_fly_image_tag)"
  export FLY_IMAGE_TAG

  # Ensure the image is published before flyctl machine run attempts to pull
  # it. Skipped if --no-auto-publish / PILA_NO_AUTO_PUBLISH=1 — the operator
  # is responsible for the build-push in that mode.
  if [ "$NO_AUTO_PUBLISH" != "true" ]; then
    if ! ensure_image "$FLY_IMAGE_TAG"; then
      exit 1
    fi
  fi

  PROVISION_SCRIPT="$PILA_REPO/scripts/remote/provision.sh"
  RESUME_SCRIPT="$PILA_REPO/scripts/remote/resume-machine.sh"
  SEED_AUTH_SCRIPT="$PILA_REPO/scripts/remote/seed-auth.sh"
  SEED_SCRIPT="$PILA_REPO/scripts/remote/seed-repo.sh"
  FETCH_SCRIPT="$PILA_REPO/scripts/remote/fetch-branch.sh"
  if [ ! -f "$PROVISION_SCRIPT" ]; then
    echo "pila: error: $PROVISION_SCRIPT not found" >&2
    container_rc=1
  elif [ ! -f "$RESUME_SCRIPT" ]; then
    echo "pila: error: $RESUME_SCRIPT not found" >&2
    container_rc=1
  elif [ ! -f "$SEED_AUTH_SCRIPT" ]; then
    echo "pila: error: $SEED_AUTH_SCRIPT not found" >&2
    container_rc=1
  elif [ ! -f "$SEED_SCRIPT" ]; then
    echo "pila: error: $SEED_SCRIPT not found" >&2
    container_rc=1
  elif [ ! -f "$FETCH_SCRIPT" ]; then
    echo "pila: error: $FETCH_SCRIPT not found" >&2
    container_rc=1
  else
    # shellcheck disable=SC1090
    . "$PROVISION_SCRIPT"
    # shellcheck disable=SC1090
    . "$RESUME_SCRIPT"
    # shellcheck disable=SC1090
    . "$SEED_AUTH_SCRIPT"
    # shellcheck disable=SC1090
    . "$SEED_SCRIPT"
    # shellcheck disable=SC1090
    . "$FETCH_SCRIPT"

    # Pause-on-failure resume path: if --run-id <id> is set and the run
    # sidecar has paused_at set, resume the existing Fly Machine instead
    # of provisioning a new one. (DESIGN §6 Remote pause-on-failure.)
    _paused_mid=""
    if [ -n "$PILA_RUN_ID" ]; then
      _sidecar="$USER_REPO/.pila/runs/$PILA_RUN_ID/run.json"
      if [ -f "$_sidecar" ]; then
        _paused_mid="$(python3 -c "
import json,sys
try:
    d = json.load(open(sys.argv[1]))
    if d.get('paused_at') and d.get('fly_machine_id'):
        print(d['fly_machine_id'])
except Exception:
    pass
" "$_sidecar" 2>/dev/null || true)"
      fi
    fi

    _provisioned=false
    _resumed=false
    if [ -n "$_paused_mid" ]; then
      if resume_machine "$_paused_mid"; then
        _provisioned=true
        _resumed=true
      fi
    elif provision_machine; then
      _provisioned=true
    fi

    # E1: when resuming a bootstrap-id paused via `pila --stop`, the
    # orchestrator on the machine has already renamed its run dir to
    # the final id via State.rename_to. Resuming with --run-id
    # _bootstrap-XXX would die in resolve_run_id (which skips
    # `_bootstrap-*` dirs). The orchestrator wrote the final id back to
    # /work/.pila/launcher-<bootstrap>.runid before renaming — read it
    # over SSH, then rewrite PILA_RUN_ID and the --run-id element of
    # REWRITTEN_ARGS before the orchestrator is exec'd. Migrate the
    # host-side run dir (D2 created `_bootstrap-XXX/run.json`) to the
    # final id so `pila --list` and subsequent verbs find the run by
    # its real name.
    if [ "$_resumed" = "true" ] && \
       [ -n "$PILA_RUN_ID" ] && \
       [[ "$PILA_RUN_ID" == _bootstrap-* ]]; then
      _bootstrap_pid="$PILA_RUN_ID"
      _final_id="$(flyctl machine exec "$PILA_MACHINE_ID" \
                     --app "$FLY_APP" \
                     -- cat "/work/.pila/launcher-${_bootstrap_pid}.runid" \
                     2>/dev/null | head -1 | tr -d '[:space:]' || true)"
      if [ -n "$_final_id" ] && [ "$_final_id" != "$_bootstrap_pid" ]; then
        echo "[pila] remote: bootstrap id ${_bootstrap_pid} promoted to ${_final_id} on machine — rewriting PILA_RUN_ID" >&2
        # Migrate host-side run dir if needed.
        _host_boot_dir="$USER_REPO/.pila/runs/${_bootstrap_pid}"
        _host_final_dir="$USER_REPO/.pila/runs/${_final_id}"
        if [ -d "$_host_boot_dir" ] && [ ! -d "$_host_final_dir" ]; then
          mv "$_host_boot_dir" "$_host_final_dir" 2>/dev/null || true
        fi
        # Rewrite PILA_RUN_ID and any `--run-id <bootstrap>` element in
        # REWRITTEN_ARGS (the user typed `--resume --run-id <bootstrap>`,
        # the loop at line ~920 passed it through).
        PILA_RUN_ID="$_final_id"
        export PILA_RUN_ID
        _rewritten_count="${#REWRITTEN_ARGS[@]}"
        _i=0
        while [ "$_i" -lt "$_rewritten_count" ]; do
          if [ "${REWRITTEN_ARGS[$_i]}" = "--run-id" ] && \
             [ "$((_i + 1))" -lt "$_rewritten_count" ] && \
             [ "${REWRITTEN_ARGS[$((_i + 1))]}" = "$_bootstrap_pid" ]; then
            REWRITTEN_ARGS[$((_i + 1))]="$_final_id"
            break
          fi
          _i=$((_i + 1))
        done
      fi
    fi

    if [ "$_provisioned" = "true" ]; then
      # Machine is running and reachable. Seed Claude config + git identity
      # so `claude -p` workers can authenticate and commit, then seed the
      # working tree (git clone + rsync uncommitted delta).  Then run the
      # orchestrator inside the machine and stream the completed run branch
      # back to the host for the host-side finalize (push + gh pr create).
      export USER_REPO
      _seed_ok=true
      if ! seed_auth; then
        echo "pila: error: seed_auth failed — aborting remote run" >&2
        container_rc=1
        _seed_ok=false
      elif [ "$_resumed" = "true" ]; then
        # Resume path: machine already has /work, just refresh the dirty
        # delta unless --no-re-seed was passed. (Phase 4 auto-re-seed.)
        if [ "$NO_RE_SEED" != "true" ]; then
          # shellcheck disable=SC1091
          . "$PILA_REPO/scripts/remote/re-seed.sh"
          [ "$RE_SEED_FORCE" = "true" ] && export PILA_RE_SEED_FORCE=1
          if ! re_seed; then
            echo "pila: error: re_seed failed — aborting remote run" >&2
            container_rc=1
            _seed_ok=false
          fi
        fi
      elif ! seed_repo; then
        echo "pila: error: repo seeding failed for machine $PILA_MACHINE_ID" >&2
        container_rc=1
        _seed_ok=false
      fi
      if [ "$_seed_ok" = "true" ]; then
        # Start the orchestrator detached on the Fly Machine. setsid makes
        # it a session leader so SIGHUP from the exec channel closing does
        # not reach it; nohup is belt-and-braces. stdout/stderr go to a log
        # file the machine owns; stdin is /dev/null. The launcher generated
        # the bootstrap run-id host-side and passed it via --run-id in
        # REWRITTEN_ARGS, so the path is known before the orchestrator
        # produces any output. DESIGN §6 *Detached orchestrator (remote
        # mode)*.
        echo "[pila] remote: machine $PILA_MACHINE_ID seeded — starting orchestrator (detached)" >&2

        # Detached-launch wrapper. Uses a python3 heredoc instead of
        # `sh -c "...setsid nohup..."` for three reasons:
        #   (a) argv goes via sys.argv — no shell quoting needed for the
        #       run-id or REWRITTEN_ARGS, so chars like ' or $ or \n
        #       cannot break the wrapper or alter the orchestrator argv.
        #   (b) start_new_session=True is equivalent to setsid and works
        #       on every Python ≥ 3.2 — no dependency on the remote
        #       shell understanding `setsid` (busybox sh does not).
        #   (c) Launcher errors from python (not from sh quoting) surface
        #       on stderr without the outer 2>&1 redirect, so a failed
        #       launch is diagnosable.
        if ! flyctl machine exec "$PILA_MACHINE_ID" \
               --app "$FLY_APP" \
               -- python3 - "$PILA_RUN_ID" "${REWRITTEN_ARGS[@]}" <<'PY'
import os, subprocess, sys

run_id = sys.argv[1]
orch_args = sys.argv[2:]

run_dir = f"/work/.pila/runs/{run_id}"
os.makedirs(run_dir, exist_ok=True)

log_path = f"{run_dir}/orchestrator.log"
pid_path = f"{run_dir}/orchestrator.pid"

with open(log_path, "ab") as log_f:
    p = subprocess.Popen(
        [
            "python3",
            "/work/.pila-image/orchestrator/pila.py",
            "--no-push",
            *orch_args,
        ],
        stdin=subprocess.DEVNULL,
        stdout=log_f,
        stderr=log_f,
        start_new_session=True,
    )

with open(pid_path, "w") as pid_f:
    pid_f.write(f"{p.pid}\n")
PY
        then
          echo "pila: error: failed to start detached orchestrator on machine $PILA_MACHINE_ID" >&2
          container_rc=1
        else
          # Phase 3: promote the PID-keyed attach pointer to a run-keyed
          # one immediately — we already know the (bootstrap) run-id. The
          # orchestrator will rename the run dir at classify time; the
          # launcher's tail wrapper handles the rename via the handover
          # file the orchestrator writes (see DESIGN §6).
          _pid_record="$USER_REPO/.pila/remote/$$.json"
          mkdir -p "$USER_REPO/.pila/runs/$PILA_RUN_ID" 2>/dev/null || true
          _run_record="$USER_REPO/.pila/runs/$PILA_RUN_ID/fly-machine.json"
          if [ -f "$_pid_record" ]; then
            cp "$_pid_record" "$_run_record" 2>/dev/null || true
          fi

          # Tail the orchestrator log for the user's terminal. This is a
          # separate exec session; its death (Ctrl-C, broken pipe, laptop
          # closing) does NOT propagate to the orchestrator. After the
          # orchestrator's State.rename_to promotes the bootstrap dir, it
          # writes the final run-id to /work/.pila/launcher-<bootstrap>.runid;
          # the wrapper script reads that, re-tails the new path, and on
          # orchestrator-pid exit prints a finalize hint and ends.
          echo "[pila] remote: tailing orchestrator log (Ctrl-C to detach — orchestrator keeps running)" >&2

          # The remote tail wrapper is shared with `pila --attach --tail`
          # via render_tail_wrapper in scripts/remote/lib.sh (already
          # sourced above). It handles the `_bootstrap-<6hex>` →
          # final-id rename transparently and prints the finalize hint
          # when the orchestrator pid disappears.
          _tail_script="$(render_tail_wrapper)"

          # Prepend an env-var assignment to the wrapper script so the
          # run-id reaches the wrapper via $PILA_TAIL_RUN_ID even on
          # transports that drop positional args (e.g.
          # `flyctl ssh console --command` — see attach.sh --tail). The
          # `flyctl machine exec ... --` path also passes "$PILA_RUN_ID"
          # positionally; the wrapper's `${PILA_TAIL_RUN_ID:-$1}` lookup
          # prefers the env var when present.
          _tail_invocation="PILA_TAIL_RUN_ID='$PILA_RUN_ID'; export PILA_TAIL_RUN_ID
$_tail_script"
          orch_rc=0
          flyctl machine exec "$PILA_MACHINE_ID" \
            --app "$FLY_APP" \
            -- sh -c "$_tail_invocation" -- "$PILA_RUN_ID" \
            || orch_rc=$?

          # On a clean tail exit (the orchestrator's pid disappeared), we
          # cannot read the orchestrator's true exit code — it ran detached.
          # The decide_teardown trap classifies based on PILA_REMOTE_EXIT_RC
          # which here reflects the TAIL's exit, not the orchestrator's.
          # Per the reclassified table (DESIGN §6), tail-exit cleanly
          # (rc=0 from the wrapper) is treated as "user can finalize"; the
          # launcher does NOT call fetch_branch from here — `pila --finalize`
          # does that. See *Detached run finalization* in IMPLEMENTATION.md.
          container_rc=$orch_rc
        fi
      fi
    else
      container_rc=1
    fi
    # The EXIT trap registered in provision.sh (decide_teardown) reads
    # PILA_REMOTE_EXIT_RC to classify the orchestrator's exit code.
    # Pause-worthy: any non-zero other than EXIT_NEEDS_ANSWERS=10,
    # EX_TEMPFAIL=75 (rate-limit), SIGINT=130, SIGTERM=143.
    # (DESIGN §6 Remote pause-on-failure.)
    export PILA_REMOTE_EXIT_RC="$container_rc"
  fi
else
  # --- local container execution path ----------------------------------
  # --rm: container is removed on exit. Worktrees + .pila/ state persist on
  #       the host filesystem via the /work bind mount, so --resume still works.
  # Mount-table rationale lives in docs/IMPLEMENTATION.md §0.5.
  #
  # TTY flags adapt to whether the launcher itself has a controlling terminal:
  #   Terminal mode (real pty on stdin) → -it. The container gets a
  #     controlling TTY; pila's log() lines stream live and the user can
  #     answer `--clarify` prompts interactively via input().
  #   Plugin mode (Claude Code's Bash tool: no TTY) → -i only.
  #     Inside the container, sys.stdin.isatty() returns False, so pila's
  #     gather_answers and mid-execution clarification paths trigger the
  #     existing EXIT_NEEDS_ANSWERS=10 flow: write .pila/pending-questions.json
  #     (visible on the host via the /work bind mount), exit 10. The plugin
  #     agent reads the file, asks the user in chat, writes .pila/answers.json,
  #     re-runs the container with --answers.
  # Ctrl-C (terminal) or harness cancellation (plugin) → SIGINT to container
  # PID 1 → orchestrator exits → kernel reaps the PID namespace (DESIGN §6
  # *Worker subtree termination*). The cleanup guarantee is identical in
  # both modes.
  # Require BOTH stdin and stdout to be TTYs before asking nerdctl for `-t`.
  # Stdin alone is not enough: piping pila's output (e.g. `pila ... | tee log`)
  # leaves stdin a TTY but redirects stdout through a pipe, and nerdctl rejects
  # `-t` against a non-console stdout with "provided file is not a console"
  # before the orchestrator gets a chance to run. Plugin mode (Bash tool: no
  # TTY on stdin) still collapses to `-i`, preserving the EXIT_NEEDS_ANSWERS=10
  # file-passing contract documented in commands/pila.md.
  TTY_FLAGS="-i"
  [ -t 0 ] && [ -t 1 ] && TTY_FLAGS="-it"

  # Use ${arr[@]+"${arr[@]}"} so empty arrays expand to nothing under
  # `set -u` (bash 3.2, the macOS system default, otherwise errors).
  #
  # Note: NOT `exec` — we need control to return to the launcher after the
  # container exits so the host-side finalize block (below) can run.
  # The --mount type=bind on /sys/fs/cgroup gives the orchestrator
  # cgroup v2 write access inside the container — required for the
  # per-worker memory.max / pids.max containment (DESIGN §6 "Worker
  # subtree termination — Memory containment"). cgroup v2 delegation
  # is file-permission based; no --privileged or --cap-add needed.
  # If the host doesn't have cgroup v2 (kernel <5.x or unified hier
  # disabled) the bind-mount no-ops cleanly and the orchestrator's
  # _cgroup_probe returns False, falling back to the pre-fix
  # uncapped behavior with one warn log line.
  nerdctl run \
    --rm $TTY_FLAGS \
    --name "pila-$(date +%s)-$$" \
    -e PILA_INSPECT_DIRS= \
    --mount type=bind,source=/sys/fs/cgroup,target=/sys/fs/cgroup,bind-propagation=rshared \
    -v "$USER_REPO:/work" \
    -v "$PILA_REPO:/work/.pila-image:ro" \
    ${AUTH_MOUNTS[@]+"${AUTH_MOUNTS[@]}"} \
    ${CACHE_MOUNTS[@]+"${CACHE_MOUNTS[@]}"} \
    ${INSPECT_MOUNTS[@]+"${INSPECT_MOUNTS[@]}"} \
    -w /work \
    "$IMAGE_TAG" ${REWRITTEN_ARGS[@]+"${REWRITTEN_ARGS[@]}"} || container_rc=$?
fi

# --- host-side finalize (push + PR) -------------------------------------
# DESIGN §6 *Finalization*: the container's phase_finalize writes
# `finished_at` to .pila/runs/<run-id>/run.json and exits 0. The
# launcher takes over from here, doing `git push` + `gh pr create` on
# the HOST so the host's working auth state (gh token, ssh-agent,
# Keychain) is what authenticates — no in-container forwarding required.
#
# Skip if:
#   - container exited non-zero (run failed; nothing to push)
#   - --no-push set (the user explicitly opted out)
#   - the structured-exit code (EXIT_NEEDS_ANSWERS=10) — the launcher's
#     plugin re-runs pila with --answers after the user responds.
if [ "$container_rc" -ne 0 ] || [ "$NO_PUSH" = "true" ]; then
  exit "$container_rc"
fi

# Locate the most-recent run dir under .pila/runs/ that has a run.json
# with finished_at set. The orchestrator writes run.json at finalize.
# `find` + sort isn't portable with -printf; iterate and pick newest.
LATEST_RUN_DIR=""
LATEST_RUN_MTIME=0
if [ -d "$USER_REPO/.pila/runs" ]; then
  for run_json in "$USER_REPO"/.pila/runs/*/run.json; do
    [ -f "$run_json" ] || continue
    # finished_at must be present and non-null.
    if [ "$(jq -r '.finished_at // ""' "$run_json")" = "" ]; then
      continue
    fi
    # pushed_at must be absent or null — otherwise this run was already
    # pushed (e.g. on a previous launcher invocation).
    if [ "$(jq -r '.pushed_at // ""' "$run_json")" != "" ]; then
      continue
    fi
    # Use mtime of run.json as the recency proxy.
    mtime="$(stat -f %m "$run_json" 2>/dev/null || stat -c %Y "$run_json" 2>/dev/null || echo 0)"
    if [ "$mtime" -gt "$LATEST_RUN_MTIME" ]; then
      LATEST_RUN_MTIME=$mtime
      LATEST_RUN_DIR="$(dirname "$run_json")"
    fi
  done
fi

if [ -z "$LATEST_RUN_DIR" ]; then
  # No run finished this invocation — nothing to push.
  exit 0
fi

# Detect --no-verify from $@ (CLI-only; not an env var).
NO_VERIFY_PUSH=false
for arg in "$@"; do
  if [ "$arg" = "--no-verify" ]; then
    NO_VERIFY_PUSH=true
  fi
done
export NO_VERIFY_PUSH

# Push + PR creation are shared with the `pila --finalize <run-id>`
# fast-path; both source scripts/host-finalize.sh and call host_finalize.
# shellcheck disable=SC1091
. "$PILA_REPO/scripts/host-finalize.sh"
host_finalize "$LATEST_RUN_DIR" || exit $?
