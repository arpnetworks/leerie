  # the canonical state-root markers — runs/ or worktrees/) from an
  # installer-dir mistake (.git/ or a leerie executable at top level
  # with no runs/). On the former, backfill .owner; on the latter, die.
  if [ -d "$dir/runs" ] || [ -d "$dir/worktrees" ]; then
    printf '%s\n' "$USER_REPO" > "$dir/.owner"
    return 0
  fi
  if [ -d "$dir/.git" ] || [ -x "$dir/leerie" ]; then
    echo "leerie: state-dir target $dir looks like the leerie install directory" >&2
    echo "  (contains .git/ or a leerie executable, and has no runs/ subdir)." >&2
    echo "refusing to write run state here. pick a different path with one of:" >&2
    echo "  --state-dir /some/path" >&2
    echo "  LEERIE_STATE_DIR=/some/path" >&2
    echo "  leerie.toml: state_dir = \"/some/path\"" >&2
    exit 1
  fi
