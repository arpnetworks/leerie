      --*) remote_log "--chain-kill: expected <chain-id>, got flag '$_ck_chain_id'"; exit 1 ;;
    esac
    _chain_url="${LEERIE_CHAIN_URL:-http://localhost:8080}"
    curl -fsSL -X DELETE "$_chain_url/chains/$_ck_chain_id"
    exit $?
    ;;
  --chain-attach)
    # Fast-path: stream logs for a chain from the leerie-chain HTTP API.
    # GET /chains/<chain-id>/log.
    shift
    _ca_chain_id="${1:-}"
    if [ -z "$_ca_chain_id" ]; then
      remote_log "--chain-attach: <chain-id> is required"
      echo "  Usage: leerie --chain-attach <chain-id>" >&2
      exit 1
    fi
    case "$_ca_chain_id" in
      --*) remote_log "--chain-attach: expected <chain-id>, got flag '$_ca_chain_id'"; exit 1 ;;
    esac
    _chain_url="${LEERIE_CHAIN_URL:-http://localhost:8080}"
    curl -fsSL "$_chain_url/chains/$_ca_chain_id/log"
    exit $?
    ;;
esac

# --- platform preflight --------------------------------------------------
OS="$(uname -s)"

print_install_hint() {
  case "$OS" in
    Darwin)
      if ! command -v brew >/dev/null 2>&1; then
        cat >&2 <<'EOF'

You need Homebrew first (leerie uses brew to install Colima):
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

Or see https://brew.sh/ for alternatives.

After installing Homebrew, re-run leerie — it will auto-install Colima.
EOF
      else
        cat >&2 <<'EOF'

Install on macOS:
  brew install colima
  colima start --runtime containerd --mount-type virtiofs
  # nerdctl shim is auto-installed by leerie on first run; or manually:
  #   colima nerdctl install

(brew install nerdctl does NOT work on macOS — the nerdctl binary requires
a Linux kernel. Colima ships nerdctl inside its VM and installs a host-side
shim that proxies to it.)

See docs/INSTALL.md for details.
EOF
      fi
      ;;
    Linux)
      cat >&2 <<'EOF'

Install on Linux:
  # Debian/Ubuntu:
  sudo apt-get install -y containerd
  # then install nerdctl from upstream:
  #   https://github.com/containerd/nerdctl/releases
  # Or distro packages where available (Arch: pacman -S nerdctl).
  sudo systemctl enable --now containerd

See docs/INSTALL.md for rootless mode and other distros.
EOF
      ;;
    *)
      remote_log "unsupported OS: $OS (need macOS or Linux)"
      ;;
  esac
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    remote_log "missing required command: $1"
    print_install_hint
    exit 1
  }
}

# --- runtime auto-install opt-out --------------------------------------
# Same flag/env shape as scripts/install.sh: --no-runtime-install on the
# CLI or LEERIE_NO_RUNTIME_INSTALL=1 in the env disables auto-install. We
# don't shift the flag off $@ — the orchestrator's argparse rejects
# unknown flags, so we just consume it before the orchestrator sees it
# (in the REWRITTEN_ARGS pass-through below).
case "${LEERIE_NO_RUNTIME_INSTALL:-}" in
  1|true|TRUE|yes|YES) NO_RUNTIME_INSTALL=true ;;
  *)                   NO_RUNTIME_INSTALL=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--no-runtime-install" ]; then
    NO_RUNTIME_INSTALL=true
  fi
done

# --- remote image auto-publish opt-out ---------------------------------
# Same shape: --no-auto-publish on the CLI or LEERIE_NO_AUTO_PUBLISH=1 in the
# env disables ensure_image() for the remote (Fly) path. The orchestrator
# never sees this flag — it's consumed in REWRITTEN_ARGS below.
case "${LEERIE_NO_AUTO_PUBLISH:-}" in
  1|true|TRUE|yes|YES) NO_AUTO_PUBLISH=true ;;
  *)                   NO_AUTO_PUBLISH=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--no-auto-publish" ]; then
    NO_AUTO_PUBLISH=true
  fi
done

# --- local-build opt-in (most users should leave this off) ---------------
# Default: ensure_image() invokes build-push.sh in its remote-builder mode
# (Fly's infra builds + pushes; no host Docker daemon required).
# --local-build on the CLI or LEERIE_LOCAL_BUILD=1 in the env forces the
# legacy local-build path (nerdctl/docker build + push). The local path
# only works on hosts with a working Docker daemon authenticated to
# registry.fly.io (Docker Desktop + `flyctl auth docker`, OR Linux with
# apt-installed Docker). It does NOT work with nerdctl-in-Colima on macOS
# because nerdctl cannot reach macOS Keychain (where Docker Desktop's
# `credsStore: desktop` helper stores the registry credential).
# The orchestrator never sees this flag — consumed by REWRITTEN_ARGS below.
case "${LEERIE_LOCAL_BUILD:-}" in
  1|true|TRUE|yes|YES) LOCAL_BUILD=true ;;
  *)                   LOCAL_BUILD=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--local-build" ]; then
    LOCAL_BUILD=true
  fi
done

# --- auto re-seed on --resume (Phase 4) --------------------------------
# Default behaviour: when resuming a paused remote run, automatically
# re-rsync the host's dirty set before re-exec'ing the orchestrator.
# --no-re-seed opts out (rate-limit auto-resume case where nothing changed).
# --force bypasses the safety check that refuses to clobber machine-side
# uncommitted edits.
NO_RE_SEED=false
RE_SEED_FORCE=false
for arg in "$@"; do
  case "$arg" in
    --no-re-seed) NO_RE_SEED=true ;;
    --force)      RE_SEED_FORCE=true ;;
  esac
done

# --- extract --run-id (passed through to orchestrator) -----------------
# The launcher needs the run-id early in the RUNTIME=fly branch so the
# remote provision step can write fly_machine_id to the sidecar
# (DESIGN §6 Remote pause-on-failure). We don't shift the arg off $@ —
# it's still forwarded via REWRITTEN_ARGS to the orchestrator's argparse.
LEERIE_RUN_ID=""
IS_RESUME=false
_prev=""
for arg in "$@"; do
  if [ "$_prev" = "--run-id" ]; then
    LEERIE_RUN_ID="$arg"
  fi
  case "$arg" in
    --run-id=*) LEERIE_RUN_ID="${arg#--run-id=}" ;;
    --resume)   IS_RESUME=true ;;
  esac
  _prev="$arg"
done
export LEERIE_RUN_ID
export IS_RESUME

# --- extract the task positional (for bootstrap-stage resume) -----------
# The orchestrator's argparse takes a single optional positional `task`.
# On a remote-mode bootstrap-stage resume, the in-machine orchestrator
# has no state.json (classify never ran), and the launcher strips
# --resume so the orchestrator routes to the fresh-launch branch. That
# branch requires a task. The user's original `leerie "<task>"` is gone
# from the resume invocation's argv, so we persist it at first-launch
# (a few sections down) and read it back here on subsequent bootstrap
# resumes. This block only extracts what the user typed THIS time.
#
# Walk $@ skipping flag values for any --flag that takes one. The
# orchestrator's --model-<W> and --effort-<W> per-worker overrides
# also take values; cover them with a prefix match.
LEERIE_TASK_ARG=""
_prev=""
_value_flags=" --run-id --answers --pr-template --max-workers \
--max-parallel --confidence-rounds --worker-memory-max \
--source-of-truth --runtime --inspect-dir --model --effort \
--judge-model --heal-model --pr-writer-model --heal-max-rounds \
--heal-success-threshold --verbosity --telemetry-dir --judge-dir \
--heal-dir --phase --host-no-push --status "
for arg in "$@"; do
  # Skip if this arg is the value of a previous value-taking flag.
  if [ -n "$_prev" ]; then
    case "$_value_flags" in
      *" $_prev "*) _prev=""; continue ;;
    esac
    case "$_prev" in
      --model-*|--effort-*) _prev=""; continue ;;
    esac
  fi
  # Skip any --flag (with or without =value).
  case "$arg" in
    --*) _prev="$arg"; continue ;;
  esac
  # First non-flag, non-value positional is the task.
  if [ -z "$LEERIE_TASK_ARG" ]; then
    LEERIE_TASK_ARG="$arg"
  fi
  _prev=""
done
export LEERIE_TASK_ARG

# --- runtime-mode knob ---------------------------------------------------
# Resolves RUNTIME=local|fly. Precedence: CLI --runtime > LEERIE_RUNTIME env
# > leerie.toml `runtime` key > default `local`. Mirrors the orchestrator's
# resolve_runtime() (leerie.py) so the launcher routes correctly before the
# container starts.
#
# Backward-compat aliases: --remote / LEERIE_REMOTE / leerie.toml `remote=true`
# map to RUNTIME=fly. The --remote flag is consumed here and not forwarded;
# --runtime is NOT consumed — it flows through REWRITTEN_ARGS to the
# orchestrator's own argparse.
RUNTIME=local
# Precedence (lowest → highest): default → legacy-toml → canonical-toml →
# legacy-env → canonical-env → CLI.  TOML is resolved first so env overrides it.
if [ -f "$USER_REPO/leerie.toml" ]; then
  # legacy: remote = true
  toml_remote="$(awk '/^[[:space:]]*remote[[:space:]]*=/ {
                        gsub(/^[[:space:]]*remote[[:space:]]*=[[:space:]]*/, "", $0);
                        gsub(/^"|"$/, "", $0);
                        print; exit
                      }' "$USER_REPO/leerie.toml" 2>/dev/null || true)"
  case "${toml_remote:-}" in
    1|true|TRUE|yes|YES) RUNTIME=fly ;;
  esac
  # canonical: runtime = local|fly
  toml_runtime="$(awk '/^[[:space:]]*runtime[[:space:]]*=/ {
                         gsub(/^[[:space:]]*runtime[[:space:]]*=[[:space:]]*/, "", $0);
                         gsub(/^"|"$/, "", $0);
                         print; exit
                       }' "$USER_REPO/leerie.toml" 2>/dev/null || true)"
  case "${toml_runtime:-}" in
    local|fly) RUNTIME="${toml_runtime}" ;;
    "")        : ;;
    *)
      remote_log "leerie.toml: runtime=${toml_runtime} is not one of local|fly"
      exit 1
      ;;
  esac
fi
# env alias (legacy) — overrides TOML
case "${LEERIE_REMOTE:-}" in
  1|true|TRUE|yes|YES) RUNTIME=fly ;;
esac
# env (canonical) — overrides TOML and legacy env alias
case "${LEERIE_RUNTIME:-}" in
  local|fly) RUNTIME="${LEERIE_RUNTIME}" ;;
  "")        : ;;
  *)
    remote_log "LEERIE_RUNTIME=${LEERIE_RUNTIME} is not one of local|fly"
    exit 1
    ;;
esac
# CLI (highest priority) — scanned before REWRITTEN_ARGS loop below.
# --remote sets RUNTIME=fly (legacy). --runtime=VALUE / --runtime VALUE set
# RUNTIME directly and also flow through to the orchestrator.
for arg in "$@"; do
  case "$arg" in
    --remote)           RUNTIME=fly ;;
    --runtime=local)    RUNTIME=local ;;
    --runtime=fly)      RUNTIME=fly ;;
    --runtime=*)
      remote_log "--runtime=${arg#--runtime=} is not one of local|fly"
      exit 1
      ;;
  esac
done
# Handle the two-argument form --runtime VALUE.
prev_was_runtime=false
for arg in "$@"; do
  if $prev_was_runtime; then
    case "$arg" in
      local|fly) RUNTIME="$arg" ;;
      *)
        remote_log "--runtime $arg is not one of local|fly"
        exit 1
        ;;
    esac
    prev_was_runtime=false
    continue
  fi
  if [ "$arg" = "--runtime" ]; then
    prev_was_runtime=true
  fi
done
# Maintain backward-compat REMOTE alias consumed downstream.
REMOTE=false
[ "$RUNTIME" = "fly" ] && REMOTE=true

# --- FLY_VM_DISK_GB (opt-in per-machine Fly volume size in GB) ------------
# Resolution ladder (highest → lowest):
#   1. --fly-disk-gb N / --fly-disk-gb=N on the CLI
#   2. $FLY_VM_DISK_GB already set in the env
#   3. fly_disk_gb = N in leerie.toml
#   4. unset (provision.sh skips the volume; machine uses Fly default disk)
#
# When set, provision.sh creates a per-machine Fly volume sized at N GB,
# mounts it at /home/leerie, persists the volume_id into run.json, and
# destroys the volume when the machine is destroyed.
# (DESIGN §6 *Remote disk policy*; IMPLEMENTATION §2.)
_cli_fly_disk_gb=""
_prev_was_fly_disk=false
for arg in "$@"; do
  if $_prev_was_fly_disk; then
    _cli_fly_disk_gb="$arg"
    _prev_was_fly_disk=false
    continue
  fi
  case "$arg" in
    --fly-disk-gb=*) _cli_fly_disk_gb="${arg#--fly-disk-gb=}" ;;
    --fly-disk-gb)   _prev_was_fly_disk=true ;;
  esac
done
if [ -n "$_cli_fly_disk_gb" ]; then
  FLY_VM_DISK_GB="$_cli_fly_disk_gb"
elif [ -z "${FLY_VM_DISK_GB:-}" ] && [ -f "$USER_REPO/leerie.toml" ]; then
  # Same flat-key grep pattern as the no_push read below (line ~1002),
  # mirroring orchestrator/leerie.py:_read_toml_key.
  _toml_fly_disk_gb="$( { grep -E '^[[:space:]]*fly_disk_gb[[:space:]]*=' \
                              "$USER_REPO/leerie.toml" 2>/dev/null \
                            | head -1 \
                            | sed -E 's/^[[:space:]]*fly_disk_gb[[:space:]]*=[[:space:]]*//; s/[[:space:]]*$//; s/^"//; s/"$//' ; } || true)"
  if [ -n "$_toml_fly_disk_gb" ]; then
    FLY_VM_DISK_GB="$_toml_fly_disk_gb"
  fi
  unset _toml_fly_disk_gb
fi
unset _cli_fly_disk_gb _prev_was_fly_disk
# Validate: must be a positive integer when set. provision.sh would otherwise
# pass garbage to `flyctl volumes create --size` and the failure mode would
# be a confusing flyctl error.
if [ -n "${FLY_VM_DISK_GB:-}" ]; then
  case "$FLY_VM_DISK_GB" in
    ''|*[!0-9]*)
      remote_log "FLY_VM_DISK_GB='$FLY_VM_DISK_GB' is not a positive integer (GB)"
      exit 1
      ;;
    0)
      remote_log "FLY_VM_DISK_GB=0 is invalid; unset the var to use Fly's default disk"
      exit 1
      ;;
  esac
  export FLY_VM_DISK_GB
fi

# DRY_RUN is referenced by scripts/runtime-install.sh; default to false
# in the launcher (the launcher has no --dry-run flag — that's install.sh).
DRY_RUN=false

# Source the shared runtime-install helpers. LEERIE_REPO points at the
# leerie install directory (where scripts/ lives) — already resolved at
# the top of this script via the symlink walk.
if [ -f "$LEERIE_REPO/scripts/runtime-install.sh" ]; then
  # shellcheck disable=SC1091
  . "$LEERIE_REPO/scripts/runtime-install.sh"
fi

# Colima/containerd preflight is only needed for local nerdctl invocations.
# Skip entirely when RUNTIME=fly (or any future non-local runtime).
if [ "$RUNTIME" = "local" ]; then
case "$OS" in
  Darwin)
    # Auto-install Colima if missing, with a TTY guard. The brew install
    # step may prompt for sudo; in plugin mode (no TTY) the prompt would
    # hang. Mirror the pattern at line ~135 (nerdctl-shim install).
    if ! command -v colima >/dev/null 2>&1; then
      if [ "$NO_RUNTIME_INSTALL" = "true" ]; then
        remote_log "Colima is missing (auto-install skipped via --no-runtime-install)."
        print_install_hint
        exit 1
      fi
      if [ -t 0 ]; then
        remote_log "Colima is missing — installing now (one-time; may prompt for sudo)..."
        if ! runtime_install_macos; then
          print_install_hint
          exit 1
        fi
      else
        remote_log "Colima is not installed and we have no terminal to"
        echo "  prompt for sudo / brew install. Run leerie once from a" >&2
        echo "  terminal so the one-time install can complete:" >&2
        echo "    leerie --version" >&2
        echo "  Or install Colima manually:" >&2
        echo "    brew install colima" >&2
        exit 1
      fi
    fi
    # Don't auto-start Colima — if the user has an existing setup with
    # dockerd we'd clobber their preference. Give a clear hint instead.
    if ! colima status >/dev/null 2>&1; then
      remote_log "Colima VM is not running."
      echo "  Start it with:  colima start --runtime containerd --mount-type virtiofs" >&2
      exit 1
    fi
    # nerdctl reaches containerd via Colima's host-side shim
    # (`colima nerdctl install`). The install writes to /usr/local/bin
    # (root-owned on macOS) via `sudo`, which prompts interactively. In
    # plugin mode (no TTY) the sudo prompt blocks forever; detect and bail
    # with a clear hint instead of hanging.
    if ! command -v nerdctl >/dev/null 2>&1; then
      if [ -t 0 ]; then
        remote_log "installing host-side nerdctl shim (one-time; may prompt for sudo)..."
        if ! colima nerdctl install >&2; then
          remote_log "failed to install nerdctl shim — run 'colima nerdctl install' manually"
          exit 1
        fi
      else
        remote_log "nerdctl shim is not installed and we have no terminal to run sudo."
        echo "  Run this once from a terminal, then re-invoke /leerie:" >&2
        echo "    colima nerdctl install" >&2
        exit 1
      fi
    fi
    if ! nerdctl info >/dev/null 2>&1; then
      remote_log "nerdctl cannot reach the container runtime."
      echo "  Ensure Colima was started with --runtime containerd:" >&2
      echo "    colima stop && colima start --runtime containerd --mount-type virtiofs" >&2
      exit 1
    fi
    # Colima auto-shares only paths under /Users/$USER by default. If any
    # bind mount we're about to make falls outside, the mount silently
    # appears empty inside the container. Warn early.
    USER_HOME_PREFIX="/Users/$(id -un)"
    check_under_home() {
      case "$1" in
        "$USER_HOME_PREFIX"|"$USER_HOME_PREFIX"/*) return 0 ;;
        *)
          remote_log "warning — '$1' is outside $USER_HOME_PREFIX"
          echo "  and may appear empty in the container. Add it to Colima's" >&2
          echo "  mount list: edit ~/.colima/default/colima.yaml's 'mounts:'" >&2
          echo "  section, then 'colima restart'." >&2
          return 1
          ;;
      esac
    }
    check_under_home "$USER_REPO" || true
    check_under_home "$LEERIE_REPO" || true
    ;;
  Linux)
    # Auto-install nerdctl + containerd if missing, with a TTY guard.
    # `sudo apt-get install` etc. would hang in plugin mode without TTY.
    if ! command -v nerdctl >/dev/null 2>&1; then
      if [ "$NO_RUNTIME_INSTALL" = "true" ]; then
        remote_log "nerdctl is missing (auto-install skipped via --no-runtime-install)."
        print_install_hint
        exit 1
      fi
      if [ -t 0 ]; then
        remote_log "nerdctl is missing — installing containerd + nerdctl (one-time; may prompt for sudo)..."
        if ! runtime_install_linux; then
          print_install_hint
          exit 1
        fi
      else
        remote_log "nerdctl is not installed and we have no terminal to"
        echo "  prompt for sudo. Run leerie once from a terminal so the" >&2
        echo "  one-time install can complete:" >&2
        echo "    leerie --version" >&2
        exit 1
      fi
    fi
    if ! nerdctl info >/dev/null 2>&1; then
      remote_log "nerdctl cannot reach containerd."
      echo "  Ensure containerd is running:  systemctl status containerd" >&2
      echo "  For rootless mode see docs/INSTALL.md." >&2
      exit 1
    fi
    ;;
  *)
    remote_log "unsupported OS: $OS"
    print_install_hint
    exit 1
    ;;
esac
fi  # end RUNTIME=local preflight

# --- host preflight: git repo + gh + jq ---------------------------------
# These checks moved out of the orchestrator (DESIGN §6 *Finalization*).
# The launcher does the host-side push + PR after the container exits,
# so the auth state needs to be valid on the host BEFORE we spin up the
# container. Fast-fail with actionable messages.
#
# `--no-push` shortcuts the gh + origin checks (the launcher will skip
# the host-side finalize entirely). The flag is also passed through to
# the orchestrator so phase_finalize knows not to do its own bookkeeping.
NO_PUSH=false
for arg in "$@"; do
  case "$arg" in
    --no-push) NO_PUSH=true ;;
  esac
done
case "${LEERIE_NO_PUSH:-}" in
  1|true|TRUE|yes|YES) NO_PUSH=true ;;
esac
# Match the orchestrator's resolve_no_push order: CLI → env → leerie.toml.
# The launcher and the in-Fly orchestrator are now both authoritative
# consumers of this intent — the launcher seeds fly-machine.json.
# host_no_push and the --host-no-push argv flag, the orchestrator gates
# pr_writer and writes run.json.no_push. Disagreement on a TOML-only
# opt-out would make the Fly auto-finalize path push against user
# intent. Pattern mirrors orchestrator/leerie.py:2279 `_read_toml_key`
# (flat `key = value` grep) — keeps the launcher free of a tomllib
# dependency that would force a host-side Python 3.11+ bump.
if [ "$NO_PUSH" = "false" ] && [ -f "$USER_REPO/leerie.toml" ]; then
  # `|| true` swallows grep's exit 1 when the key is absent (set -e
  # would otherwise abort the whole launcher). Sed normalizes the
  # value: strip surrounding whitespace and matched double or single
  # quotes, mirroring orchestrator/leerie.py:_read_toml_key.
  _toml_no_push="$( { grep -E '^[[:space:]]*no_push[[:space:]]*=' \
                          "$USER_REPO/leerie.toml" 2>/dev/null \
                      || true; } \
                    | head -1 \
                    | sed -E 's/^[[:space:]]*no_push[[:space:]]*=[[:space:]]*//;
                              s/[[:space:]]*$//;
                              s/^"(.*)"$/\1/;
                              s/^'"'"'(.*)'"'"'$/\1/')"
  # Case-fold for matching so the launcher's truthy/falsy vocabulary
  # is exactly the orchestrator's `_parse_bool_envtoml` (which uses
  # `.lower()` then matches `1|true|yes|on` / `0|false|no|off`). The
  # original value is kept for the error message so the user sees the
  # exact spelling they wrote.
  _toml_no_push_lc="$(printf '%s' "$_toml_no_push" \
                      | tr '[:upper:]' '[:lower:]')"
  case "$_toml_no_push_lc" in
    1|true|yes|on)
      NO_PUSH=true ;;
    0|false|no|off|"")
      : ;;  # explicit falsy / absent → leave NO_PUSH=false
    *)
      # Unrecognized value — die with the same error shape the
      # orchestrator surfaces from _resolve_bool_pref. Silent fall-
      # through would be the worse failure mode (a typo'd opt-out
      # silently becomes "push", which surprises the user). Both
      # layers should agree on what's a valid boolean.
      echo "leerie: error: $USER_REPO/leerie.toml: no_push='$_toml_no_push' is not a boolean" >&2
      echo "  (expected one of: 1, 0, true, false, yes, no, on, off — case-insensitive)" >&2
      exit 1 ;;
  esac
  unset _toml_no_push _toml_no_push_lc
fi

# Parse --no-verify and export NO_VERIFY_PUSH here, BEFORE
# provision_machine registers the EXIT trap. The trap's clean-exit
# branch calls host_finalize, which reads NO_VERIFY_PUSH; exporting it
# late (after the trap fires) would make `--no-verify` silently
# inoperative on the Fly path. CLI-only (no env/TOML mirror — matches
# CLAUDE.md's explicit-user-request principle for hook-skipping).
NO_VERIFY_PUSH=false
for arg in "$@"; do
  if [ "$arg" = "--no-verify" ]; then
    NO_VERIFY_PUSH=true
  fi
done
export NO_VERIFY_PUSH

# 1. cwd is a git repo (orchestrator's old check at leerie.py:7652).
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  remote_log "error: not inside a git repository"
  exit 1
fi

# 2. origin remote present (required for `git push`). Skipped under
#    --no-push. We do NOT preflight `gh auth status` or even check `gh`
#    presence here — both are needed only at PR-creation time, and
#    `gh pr create` failure is non-fatal (the run branch is already
#    pushed; the user can open the PR manually with the printed retry
#    command). Preflighting gh auth surfaced false-positives without
#    catching anything the post-push failure path doesn't handle.
if [ "$NO_PUSH" = "false" ]; then
  if ! git remote get-url origin >/dev/null 2>&1; then
    remote_log "error: this repository has no \`origin\` remote — finalize cannot"
    echo "  push without one. Add one with \`git remote add origin <url>\` or pass" >&2
    echo "  \`--no-push\`." >&2
    exit 1
  fi
fi

# 3. jq is needed for the host-side finalize to read run.json /
#    state.json. Hard-fail on macOS (brew install jq) and Linux (distro
#    package manager); we use jq for the body composition + state writes.
if [ "$NO_PUSH" = "false" ] && ! command -v jq >/dev/null 2>&1; then
  remote_log "error: \`jq\` not found on PATH."
  case "$OS" in
    Darwin) echo "  Install with: brew install jq" >&2 ;;
    Linux)  echo "  Install with your distro package manager (apt install jq / dnf install jq / pacman -S jq)." >&2 ;;
  esac
  echo "  Or pass --no-push to skip the host-side finalize." >&2
  exit 1
fi

# --- build image if not present (one-time, ~60-120s) --------------------
if ! nerdctl image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  remote_log "building container image (one-time; ~60-120s)..."
  nerdctl build \
    --build-arg HOST_UID="$(id -u)" \
    --build-arg HOST_GID="$(id -g)" \
    -t "$IMAGE_TAG" \
    "$LEERIE_REPO"
fi

# --- translate --inspect-dir paths into bind-mounts ---------------------
# Each --inspect-dir path points at a host-absolute directory the
# inspect-bucket workers need read access to (--add-dir under the hood).
# Bind-mount each one read-only at /inspect/<basename> and rewrite the arg
# so the in-container view matches. Paths from LEERIE_INSPECT_DIRS (colon-sep)
# and leerie.toml's inspect_dirs (comma-sep) need the same treatment — we
# resolve them on the host and emit --inspect-dir CLI flags. LEERIE_INSPECT_DIRS
# is cleared inside the container so resolve_inspect_dirs() picks up only
# our rewritten CLI flags.
INSPECT_MOUNTS=()
REWRITTEN_ARGS=()
INSPECT_NAMES=()
# Parallel to INSPECT_MOUNTS: pairs of "<host-path>\t<remote-target>" used by
# the remote (Fly) runtime to rsync each inspect dir to /inspect/<basename>
# on the machine. The local runtime ignores this — it uses INSPECT_MOUNTS
# directly. Populated only for inspect dirs OUTSIDE $USER_REPO; in-repo
# inspect dirs (the skip-redundant-mount branch in collect_inspect_path)
# arrive on the machine via seed_repo at /work/<subpath> and need no
# separate transport. See docs/IMPLEMENTATION.md §0.5 "Remote runtime
# (Fly.io) transport".
INSPECT_HOST_TARGETS=()

collect_inspect_path() {
  local host_path expanded resolved base mount_target user_repo_resolved
  host_path="$1"
  # Expand leading ~ — `cd` won't on its own.
  case "$host_path" in
    "~")   expanded="$HOME" ;;
    "~/"*) expanded="$HOME/${host_path#~/}" ;;
    *)     expanded="$host_path" ;;
  esac
  resolved="$(cd -P "$expanded" 2>/dev/null && pwd)" || {
    remote_log "--inspect-dir path not found: $host_path"
    exit 1
  }
  # If the path is inside $USER_REPO it's already visible at /work/<sub>,
  # so a second mount under /inspect/ would be redundant. Warn and skip.
  user_repo_resolved="$(cd -P "$USER_REPO" && pwd)"
  case "$resolved" in
    "$user_repo_resolved"|"$user_repo_resolved"/*)
      # Quote $user_repo_resolved inside ${...#...} so bash strips a literal
      # prefix instead of treating the value as a glob pattern (shellcheck
      # SC2295). Paths typically lack glob metachars, but the cost of
      # defensiveness is one quote-pair.
      local rel="${resolved#"$user_repo_resolved"}"
      remote_log "--inspect-dir '$host_path' is inside the repo; skipping redundant mount"
      REWRITTEN_ARGS+=(--inspect-dir "/work${rel}")
      return 0
      ;;
  esac
  base="$(basename "$resolved")"
  # Disambiguate basename collisions (e.g. two paths both named "src") by
  # appending a numeric suffix. Use [[ ]] for glob-style membership test;
  # surround with spaces so adjacent words don't match a substring.
  local existing=" ${INSPECT_NAMES[*]:-} "
  local candidate="$base"
  local i=2
  while [[ "$existing" == *" $candidate "* ]]; do
    candidate="$base-$i"
    i=$((i + 1))
  done
  base="$candidate"
  mount_target="/inspect/$base"
  INSPECT_NAMES+=("$base")
  INSPECT_MOUNTS+=(-v "$resolved:$mount_target:ro")
  REWRITTEN_ARGS+=(--inspect-dir "$mount_target")
  # Remote (Fly) runtime needs the host-path → /inspect/<basename> mapping to
  # rsync each dir onto the machine. Tab separator is safe: POSIX paths
  # cannot contain \t (they can contain `:` and ` `).
  INSPECT_HOST_TARGETS+=("$resolved"$'\t'"$mount_target")
}

# Serialize INSPECT_HOST_TARGETS for the remote-runtime helper. Empty array
# → empty env var → seed_inspect_dirs short-circuits. Newline-separated
# records, each "<host>\t<remote>", matching the format seed_inspect_dirs
# parses with `read -r`. See docs/IMPLEMENTATION.md §0.5 "Remote runtime
# (Fly.io) transport".
_serialize_inspect_host_targets() {
  if [ "${#INSPECT_HOST_TARGETS[@]}" -eq 0 ]; then
    LEERIE_INSPECT_HOST_TARGETS=""
  else
    LEERIE_INSPECT_HOST_TARGETS="$(printf '%s\n' "${INSPECT_HOST_TARGETS[@]}")"
  fi
  export LEERIE_INSPECT_HOST_TARGETS
}

# Pre-pass: LEERIE_INSPECT_DIRS env (colon-separated).
if [ -n "${LEERIE_INSPECT_DIRS:-}" ]; then
  OIFS="$IFS"; IFS=":"
  for p in $LEERIE_INSPECT_DIRS; do
    [ -z "$p" ] || collect_inspect_path "$p"
  done
  IFS="$OIFS"
fi
# Pre-pass: leerie.toml inspect_dirs key (comma-separated).
# The orchestrator's resolve_inspect_dirs() precedence is CLI > env > TOML,
# so once we emit --inspect-dir CLI flags here, the in-container TOML pass
# is bypassed. Best-effort parse: awk-grep the simple key=value form.
if [ -f "$USER_REPO/leerie.toml" ]; then
  toml_dirs="$(awk -F= '/^[[:space:]]*inspect_dirs[[:space:]]*=/ {
                          gsub(/^[[:space:]]*inspect_dirs[[:space:]]*=[[:space:]]*/, "", $0);
                          gsub(/^"|"$/, "", $0);
                          print; exit
                        }' "$USER_REPO/leerie.toml" 2>/dev/null || true)"
  if [ -n "$toml_dirs" ]; then
    OIFS="$IFS"; IFS=","
    for p in $toml_dirs; do
      # Trim whitespace.
      p="$(printf '%s' "$p" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      [ -z "$p" ] || collect_inspect_path "$p"
    done
    IFS="$OIFS"
  fi
fi
# Main pass: rewrite --inspect-dir in $@. The orchestrator's argparse
# declares only --inspect-dir (no -i alias — see leerie.py:6079), so we
# intercept exactly that one form and let everything else flow through.
prev_was_inspect=false
for arg in "$@"; do
  if $prev_was_inspect; then
    collect_inspect_path "$arg"
    prev_was_inspect=false
    continue
  fi
  case "$arg" in
    --inspect-dir)
      prev_was_inspect=true
      ;;
    --inspect-dir=*)
      collect_inspect_path "${arg#--inspect-dir=}"
      ;;
    --no-runtime-install)
      # Launcher-only flag; consumed by the runtime preflight above.
      # The orchestrator's argparse doesn't know it.
      ;;
    --no-auto-publish)
      # Launcher-only flag; consumed by ensure_image() in the remote path.
      ;;
    --local-build)
      # Launcher-only flag; consumed by ensure_image() to forward
      # --local-build to build-push.sh (legacy local nerdctl/docker
      # build instead of the default Fly remote builder).
      ;;
    --no-re-seed)
      # Launcher-only flag (Phase 4); consumed by the auto-re-seed-on-resume
      # block. The orchestrator's argparse doesn't know it.
      ;;
    --force)
      # Launcher-only flag (Phase 4); bypasses re_seed's safety check.
      ;;
    --remote)
      # Launcher-only flag (legacy alias for --runtime fly); consumed by
      # the runtime-mode knob above. The orchestrator's argparse doesn't know it.
      ;;
    *)
      REWRITTEN_ARGS+=("$arg")
      ;;
  esac
done

# --- assemble auth/config mounts ----------------------------------------
# Per-container config isolation. The shared host ~/.claude.json is a
# documented corruption race (anthropics/claude-code issues #28847,
# #29217, #29395, #40226 — all open). Each container gets its own copy
# of every claude/git/ssh/gpg config file it needs, staged on the host
# in a per-run scratch dir and mounted at the default in-container
# paths. Container sees normal locations; no shared host state to race.
AUTH_MOUNTS=()

if [ ! -d "$HOME/.claude" ]; then
  remote_log "$HOME/.claude not found — run \`claude\` at least once first"
  exit 1
fi
if [ ! -f "$HOME/.claude.json" ]; then
  remote_log "$HOME/.claude.json not found — run \`claude\` at least once first"
  exit 1
fi

# Scratch dir lives under ~/.cache/leerie/ (not $TMPDIR) so Colima's
# default mount config auto-shares it on macOS — $TMPDIR resolves to
# /var/folders/... on Darwin, which is outside the /Users/$USER share
# Colima exposes by default, and the bind mount would silently appear
# empty inside the container. Linux is unaffected (any host path is
# nerdctl-mountable) but the ~/.cache/leerie/ home keeps the launcher
# uniform across platforms and matches the existing cache-dir
# convention used for mise / pnpm / pip / go / cargo (see below).
mkdir -p "$HOME/.cache/leerie"
STAGE="$(mktemp -d "$HOME/.cache/leerie/cfg-XXXXXX")"

# -- .claude.json: copy with projects[] stripped. --
# The projects[] block stores prior-session per-project state
# (lastSessionId, lastCost, MCP allowlists). Stripping it gives the
# worker a clean slate on /work as a brand-new project.
python3 - "$HOME/.claude.json" "$STAGE/.claude.json" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
d.pop("projects", None)
json.dump(d, open(sys.argv[2], "w"))
PY

# -- .claude/: copy with prior-session / history / bulk dirs skipped. --
# Blacklist (not whitelist) so a newly-added capability dir Anthropic
# ships in a future release rides along by default. Update this list
# only when something *bulky and session-shaped* lands.
mkdir "$STAGE/.claude"
CLAUDE_SKIP=(
  history.jsonl     # global prompt history (22+ MB)
  projects          # per-project session transcripts
  sessions          # session metadata
  tasks plans todos # prior-session task state
  file-history      # per-session file-edit snapshots
  paste-cache       # per-session paste tracking
  shell-snapshots   # per-shell snapshots
  session-env       # per-session env snapshots
  telemetry         # CLI telemetry (we own our own)
  stats-cache.json  # per-session stats cache
  debug             # debug dumps
  downloads         # downloaded files
  backups           # .claude.json backups (we own our copy)
  chrome            # Chrome integration state
  ralph-state       # plugin state from prior sessions
  .last-cleanup     # cleanup marker (regenerates)
  # ~400 MB host npm install of the CLI; the leerie image installs
  # @anthropic-ai/claude-code globally via the Dockerfile, so this is
  # pure dead weight on the wire to Fly. Local nerdctl runs bind-mount
  # the host $HOME/.claude so they pick up the local install regardless.
  local
  # Skip the plugin cache and marketplaces (hundreds of MB on a typical
  # host — vercel's node_modules alone is ~150 MB). These are rebuildable
  # from the small JSON files we still seed (installed_plugins.json,
  # known_marketplaces.json). seed_auth runs `claude plugin marketplace
  # add` + `claude plugin install` on the remote after the tar pipe to
  # repopulate them on the machine's fast public egress instead of the
  # slow WireGuard wire.
  plugins/cache
  plugins/marketplaces
)
if command -v rsync >/dev/null 2>&1; then
  EXCLUDES=()
  for s in "${CLAUDE_SKIP[@]}"; do EXCLUDES+=(--exclude="$s"); done
  rsync -a "${EXCLUDES[@]}" --exclude='settings.json.*' \
    "$HOME/.claude/" "$STAGE/.claude/"
else
  cp -aR "$HOME/.claude/." "$STAGE/.claude/"
  for s in "${CLAUDE_SKIP[@]}"; do
    rm -rf "$STAGE/.claude/$s"
  done
  rm -f "$STAGE"/.claude/settings.json.*
fi

# -- macOS-only: extract OAuth credentials from Keychain. --
# On macOS the CLI stores its OAuth token in the Keychain (service
# `Claude Code-credentials`), not in a file. The Linux CLI reads the
# same JSON from ~/.claude/.credentials.json, so writing the Keychain
# blob to that path inside the container's staged .claude/ makes the
# Linux file-based code path work transparently on both platforms.
#
# MUST run AFTER the .claude/ copy above, otherwise the rsync would
# overwrite the credentials file.
#
# `security find-generic-password -w` succeeds silently when the
# caller is in the user's login session (which `./leerie` always is);
# outside that (SSH-without-tty, daemons) it would prompt or fail.
# Best-effort: if extraction fails, fall back to the legacy
# CLAUDE_CODE_OAUTH_TOKEN env-var bridge so workers still authenticate.
if [ "$OS" = "Darwin" ]; then
  if security find-generic-password -s "Claude Code-credentials" \
       -w >"$STAGE/.claude/.credentials.json" 2>/dev/null && \
     [ -s "$STAGE/.claude/.credentials.json" ]; then
    chmod 600 "$STAGE/.claude/.credentials.json"
  else
    rm -f "$STAGE/.claude/.credentials.json"
    if [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
      AUTH_MOUNTS+=(-e "CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN")
    else
      remote_log "note — could not extract Claude credentials from Keychain."
      echo "  Export CLAUDE_CODE_OAUTH_TOKEN in your shell, or grant the launcher" >&2
      echo "  Keychain access (the prompt that pops up the first time)." >&2
    fi
  fi
fi

# -- ~/.git* dotfiles + XDG ~/.config/git/. --
# Copy every host-side ~/.git* sibling that exists (.gitconfig,
# .gitconfig.local, .gitignore_global, .gitignore, .git-credentials)
# plus the XDG config dir. Each lands in $STAGE at the path that maps
# to its default in-container location.
for f in "$HOME"/.git*; do
  [ -e "$f" ] || continue
  cp -aR "$f" "$STAGE/"
done
if [ -d "$HOME/.config/git" ]; then
  mkdir -p "$STAGE/.config"
  cp -aR "$HOME/.config/git" "$STAGE/.config/"
fi

# -- ~/.netrc, ~/.ssh/, ~/.gnupg/ (auth/signing material). --
# Workers may need to push (SSH), authenticate over HTTPS (.netrc),
# or sign commits (GPG). Colima runs the VM on the same machine the
# host user already controls, so the trust boundary doesn't widen by
# exposing these to a container that user already owns. Exposure is
# per-container and the staging dir is reaped on exit. CRITICAL:
# filter out sockets and ephemeral runtime files — the agent sockets
# (S.gpg-agent, ssh-agent's UNIX sockets) are host-bound, can't be
# `cp -a`'d cleanly, and aren't reachable from inside the container.
if [ -f "$HOME/.netrc" ]; then
  cp -a "$HOME/.netrc" "$STAGE/.netrc"
fi
if [ -d "$HOME/.ssh" ]; then
  mkdir -p "$STAGE/.ssh"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a \
      --exclude='agent' --exclude='S.*' --exclude='*.sock' \
      "$HOME/.ssh/" "$STAGE/.ssh/"
  else
    cp -aR "$HOME/.ssh/." "$STAGE/.ssh/"
    rm -rf "$STAGE/.ssh/agent"
    find "$STAGE/.ssh" -name 'S.*' -delete 2>/dev/null
    find "$STAGE/.ssh" -name '*.sock' -delete 2>/dev/null
  fi
  chmod 700 "$STAGE/.ssh"
fi
if [ -d "$HOME/.gnupg" ]; then
  mkdir -p "$STAGE/.gnupg"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --exclude='S.*' --exclude='*.sock' \
      "$HOME/.gnupg/" "$STAGE/.gnupg/"
  else
    cp -aR "$HOME/.gnupg/." "$STAGE/.gnupg/"
    find "$STAGE/.gnupg" -name 'S.*' -delete 2>/dev/null
    find "$STAGE/.gnupg" -name '*.sock' -delete 2>/dev/null
  fi
  chmod 700 "$STAGE/.gnupg"
fi

# -- Mount each staged file/dir at its default in-container path. --
# Files mount as files; dirs mount as dirs. The container sees the
# normal default paths — no env-var redirection needed.
AUTH_MOUNTS+=(-v "$STAGE/.claude.json:/home/leerie/.claude.json")
AUTH_MOUNTS+=(-v "$STAGE/.claude:/home/leerie/.claude")
for relpath in .gitconfig .gitconfig.local .gitignore \
               .gitignore_global .git-credentials .netrc; do
  if [ -e "$STAGE/$relpath" ]; then
    AUTH_MOUNTS+=(-v "$STAGE/$relpath:/home/leerie/$relpath")
  fi
done
if [ -d "$STAGE/.config/git" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.config/git:/home/leerie/.config/git")
fi
if [ -d "$STAGE/.ssh" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.ssh:/home/leerie/.ssh")
fi
if [ -d "$STAGE/.gnupg" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.gnupg:/home/leerie/.gnupg")
fi

# Best-effort host cleanup. Container is --rm; its writes inside the
# mounts vanish with the container. This removes the host scratch.
trap 'rm -rf "$STAGE"' EXIT

# --- finalize-phase auth is host-side now -------------------------------
# Previous versions of leerie bind-mounted ~/.config/gh, ~/.git-credentials,
# ~/.ssh, and $SSH_AUTH_SOCK into the container so finalize could push
# and open a PR. After DESIGN §6 *Finalization* moved that step to the
# host launcher (post-container-exit), those mounts are no longer
# necessary — git/gh/ssh run with the host's own auth state, where they
# already work. The host preflight above verified gh auth + origin.

# --- per-repo dependency caches (DESIGN §6½, IMPLEMENTATION §0.5) -------
# Five host-side cache dirs survive across runs so:
#   - mise doesn't re-install Node 20.11.0 every time the user runs leerie
#     against a repo with .nvmrc: 20.11.0,
#   - pnpm / pip / Go / Cargo installs hit warm caches.
# Created lazily (mkdir -p) on every leerie invocation — cheap on existing
# dirs, free of failure modes on first run.
# Concurrency-safety per cache is documented in IMPLEMENTATION §0.5;
# pip's pattern (warm once serially in phase_provision, hit cached
# wheels in parallel from worktree replays) is documented in DESIGN §6½.
mkdir -p "$HOME/.cache/leerie/mise-data" \
         "$HOME/.cache/leerie/pnpm-store" \
         "$HOME/.cache/leerie/pip" \
         "$HOME/.cache/leerie/go-mod" \
         "$HOME/.cache/leerie/cargo" \
         "$LEERIE_STATE_HOST_DIR"

CACHE_MOUNTS=(
  -v "$HOME/.cache/leerie/mise-data:/home/leerie/.local/share/mise"
  -v "$HOME/.cache/leerie/pnpm-store:/home/leerie/.cache/leerie/pnpm-store"
  -v "$HOME/.cache/leerie/pip:/home/leerie/.cache/leerie/pip"
  -v "$HOME/.cache/leerie/go-mod:/home/leerie/.cache/leerie/go-mod"
  -v "$HOME/.cache/leerie/cargo:/home/leerie/.cache/leerie/cargo"
  # pnpm reads its store path from `npm_config_store_dir` (or `store-dir`
  # in .npmrc, or `--store-dir` CLI). There is no `PNPM_STORE_PATH`; a
  # prior version of this file set that and pnpm silently ignored it,
  # falling back to ~/.local/share/pnpm/store inside the container —
  # which is NOT bind-mounted, so every run paid full registry cost.
  -e "npm_config_store_dir=/home/leerie/.cache/leerie/pnpm-store"
  -e "PIP_CACHE_DIR=/home/leerie/.cache/leerie/pip"
  -e "GOMODCACHE=/home/leerie/.cache/leerie/go-mod"
  -e "CARGO_HOME=/home/leerie/.cache/leerie/cargo"
)
# MISE_DATA_DIR / MISE_SYSTEM_DATA_DIR are baked into the image as ENV
# (Dockerfile) so the resolver and mount target are stable across
# launcher invocations. Not user-tunable here.

# --- remote: resolve Fly.io image tag -----------------------------------
# FLY_IMAGE_TAG is the registry-tagged image that will be launched as a
# Fly Machine. It is only resolved when REMOTE=true so the local path
# does not pay the version-lookup cost.
resolve_fly_image_tag() {
  local fly_app region version tag
  fly_app="${LEERIE_FLY_APP:-leerie}"
  region="${FLY_REGION:-iad}"
  version="$LEERIE_VERSION"
  tag="registry.fly.io/$fly_app:$version"
  # Allow the caller to override the full tag via env.
  echo "${LEERIE_FLY_IMAGE:-$tag}"
}

# --- remote: ensure published image -------------------------------------
# Closes the operator-step gap where the first remote run fails because
# the registry tag wasn't built/pushed yet. Strategy: cache positive hits
# in ~/.cache/leerie/published-tags.txt; on miss, invoke build-push.sh
# --push (which is idempotent at the registry — pushing an already-
# present manifest just no-ops the layers). The cache is a *positive*
# list only, so a manual `flyctl image` deletion is self-healing.
#
# Skipped entirely when NO_AUTO_PUBLISH=true (the operator manages
# publishes themselves and accepts the manifest-not-found failure mode).
ensure_image() {
  local tag="$1" cache_dir cache_file
  cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/leerie"
  cache_file="$cache_dir/published-tags.txt"
  if [ -f "$cache_file" ] && grep -Fxq "$tag" "$cache_file" 2>/dev/null; then
    return 0
  fi
  local build_push="$LEERIE_REPO/scripts/remote/build-push.sh"
  if [ ! -x "$build_push" ]; then
    remote_log "error: $build_push not found or not executable"
    return 1
  fi
  local fly_app="${LEERIE_FLY_APP:-leerie}"

  # Auto-create the Fly app if missing. flyctl apps list returns a JSON
  # array; check for a Name match. The remote builder and registry push
  # both require the app to exist. Idempotent on existing apps.
  if ! flyctl apps list --json 2>/dev/null \
       | python3 -c '
import json, sys
try:
    apps = json.load(sys.stdin)
    names = [a.get("Name") or a.get("name") for a in apps]
    sys.exit(0 if sys.argv[1] in names else 1)
except Exception:
    sys.exit(1)
' "$fly_app"; then
    remote_log "remote: Fly app '$fly_app' does not exist — creating it"
    if ! flyctl apps create "$fly_app" 2>&1; then
      remote_log "error: flyctl apps create $fly_app failed"
      echo "  Create it manually: flyctl apps create $fly_app" >&2
      return 1
    fi
  fi

  # Forward --local-build to build-push.sh when the launcher was invoked
  # with --local-build or LEERIE_LOCAL_BUILD=1. Default is remote builder
  # (no host Docker daemon required).
  local build_args=(--app "$fly_app" --push)
  if [ "${LOCAL_BUILD:-false}" = "true" ]; then
    build_args+=(--local-build)
  fi

  remote_log "remote: ensuring image $tag is published (cache miss)"
  if ! "$build_push" "${build_args[@]}"; then
    remote_log "error: build-push.sh failed; remote run cannot proceed"
    return 1
  fi
  mkdir -p "$cache_dir"
  printf '%s\n' "$tag" >> "$cache_file"
  return 0
}

# --- run -----------------------------------------------------------------
container_rc=0
if [ "$RUNTIME" = "fly" ]; then
  # --- remote execution path (Fly.io Machines) -------------------------
  # provision.sh implements the machine create → started → destroy-on-exit
  # lifecycle — the remote equivalent of `nerdctl run --rm`.
  # Sourcing it brings provision_machine() and destroy_machine() into scope
  # and registers an EXIT/INT/TERM trap after the machine starts so no
  # Ctrl-C or crash can leak a machine.
  #
  # seed-auth.sh seeds Claude config + git identity so `claude -p` workers can
  # authenticate and commit. seed-repo.sh tar-pipes a git-aware payload to /work
  # via `flyctl ssh console -C "tar -xC /work"` — `git ls-files` honors
  # .gitignore + `.git/` verbatim + force-include the repo's .claude/ + always
  # skip .leerie/. No in-machine `git clone` (the machine deliberately has no
  # GitHub credentials). Orchestration inside the machine follows after both
  # seedings succeed.
  remote_log "remote: starting Fly.io machine (--runtime fly / LEERIE_RUNTIME=fly / leerie.toml runtime=fly)"

  # Default LEERIE_REMOTE_EXIT_RC to 130 (SIGINT) so the EXIT/INT trap
  # registered by provision.sh routes a Ctrl-C-during-tail to the
  # `130|143)` detach banner arm in decide_teardown — even when the
  # INT trap fires before the post-tail `export
  # LEERIE_REMOTE_EXIT_RC=$container_rc` (~30 lines below) runs.
  # Overwritten on every non-SIGINT path; the 130 default only
  # "survives" when the launcher dies before the post-tail export,
  # which is exactly the Ctrl-C case.
  export LEERIE_REMOTE_EXIT_RC=130

  # Preflight: ensure flyctl is on PATH and authenticated. require_flyctl
  # in lib.sh handles auto-install on first --runtime fly use (parallels
  # the local-runtime auto-install in scripts/install.sh). Respects
  # --no-runtime-install / LEERIE_NO_RUNTIME_INSTALL=1 (falls back to
  # hint+exit). Must run before ensure_image (which uses flyctl to push)
  # and before any other remote script is sourced.
  # shellcheck disable=SC1091
  . "$LEERIE_REPO/scripts/remote/lib.sh"
  # Spawn (or reuse) the leerie-private ssh-agent at
  # ~/.cache/leerie/agent/ssh-agent.sock and set SSH_AUTH_SOCK for the
  # rest of this process tree. Must run BEFORE any flyctl ssh call so
  # Fly-issued certs never land in the user's main agent (which would
  # cause OpenSSH to offer them to github.com and trigger rate-limits).
  _leerie_fly_agent_ensure
  if ! require_flyctl; then
    exit 1
  fi

  # Generate a bootstrap run-id host-side if the user did not pass --run-id.
  # The orchestrator runs detached on the Fly Machine and the launcher's
  # tail needs to know which orchestrator.log path to follow *before* the
  # orchestrator has produced any output. The bootstrap id matches today's
  # orchestrator-side pre-classification pattern (`_bootstrap-<6hex>`); the
  # orchestrator will rename the dir to a category-prefixed final id at the
  # end of phase_classify (State.rename_to). The launcher's tail wrapper
  # handles the rename by polling for the final id afterwards. See DESIGN
  # §6 *Detached orchestrator (remote mode)*.
  if [ -z "$LEERIE_RUN_ID" ]; then
    LEERIE_RUN_ID="_bootstrap-$(python3 -c "import secrets; print(secrets.token_hex(3))")"
    export LEERIE_RUN_ID
    # Append --run-id to REWRITTEN_ARGS so the orchestrator inside the
    # machine uses the same id (matches the --resume --run-id plumbing).
    REWRITTEN_ARGS+=("--run-id" "$LEERIE_RUN_ID")
  fi

  # Communicate the host's launch-time push intent to the in-Fly
  # orchestrator (DESIGN §6 *Finalization*, intent vs mechanism). The
  # orchestrator-side --no-push the in-Machine launcher injects is the
  # mechanism flag (Fly can't reach origin); --host-no-push is the
  # user's intent. The orchestrator gates pr_writer + the
  # run.json.no_push it writes on intent, not mechanism. Local-runtime
  # nerdctl invocation does NOT pass this — host_no_push stays None
  # there and push_will_happen() falls back to (not no_push).
  if [ "$NO_PUSH" = "true" ]; then
    REWRITTEN_ARGS+=("--host-no-push" "true")
  else
    REWRITTEN_ARGS+=("--host-no-push" "false")
  fi

  FLY_IMAGE_TAG="$(resolve_fly_image_tag)"
  export FLY_IMAGE_TAG

  # Ensure the image is published before flyctl machine run attempts to pull
  # it. Skipped if --no-auto-publish / LEERIE_NO_AUTO_PUBLISH=1 — the operator
  # is responsible for the build-push in that mode.
  if [ "$NO_AUTO_PUBLISH" != "true" ]; then
    if ! ensure_image "$FLY_IMAGE_TAG"; then
      exit 1
    fi
  fi

  PROVISION_SCRIPT="$LEERIE_REPO/scripts/remote/provision.sh"
  RESUME_SCRIPT="$LEERIE_REPO/scripts/remote/resume-machine.sh"
  SEED_AUTH_SCRIPT="$LEERIE_REPO/scripts/remote/seed-auth.sh"
  SEED_SCRIPT="$LEERIE_REPO/scripts/remote/seed-repo.sh"
  FETCH_SCRIPT="$LEERIE_REPO/scripts/remote/fetch-branch.sh"
  if [ ! -f "$PROVISION_SCRIPT" ]; then
    remote_log "error: $PROVISION_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$RESUME_SCRIPT" ]; then
    remote_log "error: $RESUME_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$SEED_AUTH_SCRIPT" ]; then
    remote_log "error: $SEED_AUTH_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$SEED_SCRIPT" ]; then
    remote_log "error: $SEED_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$FETCH_SCRIPT" ]; then
    remote_log "error: $FETCH_SCRIPT not found"
    container_rc=1
  else
    # shellcheck disable=SC1090
    . "$PROVISION_SCRIPT"
    # shellcheck disable=SC1090
    . "$RESUME_SCRIPT"
    # shellcheck disable=SC1090
    . "$SEED_AUTH_SCRIPT"
    # shellcheck disable=SC1090
    . "$SEED_SCRIPT"
    # shellcheck disable=SC1090
    . "$FETCH_SCRIPT"

    # Resume path: if a machine pointer exists for this run-id, resume
    # the existing Fly Machine instead of provisioning a new one.
    # (DESIGN §6 Remote pause-on-failure.) Uses the dual-file resolver
    # at leerie:76 — fly-machine.json first, then run.json — to mirror
    # the existing --stop/--kill/--finalize/--attach behavior. For
    # bootstrap-id runs paused before classify, run.json may not exist
    # on the host; fly-machine.json is the source of truth.
    _paused_mid=""
    if [ -n "$LEERIE_RUN_ID" ]; then
      _paused_mid="$(_resolve_fly_machine_id_from_run_dir \
                       "$LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID")"
    fi

    _provisioned=false
    _resumed=false
    if [ -n "$_paused_mid" ]; then
      if resume_machine "$_paused_mid"; then
        _provisioned=true
        _resumed=true
      elif [ "$IS_RESUME" = "true" ]; then
        # User explicitly asked to resume and the target machine is
        # unrecoverable (destroyed / refuses to start). resume_machine
        # already named the cause on stderr. Do NOT silently provision
        # a duplicate — exit with the failure so the user knows.
        container_rc=1
      fi
    elif [ "$IS_RESUME" = "true" ]; then
      # --resume against a run-id with no machine pointer anywhere
      # (no fly-machine.json, no run.json with fly_machine_id). Either
      # the run-id is a typo or the run was already cleaned up. Fail
      # loudly instead of silently provisioning a brand-new machine —
      # the user typed "resume", not "start a new run".
      remote_log "--resume: no Fly machine pointer found for run-id $LEERIE_RUN_ID"
      echo "  Looked for: $LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID/fly-machine.json" >&2
      echo "             $LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID/run.json (fly_machine_id field)" >&2
      echo "  Neither exists with a usable machine id." >&2
      echo "  Run 'leerie --list' to see known runs, or omit --resume to" >&2
      echo "  start a fresh run." >&2
      container_rc=1
    elif provision_machine; then
      _provisioned=true
    fi

    # E1: when resuming a bootstrap-id paused via `leerie --stop`, the
    # orchestrator on the machine has already renamed its run dir to
    # the final id via State.rename_to. Resuming with --run-id
    # _bootstrap-XXX would die in resolve_run_id (which skips
    # `_bootstrap-*` dirs). The orchestrator wrote the final id back to
    # /work/.leerie/launcher-<bootstrap>.runid before renaming — read it
    # over SSH, then rewrite LEERIE_RUN_ID and the --run-id element of
    # REWRITTEN_ARGS before the orchestrator is exec'd. Migrate the
    # host-side run dir (D2 created `_bootstrap-XXX/run.json`) to the
    # final id so `leerie --list` and subsequent verbs find the run by
    # its real name.
    if [ "$_resumed" = "true" ] && \
       [ -n "$LEERIE_RUN_ID" ] && \
       [[ "$LEERIE_RUN_ID" == _bootstrap-* ]]; then
      _bootstrap_pid="$LEERIE_RUN_ID"
      _final_id="$(flyctl ssh console --app "$FLY_APP" \
                     --machine "$LEERIE_MACHINE_ID" --pty=false \
                     -C "cat /work/.leerie/launcher-${_bootstrap_pid}.runid" \
                     2>/dev/null | head -1 | tr -d '[:space:]' || true)"
      if [ -n "$_final_id" ] && [ "$_final_id" != "$_bootstrap_pid" ]; then
        remote_log "remote: bootstrap id ${_bootstrap_pid} promoted to ${_final_id} on machine — rewriting LEERIE_RUN_ID"
        # Migrate host-side run dir if needed.
        _host_boot_dir="$LEERIE_STATE_HOST_DIR/runs/${_bootstrap_pid}"
        _host_final_dir="$LEERIE_STATE_HOST_DIR/runs/${_final_id}"
        if [ -d "$_host_boot_dir" ] && [ ! -d "$_host_final_dir" ]; then
          mv "$_host_boot_dir" "$_host_final_dir" 2>/dev/null || true
        fi
        # Rewrite LEERIE_RUN_ID and any `--run-id <bootstrap>` element in
        # REWRITTEN_ARGS (the user typed `--resume --run-id <bootstrap>`,
        # the loop at line ~920 passed it through).
        LEERIE_RUN_ID="$_final_id"
        export LEERIE_RUN_ID
        _rewritten_count="${#REWRITTEN_ARGS[@]}"
        _i=0
        while [ "$_i" -lt "$_rewritten_count" ]; do
          if [ "${REWRITTEN_ARGS[$_i]}" = "--run-id" ] && \
             [ "$((_i + 1))" -lt "$_rewritten_count" ] && \
             [ "${REWRITTEN_ARGS[$((_i + 1))]}" = "$_bootstrap_pid" ]; then
            REWRITTEN_ARGS[$((_i + 1))]="$_final_id"
            break
          fi
          _i=$((_i + 1))
        done
      fi
    fi

    # Promote the PID-keyed attach pointer to a run-keyed one as soon as
    # the machine is up, BEFORE seed_auth/seed_repo can fail. If anything
    # between here and the orchestrator-detach below errors out,
    # decide_teardown pauses the machine and the user's resume command
    # (`leerie --resume --run-id $LEERIE_RUN_ID --runtime fly`) needs this
    # file to resolve fly_machine_id. provision_machine writes
    # $LEERIE_STATE_HOST_DIR/remote/$$.json unconditionally on success (provision.sh:587-613);
    # resume_machine doesn't (the prior launcher's file is gone — different $$ —
    # but the run-keyed pointer survives from the original provision, so the
    # `[ ! -f "$_run_record" ]` guard makes this a no-op on resume).
    if [ "$_provisioned" = "true" ] && [ -n "$LEERIE_RUN_ID" ]; then
      _pid_record="$LEERIE_STATE_HOST_DIR/remote/$$.json"
      mkdir -p "$LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID" 2>/dev/null || true
      _run_record="$LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID/fly-machine.json"
      if [ -f "$_pid_record" ] && [ ! -f "$_run_record" ]; then
        cp "$_pid_record" "$_run_record" 2>/dev/null || true
      fi
      # Persist the task argument so a bootstrap-stage resume can recover
      # it. The in-machine orchestrator's --resume requires state.json,
      # which is never written for failures before classify. The launcher
      # strips --resume on bootstrap-stage resumes (routing to the fresh-
      # launch branch), but that branch needs a task argument. Without
      # this file the user has to retype the task on every retry.
      _task_record="$LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID/task.txt"
      if [ -n "$LEERIE_TASK_ARG" ] && [ ! -f "$_task_record" ]; then
        printf '%s' "$LEERIE_TASK_ARG" > "$_task_record" 2>/dev/null || true
      fi
    fi

    if [ "$_provisioned" = "true" ]; then
      # Machine is running and reachable. Seed Claude config + git identity
      # so `claude -p` workers can authenticate and commit, then seed the
      # working tree (git clone + rsync uncommitted delta).  Then run the
      # orchestrator inside the machine and stream the completed run branch
      # back to the host for the host-side finalize (push + gh pr create).
      export USER_REPO
      _seed_ok=true
      if ! seed_auth; then
        remote_log "error: seed_auth failed — aborting remote run"
        container_rc=1
        _seed_ok=false
      elif [ "$_resumed" = "true" ]; then
        # Resume path: machine already has /work, just refresh the dirty
        # delta unless --no-re-seed was passed. (Phase 4 auto-re-seed.)
        if [ "$NO_RE_SEED" != "true" ]; then
          # shellcheck disable=SC1091
          . "$LEERIE_REPO/scripts/remote/re-seed.sh"
          [ "$RE_SEED_FORCE" = "true" ] && export LEERIE_RE_SEED_FORCE=1
          if ! re_seed; then
            remote_log "error: re_seed failed — aborting remote run"
            container_rc=1
            _seed_ok=false
          fi
        fi
      elif ! seed_repo; then
        remote_log "error: repo seeding failed for machine $LEERIE_MACHINE_ID"
        container_rc=1
        _seed_ok=false
      fi
      # Inspect dirs: rsync each --inspect-dir host path to
      # /inspect/<basename> on the machine. Re-resolved on every run
      # (including resume) so the user can add an inspect dir at
      # --resume time and expect it to land. The orchestrator already
      # has the rewritten --inspect-dir /inspect/<basename> flags in
      # REWRITTEN_ARGS; this just makes the in-machine paths exist.
      # See docs/IMPLEMENTATION.md §0.5 "Remote runtime (Fly.io)
      # transport". A failure is fatal — workers cannot do their job
      # with --add-dir flags pointing at non-existent paths.
      if [ "$_seed_ok" = "true" ]; then
        _serialize_inspect_host_targets
        if ! seed_inspect_dirs; then
          remote_log "error: inspect-dir seeding failed for machine $LEERIE_MACHINE_ID"
          container_rc=1
          _seed_ok=false
        fi
      fi
      if [ "$_seed_ok" = "true" ]; then
        # Start the orchestrator detached on the Fly Machine. setsid makes
        # it a session leader so SIGHUP from the exec channel closing does
        # not reach it; nohup is belt-and-braces. stdout/stderr go to a log
        # file the machine owns; stdin is /dev/null. The launcher generated
        # the bootstrap run-id host-side and passed it via --run-id in
        # REWRITTEN_ARGS, so the path is known before the orchestrator
        # produces any output. DESIGN §6 *Detached orchestrator (remote
        # mode)*.
        remote_log "remote: machine $LEERIE_MACHINE_ID seeded — starting orchestrator (detached)"

        # Detached-launch wrapper. Uses a python3 heredoc instead of
        # `sh -c "...setsid nohup..."` for three reasons:
        #   (a) argv goes via sys.argv — no shell quoting needed for the
        #       run-id or REWRITTEN_ARGS, so chars like ' or $ or \n
        #       cannot break the wrapper or alter the orchestrator argv.
        #   (b) start_new_session=True is equivalent to setsid and works
        #       on every Python ≥ 3.2 — no dependency on the remote
        #       shell understanding `setsid` (busybox sh does not).
        #   (c) Launcher errors from python (not from sh quoting) surface
        #       on stderr without the outer 2>&1 redirect, so a failed
        #       launch is diagnosable.
        # flyctl `machine exec` dropped both `--stdin` and the post-`--`
        # argv form. Switch to `ssh console -C "<cmd>"` which (a) takes
        # the remote command as a single string and (b) forwards host
        # stdin. The Python launcher is built host-side with the argv
        # JSON literal embedded into the source, then piped to
        # `python3 -` on the machine — python reads its program from
        # stdin, no remote-shell argv quoting in play.

        # Strip --resume from REWRITTEN_ARGS when the run is still in the
        # bootstrap window. `--resume` on the host means "wake the paused
        # Fly machine"; the in-machine orchestrator interprets it as
        # "resume orchestrator state from disk." For a `_bootstrap-*` id,
        # no orchestrator state exists yet (by definition — classify
        # hasn't run), so the orchestrator's --resume branch dies with
        # "does not match any known run." The orchestrator's
        # --run-id <bootstrap-*> branch already honors the id and creates
        # fresh state; filtering --resume here routes there. Post-classify
        # resumes keep --resume (LEERIE_RUN_ID was promoted to the final
        # id by the rewrite block at lines 1843-1856 above, so this guard
        # is False and REWRITTEN_ARGS flows through unchanged).
        if [ "${IS_RESUME:-false}" = "true" ] && [[ "$LEERIE_RUN_ID" == _bootstrap-* ]]; then
          _filtered=()
          for _a in ${REWRITTEN_ARGS[@]+"${REWRITTEN_ARGS[@]}"}; do
            [ "$_a" = "--resume" ] || _filtered+=("$_a")
          done
          REWRITTEN_ARGS=(${_filtered[@]+"${_filtered[@]}"})
          # If the user didn't retype the task on this resume, recover it
          # from the persisted task.txt written at first-launch. The
          # orchestrator's fresh-launch branch (which we routed to by
          # stripping --resume) requires a task argument.
          _task_record="$LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID/task.txt"
          if [ -z "$LEERIE_TASK_ARG" ] && [ -f "$_task_record" ]; then
            _restored_task="$(cat "$_task_record" 2>/dev/null || true)"
            if [ -n "$_restored_task" ]; then
              REWRITTEN_ARGS+=("$_restored_task")
              remote_log "remote: recovered task from $_task_record"
            fi
          fi
        fi

        _launch_argv_json="$(python3 -c '
import json, sys
print(json.dumps(sys.argv[1:]))
' "$LEERIE_RUN_ID" "${REWRITTEN_ARGS[@]}")"
        # Derive the host's IANA timezone so we can bake it into
        # child_env["TZ"] inside the heredoc below. `readlink` of
        # /etc/localtime works on both macOS (/var/db/timezone/...)
        # and Linux (/usr/share/zoneinfo/...); the sed strips
        # everything up through `/zoneinfo/` to leave the IANA
        # name. Empty if /etc/localtime isn't a symlink — Python's
        # astimezone() then falls back to UTC.
        _host_tz="$(readlink /etc/localtime 2>/dev/null | sed 's|.*/zoneinfo/||')"
        _launch_script="$(cat <<PY
import fcntl, os, pwd, subprocess, sys, time
argv = ${_launch_argv_json}
run_id = argv[0]
orch_args = argv[1:]
run_dir = "/work/.leerie/runs/" + run_id
os.makedirs(run_dir, exist_ok=True)
# Make /work/.leerie, /work/.leerie/runs, and the run dir itself writable
# by leerie — os.makedirs created them as root (this wrapper runs as
# root via ssh-console). The orchestrator runs as leerie and may need
# to create sibling run dirs (bootstrap → final id rename, etc).
leerie_pw = pwd.getpwnam("leerie")
for d in ("/work/.leerie", "/work/.leerie/runs", run_dir):
    try:
        os.chown(d, leerie_pw.pw_uid, leerie_pw.pw_gid)
    except OSError:
        pass
# Refuse to spawn a second orchestrator on the same run dir. The real
# enforcement is in State.__init__ (which acquires the same flock and
# dies with EXIT_LOCKED=75 if held). This probe is the fast-path: it
# avoids the cost of spawning a Python process that would just die in
# startup. Same primitive (advisory flock on run_dir) used at both
# layers. See DESIGN §6 *Single owner per run dir*.
_probe_fd = os.open(run_dir, os.O_RDONLY)
try:
    try:
        fcntl.flock(_probe_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        fcntl.flock(_probe_fd, fcntl.LOCK_UN)
    except BlockingIOError:
        sys.stderr.write("orchestrator already running for run " + run_id + "\\n")
        sys.stderr.write("Tail the existing run instead of spawning a duplicate:\\n")
        sys.stderr.write("  leerie --attach " + run_id + "\\n")
        sys.exit(75)
finally:
    os.close(_probe_fd)
log_path = run_dir + "/orchestrator.log"
pid_path = run_dir + "/orchestrator.pid"
# Build the env from scratch — ssh-console sets HOME=/root which would
# point claude at the wrong credentials dir. Pin HOME=/home/leerie and
# leave PATH alone (the image's PATH includes mise + Claude Code CLI
# under /usr/local/share/mise/installs/node/lts-current/bin).
child_env = dict(os.environ)
child_env["HOME"] = "/home/leerie"
child_env["USER"] = "leerie"
child_env["LOGNAME"] = "leerie"
# Carry the host repo's basename so the orchestrator's log() prefix
# (Path(USER_REPO).name) matches the host-side remote_log() prefix.
# Without this the orchestrator's cwd=/work falls back to basename
# "work" and the [leerie] [<repo>] contract breaks mid-stream once
# the launcher starts tailing this process's stdout. The host bash
# heredoc is unquoted (<<PY), so basename runs host-side and the
# resulting literal is baked into the script piped to the Fly machine.
child_env["USER_REPO"] = "$(basename "$USER_REPO")"
# Carry the host's IANA timezone so the in-machine orchestrator's
# log() ISO-8601 prefix matches the host-side remote_log() offset.
# Fly machines default to UTC; without this the user reads mixed
# offsets (host -05:00, machine +00:00) in the tailed stream and
# can't compare timestamps at a glance. The Dockerfile installs
# tzdata so /usr/share/zoneinfo/<IANA> resolves. If readlink fails
# (e.g. /etc/localtime not a symlink), the substitution yields ""
# and Python's astimezone() falls back to UTC — same as today.
child_env["TZ"] = "${_host_tz}"
# Ensure the launcher's PATH includes the mise-managed claude binary.
# (The Dockerfile installs claude into the mise-managed node prefix;
# fly's hallpass ssh session inherits a minimal PATH that may not
# include /usr/local/share/mise/...; add it defensively.)
extra_path = "/usr/local/share/mise/installs/node/lts-current/bin"
if extra_path not in child_env.get("PATH", ""):
    child_env["PATH"] = extra_path + ":" + child_env.get("PATH", "")
with open(log_path, "ab") as log_f:
    p = subprocess.Popen(
        ["python3", "/opt/leerie-image/orchestrator/leerie.py", "--no-push", *orch_args],
        stdin=subprocess.DEVNULL,
        stdout=log_f,
        stderr=log_f,
        start_new_session=True,
        # cwd=/work so the orchestrator's os.getcwd() returns /work
        # regardless of the launching shell's (possibly stale) cwd.
        cwd="/work",
        # Run as the leerie user — the Fly image's USER leerie line only
        # applies to the entrypoint; ssh-console sessions land as root,
        # and any process we spawn here inherits root unless we set
        # this explicitly. The orchestrator needs to run as leerie so
        # claude finds creds at /home/leerie/.claude/.credentials.json
        # and so files it creates are owned by leerie (not root).
        user="leerie",
        group=leerie_pw.pw_gid,
        env=child_env,
    )
# Poll briefly before recording the pid. If this Popen lost the
# State.__init__ flock race against an already-running orchestrator
# for this run (the concurrent-spawn race described in DESIGN §6
# *Single owner per run dir*), the child exits 75 within
# milliseconds. Writing its pid to orchestrator.pid before the race
# resolves would overwrite the winning orchestrator's pid with a
# dead one — the stale-pid contagion that breaks --attach --tail's
# liveness check and --finalize --force's safety belt.
#
# Budget: 2 s (10 x 0.2 s). The realistic time from Popen to the
# child's State.__init__ flock attempt is ~300-500 ms (Python
# interpreter cold start + leerie.py imports + main()'s pre-State
# config resolution); under disk pressure it could reach ~1 s.
# State.__init__ itself is microseconds — open the run_dir fd,
# attempt fcntl.flock, return or raise — but the relevant budget
# is the end-to-end time from Popen to that point. 2 s leaves
# comfortable headroom for both paths:
#   - Winner: child reaches State.__init__ and proceeds. Poll
#     times out, we write the pid.
#   - Loser: child reaches State.__init__ and exits 75. We
#     observe rc=75 and skip the pid write.
# The reader-side /proc cross-check in lib.sh and
# force-finalize.sh catches any residual edge case where the
# budget is exceeded on the loser path.
for _ in range(10):
    if p.poll() is not None:
        break
    time.sleep(0.2)
if p.poll() == 75:
    # Stillborn flock-loser — the winner still owns the run. Do not
    # touch the pid file. The launcher's existing rc=75 short-circuit
    # (~30 lines below in the bash dispatcher) routes the user to
    # --attach via container_rc=130.
    sys.exit(75)
with open(pid_path, "w") as pid_f:
    pid_f.write(str(p.pid) + "\n")
PY
)"
        _launch_rc=0
        printf '%s' "$_launch_script" \
          | flyctl ssh console --app "$FLY_APP" --machine "$LEERIE_MACHINE_ID" \
              --pty=false -C "python3 -" \
          || _launch_rc=$?
        if [ "$_launch_rc" = "75" ]; then
          # The remote launch-wrapper's flock probe fired: an orchestrator
          # is already running for this run_id on the machine. Treat as a
          # soft refusal — the user's work is unaffected; route them to
          # --attach instead of synthesizing a "failed to start" error.
          # Mirrors State.__init__'s EXIT_LOCKED=75 (DESIGN §6 *Single
          # owner per run dir*).
          #
          # CRITICAL: container_rc=130 (not 1, not 75). The post-tail
          # `export LEERIE_REMOTE_EXIT_RC="$container_rc"` (~30 lines
          # below) propagates this into the decide_teardown trap.
          # Routing matters here:
          #   - rc=75 → EX_TEMPFAIL "genuine terminal exit" →
          #     sync-then-finalize-then-destroy → kills live machine A.
          #   - rc=1  → "*)" default → pause-on-failure → stop_machine
          #     also kills live machine A (graceful pause, but still
          #     interrupts the live run).
          #   - rc=130 → "130|143)" detach banner → leaves the machine
          #     alone and prints reattach hints (decide_teardown at
          #     scripts/remote/provision.sh:401). Exactly what we want
          #     when the original orchestrator is still alive.
          remote_log "--resume refused: orchestrator already running for $LEERIE_RUN_ID on machine $LEERIE_MACHINE_ID"
          remote_log "  The live machine is being LEFT RUNNING."
          remote_log "  Tail it without spawning a duplicate:"
          remote_log "    leerie --attach $LEERIE_RUN_ID --tail"
          container_rc=130
        elif [ "$_launch_rc" != "0" ]; then
          remote_log "error: failed to start detached orchestrator on machine $LEERIE_MACHINE_ID (rc=$_launch_rc)"
          container_rc=1
        else
          # The PID-keyed → run-keyed pointer promotion happened earlier
          # (right after provision_machine succeeded), so the run dir
          # already has fly-machine.json by the time we get here. The
          # orchestrator will rename the run dir at classify time; the
          # launcher's tail wrapper handles the rename via the handover
          # file the orchestrator writes (see DESIGN §6).

          # Tail the orchestrator log for the user's terminal. This is a
          # separate exec session; its death (Ctrl-C, broken pipe, laptop
          # closing) does NOT propagate to the orchestrator. After the
          # orchestrator's State.rename_to promotes the bootstrap dir, it
          # writes the final run-id to /work/.leerie/launcher-<bootstrap>.runid;
          # the wrapper script reads that, re-tails the new path, and on
          # orchestrator-pid exit prints a finalize hint and ends.
          remote_log "remote: tailing orchestrator log (Ctrl-C to detach — orchestrator keeps running)"

          # The remote tail wrapper is shared with `leerie --attach --tail`
          # via render_tail_wrapper in scripts/remote/lib.sh (already
          # sourced above). It handles the `_bootstrap-<6hex>` →
          # final-id rename transparently and prints the finalize hint
          # when the orchestrator pid disappears.
          _tail_script="$(render_tail_wrapper)"

          # Prepend an env-var assignment to the wrapper script so the
          # run-id reaches the wrapper via $LEERIE_TAIL_RUN_ID. Current
          # flyctl transports (ssh console -C, and the deprecated
          # machine exec form) both pass the remote command as a
          # single string, not as argv after `--`. The wrapper's
          # `${LEERIE_TAIL_RUN_ID:-$1}` fallback consults the env var
          # first; the env-var prefix below makes that the source of
          # truth.
          _tail_invocation="LEERIE_TAIL_RUN_ID='$LEERIE_RUN_ID'; export LEERIE_TAIL_RUN_ID
$_tail_script"
          orch_rc=0
          # ssh console -C takes the command as a single string and
          # forwards stdin. Pipe the wrapper script (with the env-var
          # preamble) to `sh -s` so quoting is wholly host-side.
          printf '%s' "$_tail_invocation" \
            | flyctl ssh console --app "$FLY_APP" \
                --machine "$LEERIE_MACHINE_ID" --pty=false \
                -C "sh -s" \
            || orch_rc=$?

          # On a clean tail exit (the orchestrator's pid disappeared), we
          # cannot read the orchestrator's true exit code — it ran detached.
          # The decide_teardown trap classifies based on LEERIE_REMOTE_EXIT_RC
          # which here reflects the TAIL's exit, not the orchestrator's.
          # Per the reclassified table (DESIGN §6), tail-exit cleanly
          # (rc=0 from the wrapper) is treated as "user can finalize"; the
          # launcher does NOT call fetch_branch from here — `leerie --finalize`
          # does that. See *Detached run finalization* in IMPLEMENTATION.md.
          container_rc=$orch_rc
        fi
      fi
    else
      # Reached when neither resume_machine nor provision_machine
      # produced a running machine (or --resume strict-fail set
      # container_rc=1 above). Surface a hint so the prior log lines
      # aren't the only signal — without this, a user reading the
      # tail sees `creating machine ...` followed by silence.
      if [ -z "${container_rc:-}" ] || [ "$container_rc" = "0" ]; then
        container_rc=1
      fi
      remote_log "remote: no Fly machine is running (resume/provision did not succeed) — aborting"
    fi
    # The EXIT trap registered in provision.sh (decide_teardown) reads
    # LEERIE_REMOTE_EXIT_RC to classify the orchestrator's exit code.
    # Pause-worthy: any non-zero other than EXIT_NEEDS_ANSWERS=10,
    # EX_TEMPFAIL=75 (rate-limit), SIGINT=130, SIGTERM=143.
    # (DESIGN §6 Remote pause-on-failure.)
    export LEERIE_REMOTE_EXIT_RC="$container_rc"
  fi
else
  # --- local container execution path ----------------------------------
  # --rm: container is removed on exit. Worktrees persist on the host via
  #       the /work bind mount; run state persists via the /leerie-state
  #       bind mount (LEERIE_STATE_HOST_DIR), so --resume still works.
  # Mount-table rationale lives in docs/IMPLEMENTATION.md §0.5.
  #
  # TTY flags adapt to whether the launcher itself has a controlling terminal:
  #   Terminal mode (real pty on stdin) → -it. The container gets a
  #     controlling TTY; leerie's log() lines stream live and the user can
  #     answer `--clarify` prompts interactively via input().
  #   Plugin mode (Claude Code's Bash tool: no TTY) → -i only.
  #     Inside the container, sys.stdin.isatty() returns False, so leerie's
  #     gather_answers and mid-execution clarification paths trigger the
  #     existing EXIT_NEEDS_ANSWERS=10 flow: write pending-questions.json
  #     under $LEERIE_STATE_DIR (=/leerie-state in the container, visible
  #     on the host via the LEERIE_STATE_HOST_DIR bind mount), exit 10.
  #     The plugin agent reads the file, asks the user in chat, writes
  #     answers.json to the same dir, re-runs the container with --answers.
  # Ctrl-C (terminal) or harness cancellation (plugin) → SIGINT to container
  # PID 1 → orchestrator exits → kernel reaps the PID namespace (DESIGN §6
  # *Worker subtree termination*). The cleanup guarantee is identical in
  # both modes.
  # Require BOTH stdin and stdout to be TTYs before asking nerdctl for `-t`.
  # Stdin alone is not enough: piping leerie's output (e.g. `leerie ... | tee log`)
  # leaves stdin a TTY but redirects stdout through a pipe, and nerdctl rejects
  # `-t` against a non-console stdout with "provided file is not a console"
  # before the orchestrator gets a chance to run. Plugin mode (Bash tool: no
  # TTY on stdin) still collapses to `-i`, preserving the EXIT_NEEDS_ANSWERS=10
  # file-passing contract documented in commands/leerie.md.
  TTY_FLAGS="-i"
  [ -t 0 ] && [ -t 1 ] && TTY_FLAGS="-it"

  # Use ${arr[@]+"${arr[@]}"} so empty arrays expand to nothing under
  # `set -u` (bash 3.2, the macOS system default, otherwise errors).
  #
  # Note: NOT `exec` — we need control to return to the launcher after the
  # container exits so the host-side finalize block (below) can run.
  # The --mount type=bind on /sys/fs/cgroup gives the orchestrator
  # cgroup v2 write access inside the container — required for the
  # per-worker memory.max / pids.max containment (DESIGN §6 "Worker
  # subtree termination — Memory containment"). cgroup v2 delegation
  # is file-permission based; no --privileged or --cap-add needed.
  # If the host doesn't have cgroup v2 (kernel <5.x or unified hier
  # disabled) the bind-mount no-ops cleanly and the orchestrator's
  # _cgroup_probe returns False, falling back to the pre-fix
  # uncapped behavior with one warn log line.
  nerdctl run \
    --rm $TTY_FLAGS \
    --name "leerie-$(date +%s)-$$" \
    -e LEERIE_INSPECT_DIRS= \
    -e LEERIE_STATE_DIR=/leerie-state \
    --mount type=bind,source=/sys/fs/cgroup,target=/sys/fs/cgroup,bind-propagation=rshared \
    -v "$USER_REPO:/work" \
    -v "$LEERIE_REPO:/opt/leerie-image:ro" \
    -v "$LEERIE_STATE_HOST_DIR:/leerie-state" \
    ${AUTH_MOUNTS[@]+"${AUTH_MOUNTS[@]}"} \
    ${CACHE_MOUNTS[@]+"${CACHE_MOUNTS[@]}"} \
    ${INSPECT_MOUNTS[@]+"${INSPECT_MOUNTS[@]}"} \
    -w /work \
    "$IMAGE_TAG" ${REWRITTEN_ARGS[@]+"${REWRITTEN_ARGS[@]}"} || container_rc=$?
fi

# --- host-side finalize (push + PR) -------------------------------------
# DESIGN §6 *Finalization*: the container's phase_finalize writes
# `finished_at` to .leerie/runs/<run-id>/run.json and exits 0. The
# launcher takes over from here, doing `git push` + `gh pr create` on
# the HOST so the host's working auth state (gh token, ssh-agent,
# Keychain) is what authenticates — no in-container forwarding required.
#
# **Local runtime only.** On the Fly path the run dir is NOT yet on the
# host when we reach this block — the stream-back happens inside
# `decide_teardown` (an EXIT trap in scripts/remote/provision.sh) that
# fires *after* this code returns. If we let this block run on Fly it
# always finds nothing (LATEST_RUN_DIR is empty, exits 0), then the
# trap syncs and destroys the machine without ever pushing. So: on
# Fly, finalize happens inside `decide_teardown` (it sources the same
# scripts/host-finalize.sh and calls host_finalize directly). On
# local, finalize happens here.
#
# Skip if:
#   - container exited non-zero (run failed; nothing to push)
#   - --no-push set (the user explicitly opted out)
#   - the structured-exit code (EXIT_NEEDS_ANSWERS=10) — the launcher's
#     plugin re-runs leerie with --answers after the user responds.
if [ "$container_rc" -ne 0 ] || [ "$NO_PUSH" = "true" ]; then
  exit "$container_rc"
fi

if [ "$RUNTIME" != "fly" ]; then
  # Locate the most-recent run dir under .leerie/runs/ that has a run.json
  # with finished_at set. The orchestrator writes run.json at finalize.
  # `find` + sort isn't portable with -printf; iterate and pick newest.
  LATEST_RUN_DIR=""
  LATEST_RUN_MTIME=0
  if [ -d "$LEERIE_STATE_HOST_DIR/runs" ]; then
    for run_json in "$LEERIE_STATE_HOST_DIR"/runs/*/run.json; do
      [ -f "$run_json" ] || continue
      # finished_at must be present and non-null.
      if [ "$(jq -r '.finished_at // ""' "$run_json")" = "" ]; then
        continue
      fi
      # pushed_at must be absent or null — otherwise this run was already
      # pushed (e.g. on a previous launcher invocation).
      if [ "$(jq -r '.pushed_at // ""' "$run_json")" != "" ]; then
        continue
      fi
      # Use mtime of run.json as the recency proxy.
      mtime="$(stat -f %m "$run_json" 2>/dev/null || stat -c %Y "$run_json" 2>/dev/null || echo 0)"
      if [ "$mtime" -gt "$LATEST_RUN_MTIME" ]; then
        LATEST_RUN_MTIME=$mtime
        LATEST_RUN_DIR="$(dirname "$run_json")"
      fi
    done
  fi

  if [ -z "$LATEST_RUN_DIR" ]; then
    # No run finished this invocation — nothing to push.
    exit 0
  fi

  # NO_VERIFY_PUSH was parsed + exported up at the top of the script
  # (before provision_machine registers its EXIT trap), so the Fly clean-
  # exit auto-finalize sees it. It's still in scope here for the local-
  # runtime path.

  # Push + PR creation are shared with the `leerie --finalize <run-id>`
  # fast-path; both source scripts/host-finalize.sh and call host_finalize.
  # shellcheck disable=SC1091
  . "$LEERIE_REPO/scripts/host-finalize.sh"
  host_finalize "$LATEST_RUN_DIR" || exit $?
fi
# Fly path: decide_teardown's EXIT trap will source host-finalize.sh and
# call host_finalize after fetch_branch. Nothing else to do here.
