#!/usr/bin/env bash
# leerie — entry point for the Leerie orchestrator.
# After install: `leerie "your task description"` from any git repo.
# Direct git-clone: `/path/to/leerie/leerie "your task description"`,
# or symlink this file onto your PATH manually.
#
# leerie runs inside a container — see docs/IMPLEMENTATION.md §0.5
# "Container shape" and docs/DESIGN.md §6. This launcher:
#   1. Resolves its own location (walking symlinks).
#   2. Fast path: `--version` answers without a container so the installer's
#      smoke test runs the moment the symlink is in place.
#   3. Per-OS preflight: verifies a working container runtime.
#   4. Builds the leerie image once per version, reuses thereafter.
#   5. Translates --inspect-dir paths into bind-mounts.
#   6. Execs nerdctl run with the full mount table, adapting TTY flags
#      ([-it] vs [-i]) to whether the launcher itself has a TTY.
set -euo pipefail

# --- resolve symlinks ----------------------------------------------------
# The curl|bash installer symlinks this script into ~/.local/bin/leerie, but
# the Dockerfile + orchestrator source live alongside the real launcher under
# $LEERIE_HOME (default ~/.leerie). readlink -f isn't portable to BSD/macOS, so
# walk by hand. (Same loop as the pre-container launcher — contract preserved.)
SRC="${BASH_SOURCE[0]}"
hops=0
while [ -L "$SRC" ]; do
  hops=$((hops + 1))
  if [ "$hops" -gt 20 ]; then
    echo "leerie: refusing to resolve symlink chain deeper than 20 hops at $SRC" >&2
    exit 1
  fi
  TARGET="$(readlink "$SRC")"
  case "$TARGET" in
    /*) SRC="$TARGET" ;;
    *)  SRC="$(cd -P "$(dirname "$SRC")" && pwd)/$TARGET" ;;
  esac
done
LEERIE_REPO="$(cd -P "$(dirname "$SRC")" && pwd)"
USER_REPO="$(pwd -P)"

# Bring remote_log into scope before any further stderr emit so every
# leerie-tagged line carries the HH:MM:SS [leerie] [<repo>] prefix.
# The line-29 emit above (symlink-loop fatal) stays bare because the
# chase that resolves LEERIE_REPO hasn't completed at that point.
# shellcheck disable=SC1091
. "$LEERIE_REPO/scripts/remote/_log.sh"

# Image tag = leerie:<version>. Version comes from plugin.json (single source of
# truth — same one `leerie --version` reads). The launcher only needs the value
# for tagging, so a minimal extractor avoids needing python/jq at this stage.
LEERIE_VERSION="$(awk -F'"' '/"version"/ {print $4; exit}' \
                  "$LEERIE_REPO/.claude-plugin/plugin.json" 2>/dev/null || echo dev)"
IMAGE_TAG="leerie:$LEERIE_VERSION"

# --- fast paths that don't need the container ----------------------------
# `leerie --version` should answer immediately without spinning up a container
# — used by the installer's end-to-end smoke test and by anyone who just
# wants to check what's installed.
#
# `--help` is NOT short-circuited: forwarding it through the container makes
# the orchestrator's argparse render the full flag list (worker model
# overrides, telemetry knobs, etc.) plus an epilog listing launcher-only
# verbs (--stop, --kill, --finalize, etc.). The first --help pays a
# one-time image-build cost; every subsequent invocation reuses the cached
# image and starts in ~2s.


# Extract the host's Claude OAuth credentials JSON for forwarding to
# a worker. Single source of truth for "where do creds live on this
# host": macOS Keychain (service "Claude Code-credentials") first;
# Linux / Keychain-miss fall back to ~/.claude/.credentials.json on
# disk; final fall back is the $CLAUDE_CODE_OAUTH_TOKEN env var, in
# which case we synthesize the minimal {claudeAiOauth.accessToken}
# JSON shape that the CLI reads on Linux (same shape seed-auth.sh
# constructs in its fallback path).
#
# Used by:
#   - the STAGE-assembly block (sources $STAGE/.claude/.credentials.json
#     for the Fly seed-auth tar pipe) — this is the active path.
#
# (The function is also called by chain-aware tests; nothing in the
# laptop-side --chain wave loop currently invokes it directly, since
# each per-job ./leerie --runtime fly invocation runs its own
# STAGE-assembly + seed-auth pipeline.)
#
# Prints the JSON to stdout. Returns 0 if creds were found, 1 otherwise.
_extract_claude_credentials_json() {
  local creds=""
  if [ "$(uname -s)" = "Darwin" ]; then
    creds="$(security find-generic-password -s "Claude Code-credentials" \
                -w 2>/dev/null || true)"
  fi
  if [ -z "$creds" ] && [ -s "$HOME/.claude/.credentials.json" ]; then
    creds="$(cat "$HOME/.claude/.credentials.json")"
  fi
  if [ -z "$creds" ] && [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    creds="$(printf '{"claudeAiOauth":{"accessToken":"%s"}}' \
                    "$CLAUDE_CODE_OAUTH_TOKEN")"
  fi
  if [ -z "$creds" ]; then
    return 1
  fi
  printf '%s' "$creds"
}

# Read stdin and emit a base64-encoded string (no newlines). Used by
# --chain to pack the queue spec and Claude creds into env-safe values
# without duplicating the same python one-liner per call site.
_b64_stdin() {
  python3 -c 'import sys, base64; sys.stdout.write(base64.b64encode(sys.stdin.buffer.read()).decode())'
}

# UUID format pattern (8-4-4-4-12 hex). Used by all chain-scoped verb
# arms (--stop / --kill / --finalize / --resume / --status / --attach
# / --chain --chain-id) to distinguish a chain_id from a single-run
# Fly machine id. Case-insensitive grep at the call sites; chain code
# normalizes to lowercase before string comparison against run.json
# fields (uuid.uuid4() emits lowercase, so the canonical form is
# lowercase). Exported so sourced hook scripts can reuse the pattern.
export UUID_PATTERN='^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'

# Read a single top-level key from a JSON file. Prints the value
# (empty string if absent/null/error). Used by --finalize to avoid
# repeating the same python3 one-liner.
_json_get() {
  local file="$1" key="$2"
  python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    v = d.get(sys.argv[2])
    print(v if v is not None else "")
except Exception:
    pass
' "$file" "$key"
}

# Idempotency probe for the --chain wave loop. Returns 0 (success) when
# every run with chain_id=<id> AND wave_idx=<idx> has pushed_at set,
# AND the count of such runs equals the expected wave size <n_expected>
# (so a wave that partially completed in a prior session does not
# pretend to be done). Returns non-zero otherwise.
#
# Reads $LEERIE_STATE_HOST_DIR/runs/*/run.json. Quiet on stdout/stderr.
_wave_already_done() {
  local chain_id="$1" wave_idx="$2" n_expected="$3"
  python3 - "$LEERIE_STATE_HOST_DIR" "$chain_id" "$wave_idx" "$n_expected" <<'PY'
import json, sys
from pathlib import Path
state_dir = Path(sys.argv[1])
chain_id = sys.argv[2]
wave_idx_target = sys.argv[3]
n_expected = int(sys.argv[4])
runs_dir = state_dir / "runs"
matched = 0
pushed = 0
for run_dir in runs_dir.iterdir() if runs_dir.is_dir() else []:
    rj = run_dir / "run.json"
    if not rj.is_file():
        continue
    try:
        data = json.loads(rj.read_text())
    except (OSError, ValueError):
        continue
    if data.get("chain_id") != chain_id:
        continue
    if str(data.get("wave_idx", "")) != wave_idx_target:
        continue
    matched += 1
    if data.get("pushed_at"):
        pushed += 1
sys.exit(0 if (matched == n_expected and pushed == n_expected) else 1)
PY
}

# Emit (one per line) every run-id in $LEERIE_STATE_HOST_DIR/runs/
# that belongs to <chain_id> AND matches the per-verb filter <verb>.
# Used by the chain-scoped verb arms (--stop, --kill, --finalize,
# --resume) to enumerate runs for per-run dispatch. The verb name
# selects a hardcoded filter inside the heredoc (no eval, no
# injection surface — only known verb names are accepted).
#
# Supported verbs:
#   stop     — runs whose machines are still actively running
#              (have fly_machine_id, no terminal state).
#   kill     — runs whose machines are not already destroyed
#              (killed_at is null) and have fly_machine_id.
#   finalize — runs whose work hasn't been pushed yet
#              (pushed_at is null, not killed).
#   resume   — paused runs (paused_at set, not killed).
_chain_runs_filter() {
  local chain_id="$1" verb="$2"
  # Bash-side verb assert (defense in depth — the Python heredoc
  # below also rejects unknown verbs via sys.exit(2), but that error
  # is invisible to the bash subshell-assignment pattern callers
  # use; this assert surfaces typos via remote_log instead of the
  # misleading "no runs found" downstream).
  case "$verb" in
    stop|kill|finalize|resume|running) ;;
    *)
      remote_log "_chain_runs_filter: unknown verb '$verb' (expected one of: stop kill finalize resume running)"
      return 2
      ;;
  esac
  python3 - "$LEERIE_STATE_HOST_DIR" "$chain_id" "$verb" <<'PY'
import json, sys
from pathlib import Path
state_dir = Path(sys.argv[1])
chain_id = sys.argv[2]
verb = sys.argv[3]


def matches(data: dict, verb: str) -> bool:
    if verb == "stop":
        # Running (has machine, no terminal state).
        return (
            not data.get("pushed_at")
            and not data.get("killed_at")
            and not data.get("paused_at")
            and bool(data.get("fly_machine_id"))
        )
    if verb == "kill":
        # Machine not already gone.
        return data.get("killed_at") is None and bool(data.get("fly_machine_id"))
    if verb == "finalize":
        # Not pushed yet, not killed.
        return not data.get("pushed_at") and not data.get("killed_at")
    if verb == "resume":
        # Paused, not killed.
        return bool(data.get("paused_at")) and not data.get("killed_at")
    if verb == "running":
        # Active (has machine + chain_id, no terminal state).
        return (
            bool(data.get("fly_machine_id"))
            and bool(data.get("chain_id"))
            and not data.get("pushed_at")
            and not data.get("paused_at")
            and not data.get("killed_at")
        )
    sys.stderr.write(f"_chain_runs_filter: unknown verb {verb!r}\n")
    sys.exit(2)


runs_dir = state_dir / "runs"
for run_dir in runs_dir.iterdir() if runs_dir.is_dir() else []:
    rj = run_dir / "run.json"
    if not rj.is_file():
        continue
    try:
        data = json.loads(rj.read_text())
    except (OSError, ValueError):
        continue
    if data.get("chain_id") != chain_id:
        continue
    if matches(data, verb):
        print(run_dir.name)
PY
}

# Emit (one per line) run-ids in the set of <state_dir> arguments whose
# run.json carries group_id=<group_id> AND matches the per-verb filter
# <verb>. Functionally identical to _chain_runs_filter but accepts a
# variable-length list of state directories instead of a single
# $LEERIE_STATE_HOST_DIR — run-groups scatter members across separate
# per-repo state dirs so a single-dir scan misses them.
#
# Signature:
#   _group_runs_filter <group_id> <verb> <state_dir_1> [<state_dir_2> ...]
_group_runs_filter() {
  local group_id="$1" verb="$2"
  shift 2
  case "$verb" in
    stop|kill|finalize|resume|running) ;;
    *)
      remote_log "_group_runs_filter: unknown verb '$verb' (expected one of: stop kill finalize resume running)"
      return 2
      ;;
  esac
  # Pass all state dirs as extra argv; Python reads sys.argv[3:].
  python3 - "$group_id" "$verb" "$@" <<'PY'
import json, sys
from pathlib import Path
group_id = sys.argv[1]
verb = sys.argv[2]
state_dirs = [Path(d) for d in sys.argv[3:]]


def matches(data: dict, verb: str) -> bool:
    if verb == "stop":
        return (
            not data.get("pushed_at")
            and not data.get("killed_at")
            and not data.get("paused_at")
            and bool(data.get("fly_machine_id"))
        )
    if verb == "kill":
        return data.get("killed_at") is None and bool(data.get("fly_machine_id"))
    if verb == "finalize":
        return not data.get("pushed_at") and not data.get("killed_at")
    if verb == "resume":
        return bool(data.get("paused_at")) and not data.get("killed_at")
    if verb == "running":
        return (
            bool(data.get("fly_machine_id"))
            and bool(data.get("group_id"))
            and not data.get("pushed_at")
            and not data.get("paused_at")
            and not data.get("killed_at")
        )
    sys.stderr.write(f"_group_runs_filter: unknown verb {verb!r}\n")
    sys.exit(2)


for state_dir in state_dirs:
    runs_dir = state_dir / "runs"
    for run_dir in runs_dir.iterdir() if runs_dir.is_dir() else []:
        rj = run_dir / "run.json"
        if not rj.is_file():
            continue
        try:
            data = json.loads(rj.read_text())
        except (OSError, ValueError):
            continue
        if data.get("group_id") != group_id:
            continue
        if matches(data, verb):
            print(run_dir.name)
PY
}

# Emit (one per line) the branch field of every run with chain_id=<id>
# AND wave_idx=<idx>. Used by the --chain wave loop to gather wave-N
# branch names for synth-merge. Works for both the just-fanned path
# and the resume path (single discovery surface).
_wave_branches() {
  local chain_id="$1" wave_idx="$2"
  python3 - "$LEERIE_STATE_HOST_DIR" "$chain_id" "$wave_idx" <<'PY'
import json, sys
from pathlib import Path
state_dir = Path(sys.argv[1])
chain_id = sys.argv[2]
wave_idx_target = sys.argv[3]
runs_dir = state_dir / "runs"
for run_dir in runs_dir.iterdir() if runs_dir.is_dir() else []:
    rj = run_dir / "run.json"
    if not rj.is_file():
        continue
    try:
        data = json.loads(rj.read_text())
    except (OSError, ValueError):
        continue
    if data.get("chain_id") != chain_id:
        continue
    if str(data.get("wave_idx", "")) != wave_idx_target:
        continue
    branch = data.get("branch") or ""
    if branch:
        print(branch)
PY
}

# Read volume_id from a run's host-side sidecar. provision.sh persists
# volume_id into both fly-machine.json and run.json. --kill consults
# this so the volume is reaped alongside the machine instead of
# orphaning.
_resolve_volume_id_from_run_dir() {
  local run_dir="$1"
  local candidate
  for candidate in "$run_dir/fly-machine.json" "$run_dir/run.json"; do
    if [ -f "$candidate" ]; then
      python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    vid = d.get("volume_id")
    print(vid if vid else "")
except Exception:
    pass
' "$candidate"
      return 0
    fi
  done
  return 0
}

# --- _ensure_run_json --------------------------------------------------
# If run_dir has fly-machine.json but no run.json, bootstrap a minimal
# run.json so subsequent `update_run_json` writes (paused_at,
# killed_at, etc.) have a file to merge into. Idempotent.
_ensure_run_json() {
  local run_dir="$1"
  local sidecar="$run_dir/run.json"
  if [ -f "$sidecar" ]; then
    return 0
  fi
  local fmj="$run_dir/fly-machine.json"
  if [ ! -f "$fmj" ]; then
    return 1
  fi
  python3 -c '
import json, sys
fmj = sys.argv[1]
sidecar = sys.argv[2]
try:
    d = json.load(open(fmj))
except Exception:
    d = {}
out = {
    "fly_machine_id": d.get("fly_machine_id"),
}
with open(sidecar, "w") as f:
    json.dump(out, f, indent=2)
    f.write("\n")
' "$fmj" "$sidecar"
}

# --- _auto_detect_fly_runtime --------------------------------------------
# When a run-id-bearing verb is invoked without an explicit --runtime and
# the run directory contains fly-machine.json, the run originated on Fly.
# Returns 0 (auto-detected) or 1 (not detected / explicit runtime given).
_auto_detect_fly_runtime() {
  local run_id="$1" explicit_runtime="$2"
  if [ -n "$explicit_runtime" ]; then return 1; fi
  if [ -z "$run_id" ]; then return 1; fi
  local sidecar="$LEERIE_STATE_HOST_DIR/runs/$run_id/fly-machine.json"
  if [ -f "$sidecar" ]; then
    return 0
  fi
  return 1
}

# --- _is_local_container --------------------------------------------------
# Returns 0 when the given run-id is a live nerdctl container on this host.
# Used by --stop/--kill to distinguish local runs from Fly runs when no
# fly-machine.json sidecar exists.
_is_local_container() {
  local run_id="$1"
  [ -n "$run_id" ] && nerdctl inspect "$run_id" >/dev/null 2>&1
}

# --- _reap_orphaned_container ---------------------------------------------
# Fix E (DESIGN §6 *container boundary's hidden precondition*). Before a
# local --resume spawns a fresh container, kill any container for this run
# that is still "Up" but whose owning launcher process is dead — the
# orphaned-orchestrator-holds-flock wedge (typically after an OOM-killed
# nerdctl client). Without this, the still-alive orphan holds the run-dir
# flock and the new orchestrator's State.__init__ loses the race and exits
# EXIT_LOCKED=75, wedging the run until a manual `nerdctl kill`.
#
# Lookup: the run-id IS the container id for local runs (DESIGN §6), so
# `nerdctl inspect <run-id>` targets it directly — no name/command parsing.
# Owner liveness: the container carries a `leerie.launcher_pid` label set at
# spawn; if that PID is gone (kill -0 fails), the container is orphaned.
# Best-effort throughout: any probe failure leaves the container untouched
# and the existing flock/EXIT_LOCKED path takes over.
_reap_orphaned_container() {
  local run_id="$1"
  [ -n "$run_id" ] || return 0
  # Only act on a container that exists AND is still running.
  local status
  status="$(nerdctl inspect -f '{{.State.Status}}' "$run_id" 2>/dev/null)" || return 0
  [ "$status" = "running" ] || return 0
  # Read the owning launcher PID from the label. Missing label (older
  # container from before this change) → treat as unknown; do NOT reap, to
  # avoid killing a genuinely live run.
  local owner_pid
  owner_pid="$(nerdctl inspect -f '{{index .Config.Labels "leerie.launcher_pid"}}' "$run_id" 2>/dev/null)"
  case "$owner_pid" in
    ''|'<no value>') return 0 ;;
    *[!0-9]*) return 0 ;;
  esac
  # If the owning launcher is still alive, this is a genuine duplicate-resume
  # attempt (another leerie is driving the run) — leave it; the orchestrator
  # flock will correctly refuse the duplicate with EXIT_LOCKED.
  if kill -0 "$owner_pid" 2>/dev/null; then
    return 0
  fi
  remote_log "--resume: reaping orphaned container for run $run_id (owning launcher pid $owner_pid is dead)"
  nerdctl kill "$run_id" >/dev/null 2>&1 || true
  # nerdctl --rm removes it on kill; give the kernel a moment to release the
  # run-dir flock before the fresh orchestrator tries to acquire it.
  sleep 1
}

# --- host-side per-repo state directory ----------------------------------
# Resolves LEERIE_STATE_HOST_DIR: the host path for this repo's leerie run
# state (runs/, worktrees/, etc.). Lives under $HOME so Colima auto-shares
# it; keyed by repo basename so the dir is browsable without a lookup table.
#
# Precedence (lowest → highest):
#   default ($HOME/.leerie/<basename>)
#   → leerie.toml `state_dir = ...`
#   → LEERIE_STATE_DIR env var
#   → --state-dir CLI flag
#
# The default key is just the repo basename. Cross-repo basename collisions
# (two different abs_paths sharing the same basename) are caught at
# _validate_state_ownership time via the .owner sidecar — see below.
#
# Resolved early (before the verb dispatch) so --stop/--kill/--finalize
# and other fast-path verbs can use it without the full launcher startup.
_state_dir_default() {
  local basename
  basename="$(python3 -c "import os,sys; print(os.path.basename(sys.argv[1].rstrip('/')))" "$USER_REPO")"
  echo "$HOME/.leerie/$basename"
}

LEERIE_STATE_HOST_DIR="$(_state_dir_default)"

# TOML override: state_dir = /some/path
if [ -f "$USER_REPO/leerie.toml" ]; then
  _toml_state_dir="$( { grep -E '^[[:space:]]*state_dir[[:space:]]*=' \
                            "$USER_REPO/leerie.toml" 2>/dev/null \
                        || true; } \
                      | head -1 \
                      | sed -E 's/^[[:space:]]*state_dir[[:space:]]*=[[:space:]]*//;
                                s/[[:space:]]*$//;
                                s/^"(.*)"$/\1/;
                                s/^'"'"'(.*)'"'"'$/\1/')"
  if [ -n "$_toml_state_dir" ]; then
    # Expand leading ~ so relative-home paths work as TOML values.
    case "$_toml_state_dir" in
      "~")   _toml_state_dir="$HOME" ;;
      "~/"*) _toml_state_dir="$HOME/${_toml_state_dir#"~/"}" ;;
    esac
    LEERIE_STATE_HOST_DIR="$_toml_state_dir"
  fi
  unset _toml_state_dir
fi

# Env override: LEERIE_STATE_DIR
if [ -n "${LEERIE_STATE_DIR:-}" ]; then
  LEERIE_STATE_HOST_DIR="$LEERIE_STATE_DIR"
fi

# CLI override: --state-dir /path or --state-dir=/path
_cli_state_dir=""
_prev_was_state_dir=false
for arg in "$@"; do
  if $_prev_was_state_dir; then
    _cli_state_dir="$arg"
    _prev_was_state_dir=false
    continue
  fi
  case "$arg" in
    --state-dir=*) _cli_state_dir="${arg#--state-dir=}" ;;
    --state-dir)   _prev_was_state_dir=true ;;
  esac
done
if [ -n "$_cli_state_dir" ]; then
  LEERIE_STATE_HOST_DIR="$_cli_state_dir"
fi
unset _cli_state_dir _prev_was_state_dir

# Expand leading ~ in the final resolved value.
case "$LEERIE_STATE_HOST_DIR" in
  "~")   LEERIE_STATE_HOST_DIR="$HOME" ;;
  "~/"*) LEERIE_STATE_HOST_DIR="$HOME/${LEERIE_STATE_HOST_DIR#"~/"}" ;;
esac

export LEERIE_STATE_HOST_DIR

# .owner sidecar: claims this state dir for USER_REPO so two different
# repos sharing a basename cannot silently write into the same tree.
# Also catches the case where the resolved path is the leerie install
# dir itself (a real risk now that the default key is just the basename
# — e.g. running leerie on /tmp/leerie would resolve to $HOME/.leerie/leerie).
#
# Called once after resolution and again from verb arms that need it
# (skipped for --version, which exits before doing any I/O on the state
# dir). On any anomaly: die() with an actionable message naming the
# --state-dir / LEERIE_STATE_DIR / leerie.toml overrides.
_validate_state_ownership() {
  local dir="$LEERIE_STATE_HOST_DIR"
  if [ ! -e "$dir" ]; then
    if ! mkdir -p "$dir"; then
      echo "leerie: could not create state dir $dir" >&2
      exit 1
    fi
    printf '%s\n' "$USER_REPO" > "$dir/.owner"
    return 0
  fi
  # A file (not a dir) at the target. Happens when the basename-only
  # default key collides with a FILE inside the installer's clone —
  # e.g. running leerie on a user repo named Dockerfile / LICENSE /
  # leerie.toml resolves to $HOME/.leerie/<basename>, which is one of
  # the installer's tracked top-level files. Catch this before the
  # write below would crash with bash's "Not a directory" error.
  if [ ! -d "$dir" ]; then
    echo "leerie: state-dir target $dir exists but is not a directory" >&2
    echo "  (probably an installer-clone file colliding with a same-named user repo)." >&2
    echo "refusing to write run state here. pick a different path with one of:" >&2
    echo "  --state-dir /some/path" >&2
    echo "  LEERIE_STATE_DIR=/some/path" >&2
    echo "  leerie.toml: state_dir = \"/some/path\"" >&2
    exit 1
  fi
  if [ -f "$dir/.owner" ]; then
    local recorded
    recorded="$(head -1 "$dir/.owner" 2>/dev/null || true)"
    if [ "$recorded" = "$USER_REPO" ]; then
      return 0
    fi
    echo "leerie: state-dir collision at $dir" >&2
    echo "  owner on file: $recorded" >&2
    echo "  current repo:  $USER_REPO" >&2
    echo "two repos share a basename. pick a different path with one of:" >&2
    echo "  --state-dir /some/path" >&2
    echo "  LEERIE_STATE_DIR=/some/path" >&2
    echo "  leerie.toml: state_dir = \"/some/path\"" >&2
    exit 1
  fi
