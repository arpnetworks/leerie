    # Usage:
    #   leerie --group \
    #     --repo <path> "<prompt>" \
    #     --repo <path> "<prompt>" \
    #     [--brief <file>] \
    #     [<per-member-flags>]
    #
    # Modeled on the --chain arm (leerie:2033) but cd's into each member
    # repo so each resolves its own USER_REPO and basename-keyed state
    # directory independently. See DESIGN.md §20 and IMPLEMENTATION.md
    # "Run-group verbs".
    shift
    _grp_repos=()       # parallel: repo paths
    _grp_prompts=()     # parallel: member prompts
    _grp_brief_file=""
    _grp_id_override=""
    _grp_passthrough=()
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --repo)
          _grp_repo="${2:-}"
          _grp_prompt="${3:-}"
          if [ -z "$_grp_repo" ] || [ -z "$_grp_prompt" ]; then
            remote_log "--group: --repo requires two arguments: <path> \"<prompt>\""; exit 1
          fi
          _grp_repos+=("$_grp_repo")
          _grp_prompts+=("$_grp_prompt")
          shift 3
          ;;
        --repo=*)
          remote_log "--group: --repo does not support = form; use: --repo <path> \"<prompt>\""; exit 1
          ;;
        --brief) _grp_brief_file="${2:-}"; shift 2 ;;
        --brief=*) _grp_brief_file="${1#--brief=}"; shift ;;
        --group-id) _grp_id_override="${2:-}"; shift 2 ;;
        --group-id=*) _grp_id_override="${1#--group-id=}"; shift ;;
        # State-dir guard (MANDATORY): --state-dir / LEERIE_STATE_DIR
        # would pin ALL members to one shared directory. Unlike chains
        # (single repo → shared dir is fine), a group needs each member
        # in its own basename-keyed state dir. Reject both forms.
        --state-dir|--state-dir=*)
          remote_log "--group: --state-dir is not supported; each member uses its own \$HOME/.leerie/<basename> directory"
          echo "  Remove --state-dir or use per-member leerie invocations." >&2
          exit 1
          ;;
        # Per-member flags forwarded to each member's ./leerie invocation.
        --*=*) _grp_passthrough+=("$1"); shift ;;
        --*)
          if [ "$#" -ge 2 ] && [ "${2#-}" = "$2" ]; then
            _grp_passthrough+=("$1" "$2"); shift 2
          else
            _grp_passthrough+=("$1"); shift
          fi
          ;;
        *) remote_log "--group: unexpected argument: $1"; exit 1 ;;
      esac
    done

    # State-dir guard: also reject LEERIE_STATE_DIR from the environment.
    if [ -n "${LEERIE_STATE_DIR:-}" ]; then
      remote_log "--group: LEERIE_STATE_DIR is set in the environment; this would pin all members to one state directory"
      echo "  Unset LEERIE_STATE_DIR before running --group, or use per-member leerie invocations." >&2
      exit 1
    fi

    if [ "${#_grp_repos[@]}" -lt 2 ]; then
      remote_log "--group: at least two --repo arguments are required"
      echo "  Usage: leerie --group --repo <path> \"<prompt>\" --repo <path> \"<prompt>\" [--brief <file>]" >&2
      exit 1
    fi

    # Validate each repo is a git repository before fan-out.
    for _gr in "${_grp_repos[@]}"; do
      if [ ! -d "$_gr" ]; then
        remote_log "--group: repo path not found: $_gr"; exit 1
      fi
      if ! git -C "$_gr" rev-parse --git-dir >/dev/null 2>&1; then
        remote_log "--group: not a git repository: $_gr"; exit 1
      fi
    done

    # Validate brief file if supplied.
    if [ -n "$_grp_brief_file" ]; then
      if [ ! -f "$_grp_brief_file" ]; then
        remote_log "--group: brief file not found: $_grp_brief_file"; exit 1
      fi
      if [ ! -s "$_grp_brief_file" ]; then
        remote_log "--group: brief file is empty: $_grp_brief_file"; exit 1
      fi
      _grp_brief_content="$(cat "$_grp_brief_file")"
    else
      _grp_brief_content=""
    fi

    # Mint or validate group_id.
    if [ -n "$_grp_id_override" ]; then
      _grp_id_stripped="$(echo "$_grp_id_override" | tr -d '[:space:]')"
      if [ "$_grp_id_stripped" != "$_grp_id_override" ]; then
        remote_log "--group: --group-id value had surrounding whitespace; stripped to '$_grp_id_stripped'"
        _grp_id_override="$_grp_id_stripped"
      fi
      unset _grp_id_stripped
      if ! echo "$_grp_id_override" | grep -qiE "$UUID_PATTERN"; then
        remote_log "--group: --group-id value '$_grp_id_override' is not a valid UUID (expected 8-4-4-4-12 hex)"
        exit 1
      fi
      _grp_id="$(echo "$_grp_id_override" | tr '[:upper:]' '[:lower:]')"
      remote_log "--group: reusing group_id $_grp_id"
    else
      _grp_id="$(python3 -c 'import uuid; print(uuid.uuid4())')"
    fi

    # Source lib.sh for update_run_json (used in tag-back below).
    _grp_leerie_dir="$(cd "$(dirname "$0")" && pwd)"
    # shellcheck disable=SC1091
    . "$_grp_leerie_dir/scripts/remote/lib.sh"

    # Signal handler: kill in-flight member children on Ctrl-C / SIGTERM.
    _grp_child_pids=()
    _grp_cleanup_done=0
    _grp_kill_children() {
      [ "$_grp_cleanup_done" -eq 1 ] && return 0
      _grp_cleanup_done=1
      for _p in "${_grp_child_pids[@]:-}"; do
        kill -TERM "$_p" 2>/dev/null || true
      done
      _grp_deadline=$(( $(date +%s) + 2 ))
      while [ "$(date +%s)" -lt "$_grp_deadline" ]; do
        _grp_remaining=()
        for _p in "${_grp_child_pids[@]:-}"; do
          kill -0 "$_p" 2>/dev/null && _grp_remaining+=("$_p")
        done
        _grp_child_pids=("${_grp_remaining[@]}")
        [ "${#_grp_child_pids[@]}" -eq 0 ] && break
        sleep 0.1
      done
      for _p in "${_grp_child_pids[@]:-}"; do
        kill -KILL "$_p" 2>/dev/null || true
      done
      wait 2>/dev/null || true
    }
    trap '_grp_kill_children; exit 130' INT
    trap '_grp_kill_children; exit 143' TERM

    echo ""
    echo "group submitted:"
    echo "  group_id: $_grp_id"
    echo "  members:  ${#_grp_repos[@]}"
    echo ""
    echo "  Recovery (if a member pauses on failure):"
    echo "    leerie --resume $_grp_id"
    echo "    leerie --group --group-id $_grp_id --repo ..."
    echo ""

    # Fan-out: background one ./leerie per member.
    # Each member cd's into its repo (so USER_REPO + state dir resolve
    # from basename), carries --group-id, and has all siblings as
    # --inspect-dir (read-only cross-repo visibility).
    _grp_n="${#_grp_repos[@]}"
    for _gi in $(seq 0 $((_grp_n - 1))); do
      _grp_member_repo="${_grp_repos[$_gi]}"
      _grp_member_prompt="${_grp_prompts[$_gi]}"

      # Resolve absolute path for inspect-dir (collect_inspect_path
      # needs absolute paths; the member's cwd will be the member repo,
      # but siblings are given as absolute paths).
      _grp_member_repo_abs="$(cd "$_grp_member_repo" && pwd)"

      # Build --inspect-dir flags for every OTHER member (siblings).
      _grp_inspect_args=()
      for _gj in $(seq 0 $((_grp_n - 1))); do
        [ "$_gj" -eq "$_gi" ] && continue
        _grp_sibling_abs="$(cd "${_grp_repos[$_gj]}" && pwd)"
        _grp_inspect_args+=(--inspect-dir "$_grp_sibling_abs")
      done

      # Prepend brief to prompt if provided.
      if [ -n "$_grp_brief_content" ]; then
        _grp_full_prompt="${_grp_brief_content}

${_grp_member_prompt}"
      else
        _grp_full_prompt="$_grp_member_prompt"
      fi

      (
        cd "$_grp_member_repo_abs" || exit 1
        "${LEERIE_SELF_CMD:-"$0"}" "$_grp_full_prompt" \
          "${_grp_inspect_args[@]}" \
          --group-id "$_grp_id" \
          "${_grp_passthrough[@]}"
      ) &
      _grp_child_pids+=($!)
    done

    # Wait for ALL members, capture per-child rc.
    _grp_failed=0
    for _p in "${_grp_child_pids[@]}"; do
      if ! wait "$_p"; then
        _grp_failed=$((_grp_failed + 1))
      fi
    done

    # Clear signal trap; fan-out complete.
    trap - INT TERM

    # Group tag-back: write group_id into each member's run.json.
    # Discovery: scan <member-state-dir>/runs/*/run.json for the newest
    # run.json with finished_at set — same mechanism as the local
    # finalize discovery (leerie:4967-4992). The member's state dir is
    # derived from its repo basename (same as _state_dir_default does
    # for USER_REPO).
    for _gi in $(seq 0 $((_grp_n - 1))); do
      _grp_member_repo="${_grp_repos[$_gi]}"
      _grp_member_basename="$(python3 -c "import os,sys; print(os.path.basename(sys.argv[1].rstrip('/')))" "$_grp_member_repo")"
      _grp_member_state_dir="$HOME/.leerie/$_grp_member_basename"

      # Discover the member's run.json: newest run dir with finished_at.
      _grp_run_json="$(python3 - "$_grp_member_state_dir" <<'PY'
import json, os, sys
from pathlib import Path
state_dir = Path(sys.argv[1])
runs_dir = state_dir / "runs"
best_mtime = 0
best_path = ""
for rj in runs_dir.glob("*/run.json") if runs_dir.is_dir() else []:
    try:
        data = json.loads(rj.read_text())
    except (OSError, ValueError):
        continue
    if not data.get("finished_at"):
        continue
    mtime = rj.stat().st_mtime
    if mtime > best_mtime:
        best_mtime = mtime
        best_path = str(rj)
print(best_path)
PY
)"
      if [ -z "$_grp_run_json" ] || [ ! -f "$_grp_run_json" ]; then
        # Fly runtime: try remote/<child-pid>.json pointer, then
        # fly-machine.json scan — same as chain tag-back (leerie:2263-2289).
        _grp_cp="${_grp_child_pids[$_gi]}"
        _grp_remote_ptr="$_grp_member_state_dir/remote/$_grp_cp.json"
        _grp_mid=""
        if [ -f "$_grp_remote_ptr" ]; then
          _grp_mid="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("fly_machine_id",""))' "$_grp_remote_ptr" 2>/dev/null)"
        fi
        if [ -z "$_grp_mid" ]; then
          _grp_mid="$(python3 -c '
import json, sys
from pathlib import Path
state_dir, pid = Path(sys.argv[1]), int(sys.argv[2])
for fmj in (state_dir / "runs").glob("*/fly-machine.json"):
    try:
        d = json.loads(fmj.read_text())
    except (OSError, ValueError):
        continue
    if d.get("launcher_pid") == pid:
        print(fmj.parent.name)
        break
' "$_grp_member_state_dir" "$_grp_cp" 2>/dev/null)"
        fi
        if [ -n "$_grp_mid" ]; then
          _grp_run_json="$_grp_member_state_dir/runs/$_grp_mid/run.json"
        fi
      fi

      if [ -n "$_grp_run_json" ] && [ -f "$_grp_run_json" ]; then
        update_run_json "$_grp_run_json" group_id "$_grp_id" || true
      else
        remote_log "--group: could not locate run.json for member $_grp_member_repo (tag-back skipped)"
      fi
    done

    if [ "$_grp_failed" -gt 0 ]; then
      remote_log "group $_grp_id: $_grp_failed/${_grp_n} member(s) failed"
      echo ""
      echo "Some group members paused on failure. To recover:"
      echo "  leerie --resume $_grp_id"
      exit 1
    fi

    echo ""
    remote_log "group $_grp_id: all ${_grp_n} member(s) complete"
    echo "  Inspect: leerie --status $_grp_id  |  leerie --list --groups"
    exit 0
    ;;
esac

# --- platform preflight --------------------------------------------------
OS="$(uname -s)"

print_install_hint() {
  case "$OS" in
    Darwin)
      if ! command -v brew >/dev/null 2>&1; then
        cat >&2 <<'EOF'

You need Homebrew first (leerie uses brew to install Colima):
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

Or see https://brew.sh/ for alternatives.

After installing Homebrew, re-run leerie — it will auto-install Colima.
EOF
      else
        cat >&2 <<'EOF'

Install on macOS:
  brew install colima
  colima start --runtime containerd --mount-type virtiofs
  # nerdctl shim is auto-installed by leerie on first run; or manually:
  #   colima nerdctl install

(brew install nerdctl does NOT work on macOS — the nerdctl binary requires
a Linux kernel. Colima ships nerdctl inside its VM and installs a host-side
shim that proxies to it.)

See docs/INSTALL.md for details.
EOF
      fi
      ;;
    Linux)
      cat >&2 <<'EOF'

Install on Linux:
  # Debian/Ubuntu:
  sudo apt-get install -y containerd
  # then install nerdctl from upstream:
  #   https://github.com/containerd/nerdctl/releases
  # Or distro packages where available (Arch: pacman -S nerdctl).
  sudo systemctl enable --now containerd

See docs/INSTALL.md for rootless mode and other distros.
EOF
      ;;
    *)
      remote_log "unsupported OS: $OS (need macOS or Linux)"
      ;;
  esac
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    remote_log "missing required command: $1"
    print_install_hint
    exit 1
  }
}

# --- runtime auto-install opt-out --------------------------------------
# Same flag/env shape as scripts/install.sh: --no-runtime-install on the
# CLI or LEERIE_NO_RUNTIME_INSTALL=1 in the env disables auto-install. We
# don't shift the flag off $@ — the orchestrator's argparse rejects
# unknown flags, so we just consume it before the orchestrator sees it
# (in the REWRITTEN_ARGS pass-through below).
case "${LEERIE_NO_RUNTIME_INSTALL:-}" in
  1|true|TRUE|yes|YES) NO_RUNTIME_INSTALL=true ;;
  *)                   NO_RUNTIME_INSTALL=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--no-runtime-install" ]; then
    NO_RUNTIME_INSTALL=true
  fi
done

# --- remote image auto-publish opt-out ---------------------------------
# Same shape: --no-auto-publish on the CLI or LEERIE_NO_AUTO_PUBLISH=1 in the
# env disables ensure_image() for the remote (Fly) path. The orchestrator
# never sees this flag — it's consumed in REWRITTEN_ARGS below.
case "${LEERIE_NO_AUTO_PUBLISH:-}" in
  1|true|TRUE|yes|YES) NO_AUTO_PUBLISH=true ;;
  *)                   NO_AUTO_PUBLISH=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--no-auto-publish" ]; then
    NO_AUTO_PUBLISH=true
  fi
done

# --- local-build opt-in (most users should leave this off) ---------------
# Default: ensure_image() invokes build-push.sh in its remote-builder mode
# (Fly's infra builds + pushes; no host Docker daemon required).
# --local-build on the CLI or LEERIE_LOCAL_BUILD=1 in the env forces the
# legacy local-build path (nerdctl/docker build + push). The local path
# only works on hosts with a working Docker daemon authenticated to
# registry.fly.io (Docker Desktop + `flyctl auth docker`, OR Linux with
# apt-installed Docker). It does NOT work with nerdctl-in-Colima on macOS
# because nerdctl cannot reach macOS Keychain (where Docker Desktop's
# `credsStore: desktop` helper stores the registry credential).
# The orchestrator never sees this flag — consumed by REWRITTEN_ARGS below.
case "${LEERIE_LOCAL_BUILD:-}" in
  1|true|TRUE|yes|YES) LOCAL_BUILD=true ;;
  *)                   LOCAL_BUILD=false ;;
esac
for arg in "$@"; do
  if [ "$arg" = "--local-build" ]; then
    LOCAL_BUILD=true
  fi
done

# --- auto re-seed on --resume (Phase 4) --------------------------------
# Default behaviour: when resuming a paused remote run, automatically
# re-rsync the host's dirty set before re-exec'ing the orchestrator.
# --no-re-seed opts out (rate-limit auto-resume case where nothing changed).
# --force bypasses the safety check that refuses to clobber machine-side
# uncommitted edits.
NO_RE_SEED=false
RE_SEED_FORCE=false
for arg in "$@"; do
  case "$arg" in
    --no-re-seed) NO_RE_SEED=true ;;
    --force)      RE_SEED_FORCE=true ;;
  esac
done

# --- --resume smart-router sub-mode flags -------------------------------
# Launcher-only flags consumed by the rc=75 pivot (DESIGN §6 *Smart
# resume in remote mode*). Both are stripped from REWRITTEN_ARGS below
# so the orchestrator's argparse never sees them.
#   --shell           drop into bash at /work instead of tailing the log
#   --auto-finalize   exec `leerie --finalize` on clean orchestrator exit
RESUME_SHELL=false
RESUME_AUTO_FINALIZE=false
for arg in "$@"; do
  case "$arg" in
    --shell)         RESUME_SHELL=true ;;
    --auto-finalize) RESUME_AUTO_FINALIZE=true ;;
  esac
done
export RESUME_SHELL
export RESUME_AUTO_FINALIZE

# --- extract --run-id (passed through to orchestrator) -----------------
# The launcher needs the run-id early in the RUNTIME=fly branch so the
# remote provision step can write fly_machine_id to the sidecar
# (DESIGN §6 Remote pause-on-failure). We don't shift the arg off $@ —
# it's still forwarded via REWRITTEN_ARGS to the orchestrator's argparse.
LEERIE_RUN_ID=""
IS_RESUME=false
_prev=""
for arg in "$@"; do
  if [ "$_prev" = "--run-id" ]; then
    LEERIE_RUN_ID="$arg"
  fi
  # Positional run-id: `--resume <id>` (mirrors --stop / --kill convention).
  # Only capture when the token doesn't start with `--` (not a flag).
  if [ "$_prev" = "--resume" ] && [ -n "$arg" ] && [ "${arg#--}" = "$arg" ]; then
    LEERIE_RUN_ID="$arg"
  fi
  case "$arg" in
    --run-id=*) LEERIE_RUN_ID="${arg#--run-id=}" ;;
    --resume)   IS_RESUME=true ;;
  esac
  _prev="$arg"
done
export LEERIE_RUN_ID
export IS_RESUME

# --- extract the task positional (for pre-classify resume) ----------------
# The orchestrator's argparse takes a single optional positional `task`.
# On a remote-mode pre-classify resume, the in-machine orchestrator has
# no state.json (classify never ran) and needs the task argument. The
# user's original `leerie "<task>"` is gone from the resume invocation's
# argv, so we persist it at first-launch (a few sections down) and read
# it back here on subsequent resumes. This block only extracts what the
# user typed THIS time.
#
# Walk $@ skipping flag values for any --flag that takes one. The
# orchestrator's --model-<W> and --effort-<W> per-worker overrides
# also take values; cover them with a prefix match.
LEERIE_TASK_ARG=""
_prev=""
_value_flags=" --run-id --answers --pr-template --max-workers \
--max-parallel --confidence-rounds --planner-samples --worker-memory-max \
--source-of-truth --runtime --inspect-dir --model --effort \
--judge-model --heal-model --pr-writer-model --heal-max-rounds \
--heal-success-threshold --verbosity --telemetry-dir --judge-dir \
--heal-dir --phase --host-no-push --status --chain-id \
--seed-depth --seed-shallow-threshold-mb --group-id "
for arg in "$@"; do
  # Skip if this arg is the value of a previous value-taking flag.
  if [ -n "$_prev" ]; then
    case "$_value_flags" in
      *" $_prev "*) _prev=""; continue ;;
    esac
    case "$_prev" in
      --model-*|--effort-*) _prev=""; continue ;;
    esac
  fi
  # Skip positional run-id after --resume (not the task).
  if [ "$_prev" = "--resume" ] && [ "${arg#--}" = "$arg" ]; then
    _prev=""; continue
  fi
  # Skip any --flag (with or without =value).
  case "$arg" in
    --*) _prev="$arg"; continue ;;
  esac
  # First non-flag, non-value positional is the task.
  if [ -z "$LEERIE_TASK_ARG" ]; then
    LEERIE_TASK_ARG="$arg"
  fi
  _prev=""
done
export LEERIE_TASK_ARG

# --- fail fast on missing task file ---------------------------------------
# Matches the eager validation --chain already does for prompt files (l.1722).
case "$LEERIE_TASK_ARG" in
  *.txt|*.md|*.TXT|*.MD)
    if [ -n "$LEERIE_TASK_ARG" ] && [ ! -f "$LEERIE_TASK_ARG" ]; then
      remote_log "task file not found: $LEERIE_TASK_ARG"
      exit 1
    fi
    ;;
esac

# --- runtime-mode knob ---------------------------------------------------
# Resolves RUNTIME=local|fly. Precedence: CLI --runtime > LEERIE_RUNTIME env
# > leerie.toml `runtime` key > default `local`. Mirrors the orchestrator's
# resolve_runtime() (leerie.py) so the launcher routes correctly before the
# container starts. --runtime is NOT consumed — it flows through
# REWRITTEN_ARGS to the orchestrator's own argparse.
RUNTIME=local
_RUNTIME_EXPLICIT=false
# Precedence (lowest → highest): default → toml → env → CLI.
# TOML is resolved first so env overrides it.
if [ -f "$USER_REPO/leerie.toml" ]; then
  toml_runtime="$(awk '/^[[:space:]]*runtime[[:space:]]*=/ {
                         gsub(/^[[:space:]]*runtime[[:space:]]*=[[:space:]]*/, "", $0);
                         gsub(/^"|"$/, "", $0);
                         print; exit
                       }' "$USER_REPO/leerie.toml" 2>/dev/null || true)"
  case "${toml_runtime:-}" in
    local|fly) RUNTIME="${toml_runtime}"; _RUNTIME_EXPLICIT=true ;;
    "")        : ;;
    *)
      remote_log "leerie.toml: runtime=${toml_runtime} is not one of local|fly"
      exit 1
      ;;
  esac
fi
case "${LEERIE_RUNTIME:-}" in
  local|fly) RUNTIME="${LEERIE_RUNTIME}"; _RUNTIME_EXPLICIT=true ;;
  "")        : ;;
  *)
    remote_log "LEERIE_RUNTIME=${LEERIE_RUNTIME} is not one of local|fly"
    exit 1
    ;;
esac
# CLI (highest priority) — scanned before REWRITTEN_ARGS loop below.
for arg in "$@"; do
  case "$arg" in
    --runtime=local)    RUNTIME=local; _RUNTIME_EXPLICIT=true ;;
    --runtime=fly)      RUNTIME=fly; _RUNTIME_EXPLICIT=true ;;
    --runtime=*)
      remote_log "--runtime=${arg#--runtime=} is not one of local|fly"
      exit 1
      ;;
  esac
done
# Handle the two-argument form --runtime VALUE.
prev_was_runtime=false
for arg in "$@"; do
  if $prev_was_runtime; then
    case "$arg" in
      local|fly) RUNTIME="$arg"; _RUNTIME_EXPLICIT=true ;;
      *)
        remote_log "--runtime $arg is not one of local|fly"
        exit 1
        ;;
    esac
    prev_was_runtime=false
    continue
  fi
  if [ "$arg" = "--runtime" ]; then
    prev_was_runtime=true
  fi
done

# --- auto-detect Fly runtime on --resume ---------------------------------
# Uses the shared _auto_detect_fly_runtime helper. The --resume path
# differs from the fast-path verbs: it sets REWRITTEN_ARGS (forwarded to
# the orchestrator) and uses _RUNTIME_EXPLICIT to distinguish default
# from user-set.
if [ "$IS_RESUME" = "true" ] && [ "$RUNTIME" = "local" ] && \
   [ "$_RUNTIME_EXPLICIT" = "false" ]; then
  if _auto_detect_fly_runtime "$LEERIE_RUN_ID" ""; then
    remote_log "--resume: auto-detected Fly run (fly-machine.json present); promoting --runtime to fly"
    RUNTIME=fly
    REWRITTEN_ARGS+=("--runtime" "fly")
  fi
fi
# When the user explicitly set --runtime local on a Fly-originated run,
# warn but respect their choice.
if [ "$IS_RESUME" = "true" ] && [ "$RUNTIME" = "local" ] && \
   [ "$_RUNTIME_EXPLICIT" = "true" ] && [ -n "$LEERIE_RUN_ID" ]; then
  _fly_sidecar="$LEERIE_STATE_HOST_DIR/runs/$LEERIE_RUN_ID/fly-machine.json"
  if [ -f "$_fly_sidecar" ]; then
    remote_log "warning: resuming a Fly run with --runtime local — host-side state.json may be incomplete"
    echo "  Consider: leerie --resume $LEERIE_RUN_ID --runtime fly" >&2
  fi
fi

# Fix E: reap an orphaned still-Up container from a dead launcher before we
# spawn a fresh one on the local resume path, so --resume self-heals the
# OOM-orphan flock wedge instead of exiting EXIT_LOCKED=75. Runs only for
# genuine local resumes (after Fly auto-detection above may have flipped
# RUNTIME to fly).
if [ "$IS_RESUME" = "true" ] && [ "$RUNTIME" = "local" ] && [ -n "$LEERIE_RUN_ID" ]; then
  _reap_orphaned_container "$LEERIE_RUN_ID"
fi

# --- LEERIE_FLY_APP (Fly.io app name) ------------------------------------
# Fly.io app names are globally unique — the hardcoded default "leerie" is
# already taken, so every user must set their own. Resolution:
#   1. --fly-app NAME / --fly-app=NAME on the CLI
#   2. $LEERIE_FLY_APP already set in the env
# When RUNTIME=fly and no value is set, die with a clear message.
_cli_fly_app=""
for arg in "$@"; do
  case "$arg" in
    --fly-app=*) _cli_fly_app="${arg#--fly-app=}" ;;
  esac
done
# Handle two-argument form: --fly-app NAME
_prev_was_fly_app=false
for arg in "$@"; do
  if [ "$_prev_was_fly_app" = "true" ]; then
    _cli_fly_app="$arg"
    _prev_was_fly_app=false
    continue
  fi
  if [ "$arg" = "--fly-app" ]; then
    _prev_was_fly_app=true
  fi
done
if [ -n "$_cli_fly_app" ]; then
  LEERIE_FLY_APP="$_cli_fly_app"
  export LEERIE_FLY_APP
fi
unset _cli_fly_app _prev_was_fly_app
if [ "$RUNTIME" = "fly" ] && [ -z "${LEERIE_FLY_APP:-}" ]; then
  remote_log "LEERIE_FLY_APP is required when --runtime fly."
  echo "  Fly.io app names are globally unique. Set your app name:" >&2
  echo "    export LEERIE_FLY_APP=my-leerie-app" >&2
  echo "    # or: ./leerie \"task\" --fly-app my-leerie-app" >&2
  echo "  Create the app first if needed: flyctl apps create my-leerie-app" >&2
  exit 1
fi

# --- FLY_VM_DISK_GB (per-machine Fly volume size in GB) -------------------
# Resolution ladder (highest → lowest):
#   1. --fly-disk-gb N / --fly-disk-gb=N on the CLI
#   2. $FLY_VM_DISK_GB already set in the env
#   3. fly_disk_gb = N in leerie.toml
#   4. default: 8 GB when RUNTIME=fly, unset when RUNTIME=local
#
# When set, provision.sh creates a per-machine Fly volume sized at N GB,
# mounts it at /home/leerie, persists the volume_id into run.json, and
# destroys the volume when the machine is destroyed.
# (DESIGN §6 *Remote disk policy*; IMPLEMENTATION §2.)
_cli_fly_disk_gb=""
_prev_was_fly_disk=false
for arg in "$@"; do
  if $_prev_was_fly_disk; then
    _cli_fly_disk_gb="$arg"
    _prev_was_fly_disk=false
    continue
  fi
  case "$arg" in
    --fly-disk-gb=*) _cli_fly_disk_gb="${arg#--fly-disk-gb=}" ;;
    --fly-disk-gb)   _prev_was_fly_disk=true ;;
  esac
done
if [ -n "$_cli_fly_disk_gb" ]; then
  FLY_VM_DISK_GB="$_cli_fly_disk_gb"
elif [ -z "${FLY_VM_DISK_GB:-}" ] && [ -f "$USER_REPO/leerie.toml" ]; then
  # Same flat-key grep pattern as the no_push read below (line ~1002),
  # mirroring orchestrator/leerie.py:_read_toml_key.
  _toml_fly_disk_gb="$( { grep -E '^[[:space:]]*fly_disk_gb[[:space:]]*=' \
                              "$USER_REPO/leerie.toml" 2>/dev/null \
                            | head -1 \
                            | sed -E 's/^[[:space:]]*fly_disk_gb[[:space:]]*=[[:space:]]*//; s/[[:space:]]*$//; s/^"//; s/"$//' ; } || true)"
  if [ -n "$_toml_fly_disk_gb" ]; then
    FLY_VM_DISK_GB="$_toml_fly_disk_gb"
  fi
  unset _toml_fly_disk_gb
fi
unset _cli_fly_disk_gb _prev_was_fly_disk
# Validate: must be a positive integer when set. provision.sh would otherwise
# pass garbage to `flyctl volumes create --size` and the failure mode would
# be a confusing flyctl error.
if [ -n "${FLY_VM_DISK_GB:-}" ]; then
  case "$FLY_VM_DISK_GB" in
    ''|*[!0-9]*)
      remote_log "FLY_VM_DISK_GB='$FLY_VM_DISK_GB' is not a positive integer (GB)"
      exit 1
      ;;
    0)
      remote_log "FLY_VM_DISK_GB=0 is invalid; minimum is 1 (GB)"
      exit 1
      ;;
  esac
  export FLY_VM_DISK_GB
fi
# Default to 8 GB when running on Fly and no explicit value was given.
if [ "$RUNTIME" = "fly" ] && [ -z "${FLY_VM_DISK_GB:-}" ]; then
  FLY_VM_DISK_GB=8
  export FLY_VM_DISK_GB
fi

# --- Shallow-seed knobs (DESIGN §6 *Shallow seeding for heavy repos*) --------
# Two operator knobs consumed by scripts/remote/seed-repo.sh on fresh remote
# provisions. Resolution mirrors FLY_VM_DISK_GB above: CLI flag > env var >
# leerie.toml flat key > default. Both are bash-only (the Python orchestrator
# never reads them, unlike confidence_rounds).
#
#   LEERIE_SEED_DEPTH:  git clone --depth for the shallow path. Default 50.
#                       0 = full history (disables shallow seeding entirely).
#   LEERIE_SEED_SHALLOW_THRESHOLD_MB:  activate shallow only when the repo's
#                       .git exceeds this many MB. Default 200.
#
# _resolve_seed_knob <cli-value> <env-var-name> <toml-key> <default> — prints
# the resolved value. CLI wins; else env if set; else leerie.toml flat key;
# else default. Same flat-key grep/sed as the FLY_VM_DISK_GB read above.
_resolve_seed_knob() {
  local _cli="$1" _envname="$2" _tomlkey="$3" _default="$4" _envval _tomlval
  if [ -n "$_cli" ]; then printf '%s' "$_cli"; return; fi
  eval "_envval=\"\${$_envname:-}\""
  if [ -n "$_envval" ]; then printf '%s' "$_envval"; return; fi
  if [ -f "$USER_REPO/leerie.toml" ]; then
    _tomlval="$( { grep -E "^[[:space:]]*${_tomlkey}[[:space:]]*=" \
                        "$USER_REPO/leerie.toml" 2>/dev/null \
                      | head -1 \
                      | sed -E "s/^[[:space:]]*${_tomlkey}[[:space:]]*=[[:space:]]*//; s/[[:space:]]*\$//; s/^\"//; s/\"\$//" ; } || true)"
    if [ -n "$_tomlval" ]; then printf '%s' "$_tomlval"; return; fi
  fi
  printf '%s' "$_default"
}
_cli_seed_depth=""
_cli_seed_threshold=""
_prev_seed_arg=""
for arg in "$@"; do
  if [ -n "$_prev_seed_arg" ]; then
    case "$_prev_seed_arg" in
      depth)     _cli_seed_depth="$arg" ;;
      threshold) _cli_seed_threshold="$arg" ;;
    esac
    _prev_seed_arg=""
    continue
  fi
  case "$arg" in
    --seed-depth=*)                  _cli_seed_depth="${arg#--seed-depth=}" ;;
    --seed-depth)                    _prev_seed_arg="depth" ;;
    --seed-shallow-threshold-mb=*)   _cli_seed_threshold="${arg#--seed-shallow-threshold-mb=}" ;;
    --seed-shallow-threshold-mb)     _prev_seed_arg="threshold" ;;
  esac
done
LEERIE_SEED_DEPTH="$(_resolve_seed_knob "$_cli_seed_depth" LEERIE_SEED_DEPTH seed_depth 50)"
LEERIE_SEED_SHALLOW_THRESHOLD_MB="$(_resolve_seed_knob "$_cli_seed_threshold" LEERIE_SEED_SHALLOW_THRESHOLD_MB seed_shallow_threshold_mb 200)"
unset _cli_seed_depth _cli_seed_threshold _prev_seed_arg
# Validate. Depth: non-negative integer (0 = full/disable). Threshold: positive
# integer. Reject garbage at startup rather than letting seed-repo.sh mishandle it.
case "$LEERIE_SEED_DEPTH" in
  ''|*[!0-9]*)
    remote_log "LEERIE_SEED_DEPTH='$LEERIE_SEED_DEPTH' is not a non-negative integer (0 = full history)"
    exit 1
    ;;
esac
case "$LEERIE_SEED_SHALLOW_THRESHOLD_MB" in
  ''|*[!0-9]*|0)
    remote_log "LEERIE_SEED_SHALLOW_THRESHOLD_MB='$LEERIE_SEED_SHALLOW_THRESHOLD_MB' is not a positive integer (MB)"
    exit 1
    ;;
esac
export LEERIE_SEED_DEPTH LEERIE_SEED_SHALLOW_THRESHOLD_MB

# DRY_RUN is referenced by scripts/runtime-install.sh; default to false
# in the launcher (the launcher has no --dry-run flag — that's install.sh).
DRY_RUN=false

# Source the shared runtime-install helpers. LEERIE_REPO points at the
# leerie install directory (where scripts/ lives) — already resolved at
# the top of this script via the symlink walk.
if [ -f "$LEERIE_REPO/scripts/runtime-install.sh" ]; then
  # shellcheck disable=SC1091
  . "$LEERIE_REPO/scripts/runtime-install.sh"
fi

# Colima/containerd preflight is only needed for local nerdctl invocations.
# Skip entirely when RUNTIME=fly (or any future non-local runtime).
if [ "$RUNTIME" = "local" ]; then
case "$OS" in
  Darwin)
    # Auto-install Colima if missing, with a TTY guard. The brew install
    # step may prompt for sudo; in plugin mode (no TTY) the prompt would
    # hang. Mirror the pattern at line ~135 (nerdctl-shim install).
    if ! command -v colima >/dev/null 2>&1; then
      if [ "$NO_RUNTIME_INSTALL" = "true" ]; then
        remote_log "Colima is missing (auto-install skipped via --no-runtime-install)."
        print_install_hint
        exit 1
      fi
      if [ -t 0 ]; then
        remote_log "Colima is missing — installing now (one-time; may prompt for sudo)..."
        if ! runtime_install_macos; then
          print_install_hint
          exit 1
        fi
      else
        remote_log "Colima is not installed and we have no terminal to"
        echo "  prompt for sudo / brew install. Run leerie once from a" >&2
        echo "  terminal so the one-time install can complete:" >&2
        echo "    leerie --version" >&2
        echo "  Or install Colima manually:" >&2
        echo "    brew install colima" >&2
        exit 1
      fi
    fi
    # Don't auto-start Colima — if the user has an existing setup with
    # dockerd we'd clobber their preference. Give a clear hint instead.
    if ! colima status >/dev/null 2>&1; then
      remote_log "Colima VM is not running."
      echo "  Start it with:  colima start --runtime containerd --mount-type virtiofs" >&2
      exit 1
    fi
    # nerdctl reaches containerd via Colima's host-side shim
    # (`colima nerdctl install`). The install writes to /usr/local/bin
    # (root-owned on macOS) via `sudo`, which prompts interactively. In
    # plugin mode (no TTY) the sudo prompt blocks forever; detect and bail
    # with a clear hint instead of hanging.
    if ! command -v nerdctl >/dev/null 2>&1; then
      if [ -t 0 ]; then
        remote_log "installing host-side nerdctl shim (one-time; may prompt for sudo)..."
        if ! colima nerdctl install >&2; then
          remote_log "failed to install nerdctl shim — run 'colima nerdctl install' manually"
          exit 1
        fi
      else
        remote_log "nerdctl shim is not installed and we have no terminal to run sudo."
        echo "  Run this once from a terminal, then re-invoke /leerie:" >&2
        echo "    colima nerdctl install" >&2
        exit 1
      fi
    fi
    if ! nerdctl info >/dev/null 2>&1; then
      remote_log "nerdctl cannot reach the container runtime."
      echo "  Ensure Colima was started with --runtime containerd:" >&2
      echo "    colima stop && colima start --runtime containerd --mount-type virtiofs" >&2
      exit 1
    fi
    # Colima auto-shares only paths under /Users/$USER by default. If any
    # bind mount we're about to make falls outside, the mount silently
    # appears empty inside the container. Warn early.
    USER_HOME_PREFIX="/Users/$(id -un)"
    check_under_home() {
      case "$1" in
        "$USER_HOME_PREFIX"|"$USER_HOME_PREFIX"/*) return 0 ;;
        *)
          remote_log "warning — '$1' is outside $USER_HOME_PREFIX"
          echo "  and may appear empty in the container. Add it to Colima's" >&2
          echo "  mount list: edit ~/.colima/default/colima.yaml's 'mounts:'" >&2
          echo "  section, then 'colima restart'." >&2
          return 1
          ;;
      esac
    }
    check_under_home "$USER_REPO" || true
    check_under_home "$LEERIE_REPO" || true
    ;;
  Linux)
    # Auto-install nerdctl + containerd if missing, with a TTY guard.
    # `sudo apt-get install` etc. would hang in plugin mode without TTY.
    if ! command -v nerdctl >/dev/null 2>&1; then
      if [ "$NO_RUNTIME_INSTALL" = "true" ]; then
        remote_log "nerdctl is missing (auto-install skipped via --no-runtime-install)."
        print_install_hint
        exit 1
      fi
      if [ -t 0 ]; then
        remote_log "nerdctl is missing — installing containerd + nerdctl (one-time; may prompt for sudo)..."
        if ! runtime_install_linux; then
          print_install_hint
          exit 1
        fi
      else
        remote_log "nerdctl is not installed and we have no terminal to"
        echo "  prompt for sudo. Run leerie once from a terminal so the" >&2
        echo "  one-time install can complete:" >&2
        echo "    leerie --version" >&2
        exit 1
      fi
    fi
    if ! nerdctl info >/dev/null 2>&1; then
      remote_log "nerdctl cannot reach containerd."
      echo "  Ensure containerd is running:  systemctl status containerd" >&2
      echo "  For rootless mode see docs/INSTALL.md." >&2
      exit 1
    fi
    ;;
  *)
    remote_log "unsupported OS: $OS"
    print_install_hint
    exit 1
    ;;
esac
fi  # end RUNTIME=local preflight

# --- host preflight: git repo + gh + jq ---------------------------------
# These checks moved out of the orchestrator (DESIGN §6 *Finalization*).
# The launcher does the host-side push + PR after the container exits,
# so the auth state needs to be valid on the host BEFORE we spin up the
# container. Fast-fail with actionable messages.
#
# `--no-push` shortcuts the gh + origin checks (the launcher will skip
# the host-side finalize entirely). The flag is also passed through to
# the orchestrator so phase_finalize knows not to do its own bookkeeping.
NO_PUSH=false
for arg in "$@"; do
  case "$arg" in
    --no-push) NO_PUSH=true ;;
  esac
done
case "${LEERIE_NO_PUSH:-}" in
  1|true|TRUE|yes|YES) NO_PUSH=true ;;
esac
# Match the orchestrator's resolve_no_push order: CLI → env → leerie.toml.
# The launcher and the in-Fly orchestrator are now both authoritative
# consumers of this intent — the launcher seeds fly-machine.json.
# host_no_push and the --host-no-push argv flag, the orchestrator gates
# pr_writer and writes run.json.no_push. Disagreement on a TOML-only
# opt-out would make the Fly auto-finalize path push against user
# intent. Pattern mirrors orchestrator/leerie.py:2279 `_read_toml_key`
# (flat `key = value` grep) — keeps the launcher free of a tomllib
# dependency that would force a host-side Python 3.11+ bump.
if [ "$NO_PUSH" = "false" ] && [ -f "$USER_REPO/leerie.toml" ]; then
  # `|| true` swallows grep's exit 1 when the key is absent (set -e
  # would otherwise abort the whole launcher). Sed normalizes the
  # value: strip surrounding whitespace and matched double or single
  # quotes, mirroring orchestrator/leerie.py:_read_toml_key.
  _toml_no_push="$( { grep -E '^[[:space:]]*no_push[[:space:]]*=' \
                          "$USER_REPO/leerie.toml" 2>/dev/null \
                      || true; } \
                    | head -1 \
                    | sed -E 's/^[[:space:]]*no_push[[:space:]]*=[[:space:]]*//;
                              s/[[:space:]]*$//;
                              s/^"(.*)"$/\1/;
                              s/^'"'"'(.*)'"'"'$/\1/')"
  # Case-fold for matching so the launcher's truthy/falsy vocabulary
  # is exactly the orchestrator's `_parse_bool_envtoml` (which uses
  # `.lower()` then matches `1|true|yes|on` / `0|false|no|off`). The
  # original value is kept for the error message so the user sees the
  # exact spelling they wrote.
  _toml_no_push_lc="$(printf '%s' "$_toml_no_push" \
                      | tr '[:upper:]' '[:lower:]')"
  case "$_toml_no_push_lc" in
    1|true|yes|on)
      NO_PUSH=true ;;
    0|false|no|off|"")
      : ;;  # explicit falsy / absent → leave NO_PUSH=false
    *)
      # Unrecognized value — die with the same error shape the
      # orchestrator surfaces from _resolve_bool_pref. Silent fall-
      # through would be the worse failure mode (a typo'd opt-out
      # silently becomes "push", which surprises the user). Both
      # layers should agree on what's a valid boolean.
      echo "leerie: error: $USER_REPO/leerie.toml: no_push='$_toml_no_push' is not a boolean" >&2
      echo "  (expected one of: 1, 0, true, false, yes, no, on, off — case-insensitive)" >&2
      exit 1 ;;
  esac
  unset _toml_no_push _toml_no_push_lc
fi

# Parse --no-verify and export NO_VERIFY_PUSH here, BEFORE
# provision_machine registers the EXIT trap. The trap's clean-exit
# branch calls host_finalize, which reads NO_VERIFY_PUSH; exporting it
# late (after the trap fires) would make `--no-verify` silently
# inoperative on the Fly path. CLI-only (no env/TOML mirror — matches
# CLAUDE.md's explicit-user-request principle for hook-skipping).
NO_VERIFY_PUSH=false
for arg in "$@"; do
  if [ "$arg" = "--no-verify" ]; then
    NO_VERIFY_PUSH=true
  fi
done
export NO_VERIFY_PUSH

# 1. cwd is a git repo (orchestrator's old check at leerie.py:7652).
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  remote_log "error: not inside a git repository"
  exit 1
fi

# 2. origin remote present (required for `git push`). Skipped under
#    --no-push. We do NOT preflight `gh auth status` or even check `gh`
#    presence here — both are needed only at PR-creation time, and
#    `gh pr create` failure is non-fatal (the run branch is already
#    pushed; the user can open the PR manually with the printed retry
#    command). Preflighting gh auth surfaced false-positives without
#    catching anything the post-push failure path doesn't handle.
if [ "$NO_PUSH" = "false" ]; then
  if ! git remote get-url origin >/dev/null 2>&1; then
    remote_log "error: this repository has no \`origin\` remote — finalize cannot"
    echo "  push without one. Add one with \`git remote add origin <url>\` or pass" >&2
    echo "  \`--no-push\`." >&2
    exit 1
  fi
fi

# 3. jq is needed for the host-side finalize to read run.json /
#    state.json. Hard-fail on macOS (brew install jq) and Linux (distro
#    package manager); we use jq for the body composition + state writes.
if [ "$NO_PUSH" = "false" ] && ! command -v jq >/dev/null 2>&1; then
  remote_log "error: \`jq\` not found on PATH."
  case "$OS" in
    Darwin) echo "  Install with: brew install jq" >&2 ;;
    Linux)  echo "  Install with your distro package manager (apt install jq / dnf install jq / pacman -S jq)." >&2 ;;
  esac
  echo "  Or pass --no-push to skip the host-side finalize." >&2
  exit 1
fi

# --- build image if not present (one-time, ~60-120s) --------------------
if ! nerdctl image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  remote_log "building container image (one-time; ~60-120s)..."
  nerdctl build \
    --build-arg HOST_UID="$(id -u)" \
    --build-arg HOST_GID="$(id -g)" \
    -t "$IMAGE_TAG" \
    "$LEERIE_REPO" \
    || { remote_log "error: container image build failed"; exit 1; }
fi

# --- per-repo derived image (local nerdctl) -----------------------------
# When the repo supplies .leerie/Dockerfile (or setup_packages in
# .leerie/config.toml generates one), the launcher builds a derived
# image that includes repo-specific system packages. Subsequent runs
# reuse the cached image; a rebuild fires only when the base version
# or the Dockerfile content changes.

# Return the sha256 of a file, portably across Linux (sha256sum) and
# macOS (shasum). Outputs only the hex digest.
_leerie_sha256() {
  local f="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$f" | awk '{print $1}'
  else
    shasum -a 256 "$f" | awk '{print $1}'
  fi
}

# Compute a sanitized repo identifier from the git remote URL (or
# basename fallback) for use in the image tag. Tag chars: [a-z0-9._-].
_leerie_repo_id() {
  local raw sanitized
  raw="$(git -C "$USER_REPO" remote get-url origin 2>/dev/null || true)"
  if [ -z "$raw" ]; then
    raw="$(basename "$USER_REPO")"
  else
    # Extract owner/repo from HTTPS or SSH URLs, strip .git suffix.
    # https://github.com/owner/repo.git → owner/repo
    # git@github.com:owner/repo.git    → owner/repo
    raw="${raw%.git}"
    raw="$(printf '%s' "$raw" | sed -E 's|.*[:/]([^/:]+/[^/:]+)$|\1|')"
  fi
  # Lowercase and replace non-tag chars with '-'.
  sanitized="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9._/]|-|g')"
  # Replace '/' with '-' to keep the tag a single-component path element.
  sanitized="$(printf '%s' "$sanitized" | tr '/' '-')"
  printf '%s' "$sanitized"
}

# Returns the per-repo image tag when a .leerie/Dockerfile is present
# (real or auto-generated); empty string otherwise.
resolve_repo_image_tag() {
  local dockerfile="$USER_REPO/.leerie/Dockerfile"
  if [ ! -f "$dockerfile" ]; then
    # Check setup_packages — if set and no Dockerfile, we'll auto-generate.
    local sp
    sp="$( { grep -E '^[[:space:]]*setup_packages[[:space:]]*=' \
                "$USER_REPO/.leerie/config.toml" 2>/dev/null \
            || true; } \
          | head -1 \
          | sed -E 's/^[[:space:]]*setup_packages[[:space:]]*=[[:space:]]*//;
                    s/[[:space:]]*$//;
                    s/^"(.*)"$/\1/;
                    s/^'"'"'(.*)'"'"'$/\1/')"
    if [ -z "$sp" ]; then
      # No Dockerfile and no setup_packages — use base image.
      echo ""
      return
    fi
    # setup_packages is set; a Dockerfile will be auto-generated (see below).
  fi
  local repo_id
  repo_id="$(_leerie_repo_id)"
  echo "leerie-repo/${repo_id}:${LEERIE_VERSION}"
}

# Build the per-repo derived image. Caller has already verified the build
# is needed (image absent, Dockerfile changed, or base version changed).
build_repo_image() {
  local repo_image_tag="$1"
  local dockerfile="$USER_REPO/.leerie/Dockerfile"
  remote_log "building per-repo container image ($repo_image_tag)..."
  nerdctl build \
    --build-arg BASE_IMAGE="$IMAGE_TAG" \
    --build-arg HOST_UID="$(id -u)" \
    --build-arg HOST_GID="$(id -g)" \
    -t "$repo_image_tag" \
    -f "$dockerfile" \
    "$USER_REPO" \
    || { remote_log "error: per-repo container image build failed"; exit 1; }
}

# Determine whether a per-repo image build is needed and run it.
REPO_IMAGE_TAG=""
_leerie_config_toml="$USER_REPO/.leerie/config.toml"
_leerie_dockerfile="$USER_REPO/.leerie/Dockerfile"

# Auto-generate a Dockerfile from setup_packages if no Dockerfile exists.
if [ ! -f "$_leerie_dockerfile" ] && [ -f "$_leerie_config_toml" ]; then
  _sp="$( { grep -E '^[[:space:]]*setup_packages[[:space:]]*=' \
                "$_leerie_config_toml" 2>/dev/null \
            || true; } \
          | head -1 \
          | sed -E 's/^[[:space:]]*setup_packages[[:space:]]*=[[:space:]]*//;
                    s/[[:space:]]*$//;
                    s/^"(.*)"$/\1/;
                    s/^'"'"'(.*)'"'"'$/\1/')"
  if [ -n "$_sp" ]; then
    # Convert comma-separated list to space-separated package names.
    _sp_packages="$(printf '%s' "$_sp" | tr ',' ' ' | tr -s ' ')"
    remote_log "auto-generating .leerie/Dockerfile from setup_packages: $_sp_packages"
    mkdir -p "$USER_REPO/.leerie"
    # Write to a temp file then move atomically so a half-written file is
    # never visible to the hash check below.
    _gen_df_tmp="$USER_REPO/.leerie/.Dockerfile.gen.$$"
    printf 'ARG BASE_IMAGE\nFROM $BASE_IMAGE\nUSER root\nRUN apt-get update && apt-get install -y --no-install-recommends \\\n' \
      > "$_gen_df_tmp"
    for _pkg in $_sp_packages; do
      printf '    %s \\\n' "$_pkg" >> "$_gen_df_tmp"
    done
    printf '    && rm -rf /var/lib/apt/lists/*\nUSER leerie\n' >> "$_gen_df_tmp"
    mv "$_gen_df_tmp" "$_leerie_dockerfile"
    unset _gen_df_tmp _pkg
  fi
  unset _sp _sp_packages
fi
unset _leerie_config_toml

# Only proceed if a Dockerfile is now present (real or auto-generated).
if [ -f "$_leerie_dockerfile" ]; then
  REPO_IMAGE_TAG="$(resolve_repo_image_tag)"
  if [ -n "$REPO_IMAGE_TAG" ]; then
    # Hash file stores "<base_version>:<dockerfile_sha256>" so either
    # the base version or Dockerfile content change triggers a rebuild.
    _hash_file="$LEERIE_STATE_HOST_DIR/.dockerfile-hash"
    _cur_df_sha="$(_leerie_sha256 "$_leerie_dockerfile")"
    _cur_hash="${LEERIE_VERSION}:${_cur_df_sha}"
    _stored_hash=""
    [ -f "$_hash_file" ] && _stored_hash="$(cat "$_hash_file" 2>/dev/null || true)"

    _need_build=false
    if ! nerdctl image inspect "$REPO_IMAGE_TAG" >/dev/null 2>&1; then
      _need_build=true
    elif [ "$_cur_hash" != "$_stored_hash" ]; then
      _need_build=true
    fi

    if [ "$_need_build" = "true" ]; then
      build_repo_image "$REPO_IMAGE_TAG"
      printf '%s\n' "$_cur_hash" > "$_hash_file"
    else
      remote_log "per-repo image up-to-date ($REPO_IMAGE_TAG); skipping build"
    fi
    unset _hash_file _cur_df_sha _cur_hash _stored_hash _need_build
  fi
fi
unset _leerie_dockerfile

# --- translate --inspect-dir paths into bind-mounts ---------------------
# Each --inspect-dir path points at a host-absolute directory the
# inspect-bucket workers need read access to (--add-dir under the hood).
# Bind-mount each one read-only at /inspect/<basename> and rewrite the arg
# so the in-container view matches. Paths from LEERIE_INSPECT_DIRS (colon-sep)
# and leerie.toml's inspect_dirs (comma-sep) need the same treatment — we
# resolve them on the host and emit --inspect-dir CLI flags. LEERIE_INSPECT_DIRS
# is cleared inside the container so resolve_inspect_dirs() picks up only
# our rewritten CLI flags.
INSPECT_MOUNTS=()
REWRITTEN_ARGS=()
INSPECT_NAMES=()
# Parallel to INSPECT_MOUNTS: pairs of "<host-path>\t<remote-target>" used by
# the remote (Fly) runtime to rsync each inspect dir to /inspect/<basename>
# on the machine. The local runtime ignores this — it uses INSPECT_MOUNTS
# directly. Populated only for inspect dirs OUTSIDE $USER_REPO; in-repo
# inspect dirs (the skip-redundant-mount branch in collect_inspect_path)
# arrive on the machine via seed_repo at /work/<subpath> and need no
# separate transport. See docs/IMPLEMENTATION.md §0.5 "Remote runtime
# (Fly.io) transport".
INSPECT_HOST_TARGETS=()

collect_inspect_path() {
  local host_path expanded resolved base mount_target user_repo_resolved
  host_path="$1"
  # Expand leading ~ — `cd` won't on its own.
  case "$host_path" in
    "~")   expanded="$HOME" ;;
    "~/"*) expanded="$HOME/${host_path#~/}" ;;
    *)     expanded="$host_path" ;;
  esac
  resolved="$(cd -P "$expanded" 2>/dev/null && pwd)" || {
    remote_log "--inspect-dir path not found: $host_path"
    exit 1
  }
  # If the path is inside $USER_REPO it's already visible at /work/<sub>,
  # so a second mount under /inspect/ would be redundant. Warn and skip.
  user_repo_resolved="$(cd -P "$USER_REPO" && pwd)"
  case "$resolved" in
    "$user_repo_resolved"|"$user_repo_resolved"/*)
      # Quote $user_repo_resolved inside ${...#...} so bash strips a literal
      # prefix instead of treating the value as a glob pattern (shellcheck
      # SC2295). Paths typically lack glob metachars, but the cost of
      # defensiveness is one quote-pair.
      local rel="${resolved#"$user_repo_resolved"}"
      remote_log "--inspect-dir '$host_path' is inside the repo; skipping redundant mount"
      REWRITTEN_ARGS+=(--inspect-dir "/work${rel}")
      return 0
      ;;
  esac
  base="$(basename "$resolved")"
  # Disambiguate basename collisions (e.g. two paths both named "src") by
  # appending a numeric suffix. Use [[ ]] for glob-style membership test;
  # surround with spaces so adjacent words don't match a substring.
  local existing=" ${INSPECT_NAMES[*]:-} "
  local candidate="$base"
  local i=2
  while [[ "$existing" == *" $candidate "* ]]; do
    candidate="$base-$i"
    i=$((i + 1))
  done
  base="$candidate"
  mount_target="/inspect/$base"
  INSPECT_NAMES+=("$base")
  INSPECT_MOUNTS+=(-v "$resolved:$mount_target:ro")
  REWRITTEN_ARGS+=(--inspect-dir "$mount_target")
  # Remote (Fly) runtime needs the host-path → /inspect/<basename> mapping to
  # rsync each dir onto the machine. Tab separator is safe: POSIX paths
  # cannot contain \t (they can contain `:` and ` `).
  INSPECT_HOST_TARGETS+=("$resolved"$'\t'"$mount_target")
}

# Serialize INSPECT_HOST_TARGETS for the remote-runtime helper. Empty array
# → empty env var → seed_inspect_dirs short-circuits. Newline-separated
# records, each "<host>\t<remote>", matching the format seed_inspect_dirs
# parses with `read -r`. See docs/IMPLEMENTATION.md §0.5 "Remote runtime
# (Fly.io) transport".
_serialize_inspect_host_targets() {
  if [ "${#INSPECT_HOST_TARGETS[@]}" -eq 0 ]; then
    LEERIE_INSPECT_HOST_TARGETS=""
  else
    LEERIE_INSPECT_HOST_TARGETS="$(printf '%s\n' "${INSPECT_HOST_TARGETS[@]}")"
  fi
  export LEERIE_INSPECT_HOST_TARGETS
}

# Pre-pass: LEERIE_INSPECT_DIRS env (colon-separated).
if [ -n "${LEERIE_INSPECT_DIRS:-}" ]; then
  OIFS="$IFS"; IFS=":"
  for p in $LEERIE_INSPECT_DIRS; do
    [ -z "$p" ] || collect_inspect_path "$p"
  done
  IFS="$OIFS"
fi
# Pre-pass: leerie.toml inspect_dirs key (comma-separated).
# The orchestrator's resolve_inspect_dirs() precedence is CLI > env > TOML,
# so once we emit --inspect-dir CLI flags here, the in-container TOML pass
# is bypassed. Best-effort parse: awk-grep the simple key=value form.
if [ -f "$USER_REPO/leerie.toml" ]; then
  toml_dirs="$(awk -F= '/^[[:space:]]*inspect_dirs[[:space:]]*=/ {
                          gsub(/^[[:space:]]*inspect_dirs[[:space:]]*=[[:space:]]*/, "", $0);
                          gsub(/^"|"$/, "", $0);
                          print; exit
                        }' "$USER_REPO/leerie.toml" 2>/dev/null || true)"
  if [ -n "$toml_dirs" ]; then
    OIFS="$IFS"; IFS=","
    for p in $toml_dirs; do
      # Trim whitespace.
      p="$(printf '%s' "$p" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      [ -z "$p" ] || collect_inspect_path "$p"
    done
    IFS="$OIFS"
  fi
fi
# Main pass: rewrite --inspect-dir in $@. The orchestrator's argparse
# declares only --inspect-dir (no -i alias — see leerie.py:6079), so we
# intercept exactly that one form and let everything else flow through.
prev_was_inspect=false
_prev_was_resume=false
_prev_was_chain_id=false
_prev_was_fly_app_rewrite=false
_prev_was_state_dir_rewrite=false
_prev_was_seed_knob=false
for arg in "$@"; do
  if [ "$_prev_was_state_dir_rewrite" = "true" ]; then
    _prev_was_state_dir_rewrite=false
    continue
  fi
  if [ "$_prev_was_fly_app_rewrite" = "true" ]; then
    _prev_was_fly_app_rewrite=false
    continue
  fi
  if [ "$_prev_was_seed_knob" = "true" ]; then
    # Consume the value of --seed-depth / --seed-shallow-threshold-mb.
    _prev_was_seed_knob=false
    continue
  fi
  if $prev_was_inspect; then
    collect_inspect_path "$arg"
    prev_was_inspect=false
    continue
  fi
  # Consume the value of --chain-id (next arg after --chain-id <val>).
  # The chain_id is a launcher-side tag written to run.json post-
  # finalize by the wave loop; the orchestrator doesn't need to know it.
  if $_prev_was_chain_id; then
    _prev_was_chain_id=false
    export LEERIE_CHAIN_ID="$arg"
    continue
  fi
  # Consume positional run-id after --resume: rewrite to --run-id <val>
  # so the orchestrator sees the canonical form (mirrors --stop/--kill).
  if $_prev_was_resume && [ "${arg#--}" = "$arg" ]; then
    _prev_was_resume=false
    REWRITTEN_ARGS+=("--run-id" "$arg")
    continue
  fi
  _prev_was_resume=false
  case "$arg" in
    --inspect-dir)
      prev_was_inspect=true
      ;;
    --inspect-dir=*)
      collect_inspect_path "${arg#--inspect-dir=}"
      ;;
    --chain-id)
      _prev_was_chain_id=true
      ;;
    --chain-id=*)
      export LEERIE_CHAIN_ID="${arg#--chain-id=}"
      ;;
    --no-runtime-install)
      # Launcher-only flag; consumed by the runtime preflight above.
      # The orchestrator's argparse doesn't know it.
      ;;
    --no-auto-publish)
      # Launcher-only flag; consumed by ensure_image() in the remote path.
      ;;
    --state-dir)
      # Launcher-only flag; consumed by the state-dir resolver above.
      _prev_was_state_dir_rewrite=true
      ;;
    --state-dir=*)
      # Launcher-only flag (=form); consumed above.
      ;;
    --fly-app)
      # Launcher-only flag; consumed by the LEERIE_FLY_APP resolver above.
      _prev_was_fly_app_rewrite=true
      ;;
    --fly-app=*)
      # Launcher-only flag (=form); consumed above.
      ;;
    --local-build)
      # Launcher-only flag; consumed by ensure_image() to forward
      # --local-build to build-push.sh (legacy local nerdctl/docker
      # build instead of the default Fly remote builder).
      ;;
    --seed-depth|--seed-shallow-threshold-mb)
      # Launcher-only flags (DESIGN §6 *Shallow seeding for heavy repos*);
      # resolved into LEERIE_SEED_DEPTH / LEERIE_SEED_SHALLOW_THRESHOLD_MB
      # above and consumed by seed-repo.sh. The orchestrator's argparse
      # doesn't know them — strip both the flag and its value so they don't
      # leak to parse_args() (which is strict, not parse_known_args).
      _prev_was_seed_knob=true
      ;;
    --seed-depth=*|--seed-shallow-threshold-mb=*)
      # =form; consumed above.
      ;;
    --no-re-seed)
      # Launcher-only flag (Phase 4); consumed by the auto-re-seed-on-resume
      # block. The orchestrator's argparse doesn't know it.
      ;;
    --force)
      # Launcher-only flag (Phase 4); bypasses re_seed's safety check.
      ;;
    --shell)
      # Launcher-only flag; opts into bash shell on the --resume rc=75 pivot
      # (DESIGN §6 *Smart resume in remote mode*). The orchestrator's
      # argparse doesn't know it.
      ;;
    --auto-finalize)
      # Launcher-only flag; triggers `leerie --finalize` on clean exit via
      # tail_with_optional_autofinalize. The orchestrator's argparse
      # doesn't know it.
      ;;
    --finalize|--stop|--kill|--re-seed|--accept-blocked|--attach|--chain|--chain-submit|--chain-status|--list-chains|--chain-kill|--chain-attach|config)
      # Launcher-only verbs — normally dispatched at the top-level case
      # (line ~553) when they appear as $1. If one appears here it was
      # in a non-$1 position (e.g. `leerie <id> --finalize --runtime fly`
      # instead of `leerie --finalize <id> --runtime fly`). Error instead
      # of leaking to the orchestrator's argparse.
      remote_log "error: '$arg' is a verb and must be the first argument."
      remote_log "  Run: leerie $arg [args...]"
      exit 1
      ;;
    --resume)
      # Forward --resume to the orchestrator and mark that the next
      # non-flag positional token is the run-id (not the task).
      REWRITTEN_ARGS+=("$arg")
      _prev_was_resume=true
      continue
      ;;
    *)
      REWRITTEN_ARGS+=("$arg")
      ;;
  esac
done

# --- assemble auth/config mounts ----------------------------------------
# Per-container config isolation. The shared host ~/.claude.json is a
# documented corruption race (anthropics/claude-code issues #28847,
# #29217, #29395, #40226 — all open). Each container gets its own copy
# of every claude/git/ssh/gpg config file it needs, staged on the host
# in a per-run scratch dir and mounted at the default in-container
# paths. Container sees normal locations; no shared host state to race.
AUTH_MOUNTS=()

# Returns 0 if any Claude settings file enables Bedrock mode
# (CLAUDE_CODE_USE_BEDROCK=1 in the env block). Checks all three files the
# Claude CLI merges (userSettings → projectSettings → localSettings):
#   ~/.claude/settings.json           — userSettings
#   <repo>/.claude/settings.json      — projectSettings
#   <repo>/.claude/settings.local.json — localSettings
# Any one of them is sufficient — CLAUDE_CODE_USE_BEDROCK has no "disable" value
# (isEnvTruthy only matches "1"/"true"/"yes"/"on"), so OR semantics are equivalent
# to precedence here. The key is only valid inside the env block, not as a
# top-level settings key.
detect_bedrock_mode() {
  python3 - \
    "${HOME}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.local.json" \
    2>/dev/null <<'PY'
import json, sys
for p in sys.argv[1:]:
    try:
        d = json.load(open(p))
        if str(d.get("env", {}).get("CLAUDE_CODE_USE_BEDROCK", "")).strip().lower() in ("1", "true", "yes", "on"):
            sys.exit(0)
    except Exception:
        pass
sys.exit(1)
PY
}

# Verifies the AWS SSO token is valid on the host before the container starts.
# The Claude CLI's awsAuthRefresh command (aws sso login) opens a browser and
# requires an interactive TTY — it cannot run inside a non-interactive container.
# Catching expiry here is the only safe path; the container gets a read-only
# snapshot of ~/.aws/ and cannot refresh tokens itself.
bedrock_preflight() {
  if ! command -v aws >/dev/null 2>&1; then
    remote_log "error: Bedrock mode is enabled but 'aws' CLI not found on PATH."
    echo "  Install the AWS CLI and re-run leerie." >&2
    exit 1
  fi
  local profile
  profile="$(python3 - \
    "${HOME}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.local.json" \
    2>/dev/null <<'PY'
import json, sys
profile = ""
for p in sys.argv[1:]:
    try:
        d = json.load(open(p))
        v = d.get("env", {}).get("AWS_PROFILE", "")
        if v:
            profile = v
    except Exception:
        pass
if profile:
    print(profile)
PY
  )"
  local aws_args=()
  [ -n "$profile" ] && aws_args+=(--profile "$profile")
  if ! aws sts get-caller-identity "${aws_args[@]}" >/dev/null 2>&1; then
    remote_log "error: Bedrock mode is enabled but AWS credentials are expired or missing."
    if [ -n "$profile" ]; then
      echo "  Run: aws sso login --profile $profile" >&2
    else
      echo "  Run: aws sso login  (or set AWS_PROFILE and re-run)" >&2
    fi
    echo "  Then re-run leerie." >&2
    exit 1
  fi
}

if [ ! -d "$HOME/.claude" ]; then
  remote_log "$HOME/.claude not found — run \`claude\` at least once first"
  exit 1
fi
if [ ! -f "$HOME/.claude.json" ]; then
  remote_log "$HOME/.claude.json not found — run \`claude\` at least once first"
  exit 1
fi

# Scratch dir lives under ~/.cache/leerie/ (not $TMPDIR) so Colima's
# default mount config auto-shares it on macOS — $TMPDIR resolves to
# /var/folders/... on Darwin, which is outside the /Users/$USER share
# Colima exposes by default, and the bind mount would silently appear
# empty inside the container. Linux is unaffected (any host path is
# nerdctl-mountable) but the ~/.cache/leerie/ home keeps the launcher
# uniform across platforms and matches the existing cache-dir
# convention used for mise / pnpm / pip / go / cargo (see below).
mkdir -p "$HOME/.cache/leerie"
STAGE="$(mktemp -d "$HOME/.cache/leerie/cfg-XXXXXX")"

# -- .claude.json: copy with projects[] stripped. --
# The projects[] block stores prior-session per-project state
# (lastSessionId, lastCost, MCP allowlists). Stripping it gives the
# worker a clean slate on /work as a brand-new project.
python3 - "$HOME/.claude.json" "$STAGE/.claude.json" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
d.pop("projects", None)
json.dump(d, open(sys.argv[2], "w"))
PY

# -- .claude/: copy with prior-session / history / bulk dirs skipped. --
# Blacklist (not whitelist) so a newly-added capability dir Anthropic
# ships in a future release rides along by default. Update this list
# only when something *bulky and session-shaped* lands.
mkdir "$STAGE/.claude"
CLAUDE_SKIP=(
  history.jsonl     # global prompt history (22+ MB)
  projects          # per-project session transcripts
  sessions          # session metadata
  tasks plans todos # prior-session task state
  file-history      # per-session file-edit snapshots
  paste-cache       # per-session paste tracking
  shell-snapshots   # per-shell snapshots
  session-env       # per-session env snapshots
  telemetry         # CLI telemetry (we own our own)
  stats-cache.json  # per-session stats cache
  debug             # debug dumps
  downloads         # downloaded files
  backups           # .claude.json backups (we own our copy)
  chrome            # Chrome integration state
  ralph-state       # plugin state from prior sessions
  .last-cleanup     # cleanup marker (regenerates)
  # ~400 MB host npm install of the CLI; the leerie image installs
  # @anthropic-ai/claude-code globally via the Dockerfile, so this is
  # pure dead weight on the wire to Fly. Local nerdctl runs bind-mount
  # the host $HOME/.claude so they pick up the local install regardless.
  local
  # Skip the plugin cache and marketplaces (hundreds of MB on a typical
  # host — vercel's node_modules alone is ~150 MB). These are rebuildable
  # from the small JSON files we still seed (installed_plugins.json,
  # known_marketplaces.json). seed_auth runs `claude plugin marketplace
  # add` + `claude plugin install` on the remote after the tar pipe to
  # repopulate them on the machine's fast public egress instead of the
  # slow WireGuard wire.
  plugins/cache
  plugins/marketplaces
)
if command -v rsync >/dev/null 2>&1; then
  EXCLUDES=()
  for s in "${CLAUDE_SKIP[@]}"; do EXCLUDES+=(--exclude="$s"); done
  rsync -a "${EXCLUDES[@]}" --exclude='settings.json.*' \
    "$HOME/.claude/" "$STAGE/.claude/"
else
  cp -aR "$HOME/.claude/." "$STAGE/.claude/"
  for s in "${CLAUDE_SKIP[@]}"; do
    rm -rf "$STAGE/.claude/$s"
  done
  rm -f "$STAGE"/.claude/settings.json.*
fi

# -- Extract OAuth credentials for the staged $STAGE/.claude/. --
# On macOS the CLI stores its OAuth token in the Keychain (service
# `Claude Code-credentials`), not in a file. The Linux CLI reads the
# same JSON from ~/.claude/.credentials.json, so writing whatever the
# host has (Keychain blob, on-disk file, or $CLAUDE_CODE_OAUTH_TOKEN
# bridged to the same JSON shape) to that path inside the container's
# staged .claude/ makes the Linux file-based code path work
# transparently on both platforms.
#
# MUST run AFTER the .claude/ copy above, otherwise the rsync would
# overwrite the credentials file.
#
# `security find-generic-password -w` succeeds silently when the
# caller is in the user's login session (which `./leerie` always is);
# outside that (SSH-without-tty, daemons) it would prompt or fail.
# Best-effort: if extraction fails, fall back to the legacy
# CLAUDE_CODE_OAUTH_TOKEN env-var bridge so workers still authenticate.
if _CLAUDE_CREDS_JSON="$(_extract_claude_credentials_json)" \
   && [ -n "$_CLAUDE_CREDS_JSON" ]; then
  printf '%s' "$_CLAUDE_CREDS_JSON" >"$STAGE/.claude/.credentials.json"
  chmod 600 "$STAGE/.claude/.credentials.json"
  unset _CLAUDE_CREDS_JSON
else
  rm -f "$STAGE/.claude/.credentials.json"
  if [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    AUTH_MOUNTS+=(-e "CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN")
  elif [ "$OS" = "Darwin" ]; then
    remote_log "note — could not extract Claude credentials from Keychain."
    echo "  Export CLAUDE_CODE_OAUTH_TOKEN in your shell, or grant the launcher" >&2
    echo "  Keychain access (the prompt that pops up the first time)." >&2
  fi
fi

# -- ~/.git* dotfiles + XDG ~/.config/git/. --
# Copy every host-side ~/.git* sibling that exists (.gitconfig,
# .gitconfig.local, .gitignore_global, .gitignore, .git-credentials)
# plus the XDG config dir. Each lands in $STAGE at the path that maps
# to its default in-container location.
for f in "$HOME"/.git*; do
  [ -e "$f" ] || continue
  cp -aR "$f" "$STAGE/"
done
if [ -d "$HOME/.config/git" ]; then
  mkdir -p "$STAGE/.config"
  cp -aR "$HOME/.config/git" "$STAGE/.config/"
fi

# -- ~/.netrc, ~/.ssh/, ~/.gnupg/ (auth/signing material). --
# Workers may need to push (SSH), authenticate over HTTPS (.netrc),
# or sign commits (GPG). Colima runs the VM on the same machine the
# host user already controls, so the trust boundary doesn't widen by
# exposing these to a container that user already owns. Exposure is
# per-container and the staging dir is reaped on exit. CRITICAL:
# filter out sockets and ephemeral runtime files — the agent sockets
# (S.gpg-agent, ssh-agent's UNIX sockets) are host-bound, can't be
# `cp -a`'d cleanly, and aren't reachable from inside the container.
if [ -f "$HOME/.netrc" ]; then
  cp -a "$HOME/.netrc" "$STAGE/.netrc"
fi
if [ -d "$HOME/.ssh" ]; then
  mkdir -p "$STAGE/.ssh"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a \
      --exclude='agent' --exclude='S.*' --exclude='*.sock' \
      "$HOME/.ssh/" "$STAGE/.ssh/"
  else
    cp -aR "$HOME/.ssh/." "$STAGE/.ssh/"
    rm -rf "$STAGE/.ssh/agent"
    find "$STAGE/.ssh" -name 'S.*' -delete 2>/dev/null
    find "$STAGE/.ssh" -name '*.sock' -delete 2>/dev/null
  fi
  chmod 700 "$STAGE/.ssh"
fi
if [ -d "$HOME/.gnupg" ]; then
  mkdir -p "$STAGE/.gnupg"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --exclude='S.*' --exclude='*.sock' \
      "$HOME/.gnupg/" "$STAGE/.gnupg/"
  else
    cp -aR "$HOME/.gnupg/." "$STAGE/.gnupg/"
    find "$STAGE/.gnupg" -name 'S.*' -delete 2>/dev/null
    find "$STAGE/.gnupg" -name '*.sock' -delete 2>/dev/null
  fi
  chmod 700 "$STAGE/.gnupg"
  # Strip use-keyboxd: macOS GnuPG 2.4+ enables keyboxd by default, but
  # the container can't reach the host daemon (socket excluded above) and
  # gpg crashes with "SQL library used incorrectly" during mise's Node
  # signature verification. Falling back to file-based pubring.kbx lookup.
  if [ -f "$STAGE/.gnupg/common.conf" ]; then
    grep -v '^[[:space:]]*use-keyboxd[[:space:]]*$' "$STAGE/.gnupg/common.conf" \
      > "$STAGE/.gnupg/common.conf.tmp" || true
    mv "$STAGE/.gnupg/common.conf.tmp" "$STAGE/.gnupg/common.conf"
  fi
fi

# -- ~/.aws/ (Bedrock mode only) --
# The Claude CLI's AWS SDK resolves credentials via pure file I/O:
#   ~/.aws/config          — profile definition + SSO session config
#   ~/.aws/sso/cache/*.json — cached SSO access tokens (~12 h TTL)
#   ~/.aws/credentials     — static long-term keys (empty on SSO-only setups)
# No aws binary is needed inside the container for normal operation.
# cli/cache is excluded (CLI result cache; large, irrelevant to auth).
# Mount read-only: workers never write AWS credentials.
_BEDROCK_ACTIVE=false
_BEDROCK_PROFILE=""
_BEDROCK_REGION=""
if detect_bedrock_mode; then
  _BEDROCK_ACTIVE=true
  if [ ! -d "$HOME/.aws" ]; then
    remote_log "error: Bedrock mode is enabled but ~/.aws/ not found on host."
    echo "  Run 'aws configure' or 'aws sso login' first, then re-run leerie." >&2
    exit 1
  fi
  bedrock_preflight
  mkdir -p "$STAGE/.aws"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --exclude='cli/cache' "$HOME/.aws/" "$STAGE/.aws/"
  else
    cp -aR "$HOME/.aws/." "$STAGE/.aws/"
    rm -rf "$STAGE/.aws/cli/cache"
  fi
  AUTH_MOUNTS+=(-v "$STAGE/.aws:/home/leerie/.aws:ro")
  # Belt-and-suspenders: also inject Bedrock env vars explicitly so
  # claude -p workers activate Bedrock via process.env rather than relying
  # solely on the settings.json env block (which may not be applied by all
  # claude binary versions or in all cwd contexts inside the container).
  AUTH_MOUNTS+=(-e "CLAUDE_CODE_USE_BEDROCK=1")
  # Extract AWS_PROFILE and AWS_REGION from settings files (last-match-wins,
  # same merge order Claude CLI uses: userSettings < projectSettings < localSettings).
  _BEDROCK_PROFILE="$(python3 - \
    "${HOME}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.local.json" \
    2>/dev/null <<'PY'
import json, sys
v = ""
for p in sys.argv[1:]:
    try:
        nv = json.load(open(p)).get("env", {}).get("AWS_PROFILE", "")
        if nv: v = nv
    except Exception: pass
print(v)
PY
  )"
  _BEDROCK_REGION="$(python3 - \
    "${HOME}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.json" \
    "${USER_REPO}/.claude/settings.local.json" \
    2>/dev/null <<'PY'
import json, sys
v = ""
for p in sys.argv[1:]:
    try:
        nv = json.load(open(p)).get("env", {}).get("AWS_REGION", "")
        if nv: v = nv
    except Exception: pass
print(v)
PY
  )"
  [ -n "$_BEDROCK_PROFILE" ] && AUTH_MOUNTS+=(-e "AWS_PROFILE=$_BEDROCK_PROFILE")
  [ -n "$_BEDROCK_REGION" ]  && AUTH_MOUNTS+=(-e "AWS_REGION=$_BEDROCK_REGION")
fi

# -- Mount each staged file/dir at its default in-container path. --
# Files mount as files; dirs mount as dirs. The container sees the
# normal default paths — no env-var redirection needed.
AUTH_MOUNTS+=(-v "$STAGE/.claude.json:/home/leerie/.claude.json")
AUTH_MOUNTS+=(-v "$STAGE/.claude:/home/leerie/.claude")
for relpath in .gitconfig .gitconfig.local .gitignore \
               .gitignore_global .git-credentials .netrc; do
  if [ -e "$STAGE/$relpath" ]; then
    AUTH_MOUNTS+=(-v "$STAGE/$relpath:/home/leerie/$relpath")
  fi
done
if [ -d "$STAGE/.config/git" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.config/git:/home/leerie/.config/git")
fi
if [ -d "$STAGE/.ssh" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.ssh:/home/leerie/.ssh")
fi
if [ -d "$STAGE/.gnupg" ]; then
  AUTH_MOUNTS+=(-v "$STAGE/.gnupg:/home/leerie/.gnupg")
fi

# Best-effort host cleanup. Container is --rm; its writes inside the
# mounts vanish with the container. This removes the host scratch.
trap 'rm -rf "$STAGE"; rm -f "${_cidfile:-}" 2>/dev/null' EXIT

# --- finalize-phase auth is host-side now -------------------------------
# Previous versions of leerie bind-mounted ~/.config/gh, ~/.git-credentials,
# ~/.ssh, and $SSH_AUTH_SOCK into the container so finalize could push
# and open a PR. After DESIGN §6 *Finalization* moved that step to the
# host launcher (post-container-exit), those mounts are no longer
# necessary — git/gh/ssh run with the host's own auth state, where they
# already work. The host preflight above verified gh auth + origin.

# --- per-repo dependency caches (DESIGN §6½, IMPLEMENTATION §0.5) -------
# Five host-side cache dirs survive across runs so:
#   - mise doesn't re-install Node 20.11.0 every time the user runs leerie
#     against a repo with .nvmrc: 20.11.0,
#   - pnpm / pip / Go / Cargo installs hit warm caches.
# Created lazily (mkdir -p) on every leerie invocation — cheap on existing
# dirs, free of failure modes on first run.
# Concurrency-safety per cache is documented in IMPLEMENTATION §0.5;
# pip's pattern (warm once serially in phase_provision, hit cached
# wheels in parallel from worktree replays) is documented in DESIGN §6½.
mkdir -p "$HOME/.cache/leerie/mise-data" \
         "$HOME/.cache/leerie/pnpm-store" \
         "$HOME/.cache/leerie/pip" \
         "$HOME/.cache/leerie/go-mod" \
         "$HOME/.cache/leerie/cargo" \
         "$HOME/.cache/leerie/corepack" \
         "$HOME/.cache/leerie/bundle" \
         "$LEERIE_STATE_HOST_DIR"

CACHE_MOUNTS=(
  -v "$HOME/.cache/leerie/mise-data:/home/leerie/.local/share/mise"
  -v "$HOME/.cache/leerie/pnpm-store:/home/leerie/.cache/leerie/pnpm-store"
  -v "$HOME/.cache/leerie/pip:/home/leerie/.cache/leerie/pip"
  -v "$HOME/.cache/leerie/go-mod:/home/leerie/.cache/leerie/go-mod"
  -v "$HOME/.cache/leerie/cargo:/home/leerie/.cache/leerie/cargo"
  -v "$HOME/.cache/leerie/corepack:/home/leerie/.cache/leerie/corepack"
  # pnpm reads its store path from `npm_config_store_dir` (or `store-dir`
  # in .npmrc, or `--store-dir` CLI). There is no `PNPM_STORE_PATH`; a
  # prior version of this file set that and pnpm silently ignored it,
  # falling back to ~/.local/share/pnpm/store inside the container —
  # which is NOT bind-mounted, so every run paid full registry cost.
  -e "npm_config_store_dir=/home/leerie/.cache/leerie/pnpm-store"
  -e "PIP_CACHE_DIR=/home/leerie/.cache/leerie/pip"
  -e "GOMODCACHE=/home/leerie/.cache/leerie/go-mod"
  -e "CARGO_HOME=/home/leerie/.cache/leerie/cargo"
  -e "COREPACK_HOME=/home/leerie/.cache/leerie/corepack"
  -v "$HOME/.cache/leerie/bundle:/home/leerie/.cache/leerie/bundle"
  -e "BUNDLE_PATH=/home/leerie/.cache/leerie/bundle"
  -e "BUNDLE_CACHE_ALL=1"
)
# MISE_DATA_DIR / MISE_SYSTEM_DATA_DIR are baked into the image as ENV
# (Dockerfile) so the resolver and mount target are stable across
# launcher invocations. Not user-tunable here.

# --- remote: resolve Fly.io image tag -----------------------------------
# FLY_IMAGE_TAG is the registry-tagged image that will be launched as a
# Fly Machine. It is only resolved when REMOTE=true so the local path
# does not pay the version-lookup cost.
resolve_fly_image_tag() {
  local fly_app region version tag
  fly_app="$LEERIE_FLY_APP"
  region="${FLY_REGION:-iad}"
  version="$LEERIE_VERSION"
  tag="registry.fly.io/$fly_app:$version"
  # Allow the caller to override the full tag via env.
  echo "${LEERIE_FLY_IMAGE:-$tag}"
}

# Module-level context set by _set_fly_per_repo_image() and read by
# ensure_image() to build the per-repo derived image on Fly.
_FLY_PER_REPO_DOCKERFILE=""
_FLY_BASE_TAG=""

# When .leerie/Dockerfile is present (real or auto-generated), set
# LEERIE_FLY_IMAGE to registry.fly.io/$APP:$VERSION-$REPO_HASH so that
# resolve_fly_image_tag() returns the per-repo tag. Also records the
# Dockerfile path and base tag in _FLY_PER_REPO_DOCKERFILE / _FLY_BASE_TAG
# for ensure_image() to use when invoking build-push.sh.
# Idempotent: called once before resolve_fly_image_tag().
_set_fly_per_repo_image() {
  local dockerfile="$USER_REPO/.leerie/Dockerfile"
  if [ ! -f "$dockerfile" ]; then
    return 0
  fi
  local fly_app version base_tag repo_hash per_repo_tag
  fly_app="$LEERIE_FLY_APP"
  version="$LEERIE_VERSION"
  base_tag="registry.fly.io/$fly_app:$version"
  # First 12 hex chars of the Dockerfile sha256 — short but collision-free
  # at the scale of per-repo image variants for a single leerie installation.
  repo_hash="$(_leerie_sha256 "$dockerfile" | cut -c1-12)"
  per_repo_tag="registry.fly.io/$fly_app:${version}-${repo_hash}"
  LEERIE_FLY_IMAGE="$per_repo_tag"
  export LEERIE_FLY_IMAGE
  _FLY_PER_REPO_DOCKERFILE="$dockerfile"
  _FLY_BASE_TAG="$base_tag"
  remote_log "remote: per-repo Fly image tag: $per_repo_tag (base: $base_tag)"
}

# --- remote: ensure published image -------------------------------------
# Closes the operator-step gap where the first remote run fails because
# the registry tag wasn't built/pushed yet. Strategy: cache positive hits
# in ~/.cache/leerie/published-tags.txt; on miss, invoke build-push.sh
# --push (which is idempotent at the registry — pushing an already-
# present manifest just no-ops the layers). The cache is a *positive*
# list only, so a manual `flyctl image` deletion is self-healing.
#
# When _FLY_PER_REPO_DOCKERFILE is set (a per-repo .leerie/Dockerfile
# exists), the base image is ensured first; then build-push.sh is called
# with --dockerfile and --build-arg BASE_IMAGE=<base_tag> to build and
# push the derived per-repo image.
#
# Skipped entirely when NO_AUTO_PUBLISH=true (the operator manages
# publishes themselves and accepts the manifest-not-found failure mode).
ensure_image() {
  local tag="$1" cache_dir cache_file
  cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/leerie"
  cache_file="$cache_dir/published-tags.txt"
  if [ -f "$cache_file" ] && grep -Fxq "$tag" "$cache_file" 2>/dev/null; then
    return 0
  fi
  local build_push="$LEERIE_REPO/scripts/remote/build-push.sh"
  if [ ! -x "$build_push" ]; then
    remote_log "error: $build_push not found or not executable"
    return 1
  fi
  local fly_app="$LEERIE_FLY_APP"

  # Auto-create the Fly app if missing. flyctl apps list returns a JSON
  # array; check for a Name match. The remote builder and registry push
  # both require the app to exist. Idempotent on existing apps.
  if ! flyctl apps list --json 2>/dev/null \
       | python3 -c '
import json, sys
try:
    apps = json.load(sys.stdin)
    names = [a.get("Name") or a.get("name") for a in apps]
    sys.exit(0 if sys.argv[1] in names else 1)
except Exception:
    sys.exit(1)
' "$fly_app"; then
    remote_log "remote: Fly app '$fly_app' does not exist — creating it"
    if ! flyctl apps create "$fly_app" 2>&1; then
      remote_log "error: flyctl apps create $fly_app failed"
      echo "  Create it manually: flyctl apps create $fly_app" >&2
      return 1
    fi
  fi

  # Forward --local-build to build-push.sh when the launcher was invoked
  # with --local-build or LEERIE_LOCAL_BUILD=1. Default is remote builder
  # (no host Docker daemon required).
  local build_args=(--app "$fly_app" --push)
  if [ "${LOCAL_BUILD:-false}" = "true" ]; then
    build_args+=(--local-build)
  fi

  # Per-repo derived image: ensure the base image is published first, then
  # build and push the derived image with the per-repo Dockerfile.
  if [ -n "${_FLY_PER_REPO_DOCKERFILE:-}" ]; then
    local base_tag="${_FLY_BASE_TAG}"
    # Ensure base image is cached/published before building the derived one.
    if [ ! -f "$cache_file" ] || ! grep -Fxq "$base_tag" "$cache_file" 2>/dev/null; then
      remote_log "remote: ensuring base image $base_tag is published (needed for per-repo build)"
      if ! "$build_push" "${build_args[@]}"; then
        remote_log "error: build-push.sh failed for base image; remote run cannot proceed"
        return 1
      fi
      mkdir -p "$cache_dir"
      printf '%s\n' "$base_tag" >> "$cache_file"
    fi
    # Now build and push the per-repo derived image.
    local per_repo_args=("${build_args[@]}"
      --dockerfile "$_FLY_PER_REPO_DOCKERFILE"
      --build-arg "BASE_IMAGE=$base_tag"
      --tag "$tag"
    )
    remote_log "remote: ensuring per-repo image $tag is published (cache miss)"
    if ! "$build_push" "${per_repo_args[@]}"; then
      remote_log "error: build-push.sh failed for per-repo image; remote run cannot proceed"
      return 1
    fi
    mkdir -p "$cache_dir"
    printf '%s\n' "$tag" >> "$cache_file"
    return 0
  fi

  remote_log "remote: ensuring image $tag is published (cache miss)"
  if ! "$build_push" "${build_args[@]}"; then
    remote_log "error: build-push.sh failed; remote run cannot proceed"
    return 1
  fi
  mkdir -p "$cache_dir"
  printf '%s\n' "$tag" >> "$cache_file"
  return 0
}

# --- run -----------------------------------------------------------------
container_rc=0
if [ "$RUNTIME" = "fly" ]; then
  # --- remote execution path (Fly.io Machines) -------------------------
  # provision.sh implements the machine create → started → destroy-on-exit
  # lifecycle — the remote equivalent of `nerdctl run --rm`.
  # Sourcing it brings provision_machine() and destroy_machine() into scope
  # and registers an EXIT/INT/TERM trap after the machine starts so no
  # Ctrl-C or crash can leak a machine.
  #
  # seed-auth.sh seeds Claude config + git identity so `claude -p` workers can
  # authenticate and commit. seed-repo.sh tar-pipes a git-aware payload to /work
  # via `flyctl ssh console -C "tar -xC /work"` — `git ls-files` honors
  # .gitignore + `.git/` verbatim + force-include the repo's .claude/ + always
  # skip .leerie/. No in-machine `git clone` (the machine deliberately has no
  # GitHub credentials). Orchestration inside the machine follows after both
  # seedings succeed.
  remote_log "remote: starting Fly.io machine (--runtime fly / LEERIE_RUNTIME=fly / leerie.toml runtime=fly)"

  # Default LEERIE_REMOTE_EXIT_RC to 130 (SIGINT) so the EXIT/INT trap
  # registered by provision.sh routes a Ctrl-C-during-tail to the
  # `130|143)` detach banner arm in decide_teardown — even when the
  # INT trap fires before the post-tail `export
  # LEERIE_REMOTE_EXIT_RC=$container_rc` (~30 lines below) runs.
  # Overwritten on every non-SIGINT path; the 130 default only
  # "survives" when the launcher dies before the post-tail export,
  # which is exactly the Ctrl-C case.
  export LEERIE_REMOTE_EXIT_RC=130

  # Preflight: ensure flyctl is on PATH and authenticated. require_flyctl
  # in lib.sh handles auto-install on first --runtime fly use (parallels
  # the local-runtime auto-install in scripts/install.sh). Respects
  # --no-runtime-install / LEERIE_NO_RUNTIME_INSTALL=1 (falls back to
  # hint+exit). Must run before ensure_image (which uses flyctl to push)
  # and before any other remote script is sourced.
  # shellcheck disable=SC1091
  . "$LEERIE_REPO/scripts/remote/lib.sh"
  # Spawn (or reuse) the leerie-private ssh-agent at
  # ~/.cache/leerie/agent/ssh-agent.sock and set SSH_AUTH_SOCK for the
  # rest of this process tree. Must run BEFORE any flyctl ssh call so
  # Fly-issued certs never land in the user's main agent (which would
  # cause OpenSSH to offer them to github.com and trigger rate-limits).
  _leerie_fly_agent_ensure
  if ! require_flyctl; then
    exit 1
  fi

  # run_id = machine_id: set AFTER provision_machine succeeds (see below).
  # For --resume, LEERIE_RUN_ID is already set from --run-id.

  # Communicate the host's launch-time push intent to the in-Fly
  # orchestrator (DESIGN §6 *Finalization*, intent vs mechanism). The
  # orchestrator-side --no-push the in-Machine launcher injects is the
  # mechanism flag (Fly can't reach origin); --host-no-push is the
  # user's intent. The orchestrator gates pr_writer + the
  # run.json.no_push it writes on intent, not mechanism. Local-runtime
  # nerdctl invocation does NOT pass this — host_no_push stays None
  # there and push_will_happen() falls back to (not no_push).
  if [ "$NO_PUSH" = "true" ]; then
    REWRITTEN_ARGS+=("--host-no-push" "true")
  else
    REWRITTEN_ARGS+=("--host-no-push" "false")
  fi

  # Set LEERIE_FLY_IMAGE to the per-repo derived tag when .leerie/Dockerfile
  # is present; also records context for ensure_image(). No-op otherwise.
  _set_fly_per_repo_image
  FLY_IMAGE_TAG="$(resolve_fly_image_tag)"
  export FLY_IMAGE_TAG

  # Ensure the image is published before flyctl machine run attempts to pull
  # it. Skipped if --no-auto-publish / LEERIE_NO_AUTO_PUBLISH=1 — the operator
  # is responsible for the build-push in that mode.
  if [ "$NO_AUTO_PUBLISH" != "true" ]; then
    if ! ensure_image "$FLY_IMAGE_TAG"; then
      exit 1
    fi
  fi

  PROVISION_SCRIPT="$LEERIE_REPO/scripts/remote/provision.sh"
  RESUME_SCRIPT="$LEERIE_REPO/scripts/remote/resume-machine.sh"
  SEED_AUTH_SCRIPT="$LEERIE_REPO/scripts/remote/seed-auth.sh"
  SEED_SCRIPT="$LEERIE_REPO/scripts/remote/seed-repo.sh"
  FETCH_SCRIPT="$LEERIE_REPO/scripts/remote/fetch-branch.sh"
  if [ ! -f "$PROVISION_SCRIPT" ]; then
    remote_log "error: $PROVISION_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$RESUME_SCRIPT" ]; then
    remote_log "error: $RESUME_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$SEED_AUTH_SCRIPT" ]; then
    remote_log "error: $SEED_AUTH_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$SEED_SCRIPT" ]; then
    remote_log "error: $SEED_SCRIPT not found"
    container_rc=1
  elif [ ! -f "$FETCH_SCRIPT" ]; then
    remote_log "error: $FETCH_SCRIPT not found"
    container_rc=1
  else
    # shellcheck disable=SC1090
    . "$PROVISION_SCRIPT"
    # shellcheck disable=SC1090
    . "$RESUME_SCRIPT"
    # shellcheck disable=SC1090
    . "$SEED_AUTH_SCRIPT"
    # shellcheck disable=SC1090
    . "$SEED_SCRIPT"
    # shellcheck disable=SC1090
    . "$FETCH_SCRIPT"

    # --resume auto-discovery (Phase 1). Runs only when --resume was
    # passed and no explicit --run-id is set. Scans the per-launcher
    # records under $LEERIE_STATE_HOST_DIR/remote/*.json for entries
    # whose recorded launcher_pid is still alive (kill -0). Exactly
    # one match resolves LEERIE_RUN_ID and continues; multiple match
    # lists them and exits; zero matches falls through (the existing
    # zero-match error path at the elif below fires when both
    # LEERIE_RUN_ID and _paused_mid stay empty). DESIGN §6 *Smart
    # resume in remote mode*.
    if [ -z "$LEERIE_RUN_ID" ] && [ "$IS_RESUME" = "true" ]; then
      _active_records=()
      if [ -d "$LEERIE_STATE_HOST_DIR/remote" ]; then
        for _record_file in "$LEERIE_STATE_HOST_DIR/remote"/*.json; do
          [ -e "$_record_file" ] || continue
          _launcher_pid="$(basename "$_record_file" .json)"
          if [ -n "$_launcher_pid" ] && kill -0 "$_launcher_pid" 2>/dev/null; then
            _active_records+=("$_record_file")
          fi
        done
      fi
      case "${#_active_records[@]}" in
        0)
          # No active records. Fall through to the existing zero-match
          # error path below by leaving LEERIE_RUN_ID empty.
          ;;
        1)
          LEERIE_RUN_ID="$(python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    print(d.get("run_id") or "")
except Exception:
    pass
' "${_active_records[0]}" 2>/dev/null || true)"
          export LEERIE_RUN_ID
          if [ -n "$LEERIE_RUN_ID" ]; then
            remote_log "--resume: auto-discovered run-id $LEERIE_RUN_ID from active launcher record"
          fi
          ;;
        *)
          remote_log "--resume: multiple active launches — pass the run-id to disambiguate:"
          for _f in "${_active_records[@]}"; do
            python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    print(f'  pid={d.get(\"launcher_pid\",\"?\")} run={d.get(\"run_id\",\"?\")} machine={d.get(\"fly_machine_id\",\"?\")}')
except Exception:
    pass
" "$_f" >&2 || true
          done
          container_rc=1
          ;;
      esac
    fi

    # Resume path: if a machine pointer exists for this run-id, resume
    # the existing Fly Machine instead of provisioning a new one.
    # (DESIGN §6 Remote pause-on-failure.) Uses the dual-file resolver
    # at leerie:76 — fly-machine.json first, then run.json — to mirror
    # the existing --stop/--kill/--finalize/--resume behavior. For
    # run_id IS the machine ID (DESIGN §6).
    _paused_mid=""
    if [ -n "$LEERIE_RUN_ID" ] && [ "$container_rc" -eq 0 ]; then
      _paused_mid="$LEERIE_RUN_ID"
    fi

    _provisioned=false
    _resumed=false
    if [ "$container_rc" -ne 0 ]; then
      # Auto-discovery printed a multi-match list and set container_rc=1
      # already. Skip the resume/provision decision — nothing to do.
      :
    elif [ -n "$_paused_mid" ]; then
      if resume_machine "$_paused_mid"; then
        _provisioned=true
        _resumed=true
      elif [ "$IS_RESUME" = "true" ]; then
        # User explicitly asked to resume and the target machine is
        # unrecoverable (destroyed / refuses to start). resume_machine
        # already named the cause on stderr. Do NOT silently provision
        # a duplicate — exit with the failure so the user knows.
        container_rc=1
      fi
    elif [ "$IS_RESUME" = "true" ] && [ -n "$LEERIE_RUN_ID" ]; then
      # --resume against a run-id whose machine is not found. The
      # run_id IS the machine ID, so resume_machine would have found it
      # if it existed. Fail loudly.
      remote_log "--resume: machine $LEERIE_RUN_ID not found or not resumable"
      echo "  Run 'leerie --list' to see known runs, or omit --resume to" >&2
      echo "  start a fresh run." >&2
      container_rc=1
    elif [ "$IS_RESUME" = "true" ]; then
      # --resume with no --run-id AND auto-discovery found zero active
      # records. Distinct from the per-id error above — no run to point
      # at, so list-style guidance is the right next step.
      remote_log "--resume: no active remote launchers found"
      echo "  No records under $LEERIE_STATE_HOST_DIR/remote/ and" >&2
      echo "  no --run-id was given." >&2
      echo "  Run 'leerie --list' to see known runs, or omit --resume to" >&2
      echo "  start a fresh run." >&2
      container_rc=1
    elif provision_machine; then
      _provisioned=true
      # run_id = machine_id: set LEERIE_RUN_ID now that we know the
      # machine ID. Pass --run-id to the orchestrator via REWRITTEN_ARGS.
      if [ -z "$LEERIE_RUN_ID" ]; then
        LEERIE_RUN_ID="$LEERIE_MACHINE_ID"
        export LEERIE_RUN_ID
        REWRITTEN_ARGS+=("--run-id" "$LEERIE_RUN_ID")
      fi
    fi
    # Promote the PID-keyed attach pointer to a run-keyed one as soon as
    # the machine is up, BEFORE seed_auth/seed_repo can fail. If anything
    # between here and the orchestrator-detach below errors out,
    # decide_teardown pauses the machine and the user's resume command
    # (`leerie --resume <run-id> --runtime fly`) needs this file to resolve
    # fly_machine_id. provision_machine now writes fly-machine.json directly
    # (provision.sh) so this copy is typically a no-op (guarded by
    # `[ ! -f "$_run_record" ]`). Kept as a fallback for images predating
    # that change and for resume_machine (which doesn't re-write the file).
    if [ "$_provisioned" = "true" ] && [ -n "$LEERIE_RUN_ID" ]; then
