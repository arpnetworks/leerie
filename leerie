  # _cgroup_probe returns False, falling back to the pre-fix
  # uncapped behavior with one warn log line.
  # Write the container ID to a cidfile and bind-mount it into the
  # container so container-entry.sh can inject --run-id <container-id>.
  # nerdctl writes the cidfile before PID 1 starts.

  # On macOS (Darwin), unconditionally set the cgroup bind-mount —
  # Colima's VM always has cgroup v2 with shared propagation, but the
  # host has no /sys/fs/cgroup to probe. On Linux, probe whether the
  # container runtime's namespace has /sys/fs/cgroup as shared (required
  # for rshared bind-propagation). Rootless containerd (rootlesskit
  # --propagation=rslave) demotes it to master (slave), making the
  # bind-mount fail. When skipped, the orchestrator's _cgroup_probe
  # detects the missing mount and falls back to uncapped workers with
  # one warn line.
  CGROUP_MOUNT_ARG=()
  if [ "$(uname -s)" = "Darwin" ]; then
    # macOS has no /sys/fs/cgroup — the host-side probe below always
    # fails. But Colima's Linux VM runs rootful containerd with cgroup
    # v2 and shared propagation, so the bind-mount works inside the VM.
    CGROUP_MOUNT_ARG=(--mount "type=bind,source=/sys/fs/cgroup,target=/sys/fs/cgroup,bind-propagation=rshared")
  elif [ -f /sys/fs/cgroup/cgroup.controllers ]; then
    _cg_shared=true
    _rl_child="/run/user/$(id -u)/containerd-rootless/child_pid"
    if [ -f "$_rl_child" ]; then
      _child_pid=$(cat "$_rl_child" 2>/dev/null)
      if [ -n "$_child_pid" ] && \
         ! grep -q ' /sys/fs/cgroup .*shared:' "/proc/$_child_pid/mountinfo" 2>/dev/null; then
        _cg_shared=false
      fi
    fi
    if [ "$_cg_shared" = "true" ]; then
      CGROUP_MOUNT_ARG=(--mount "type=bind,source=/sys/fs/cgroup,target=/sys/fs/cgroup,bind-propagation=rshared")
    fi
  fi

  # Rootless nerdctl: container-entry.sh uses `unshare --user` to remap
  # UID 0 to leerie so claude accepts --dangerously-skip-permissions.
  # The OCI default seccomp profile blocks unshare(CLONE_NEWUSER), so we
  # lift it for rootless runs. Gate on the same containerd-rootless
  # sentinel the cgroup probe uses — the file only exists when
  # containerd-rootless-setuptool.sh was used on Linux; on macOS (Colima)
  # containerd is rootful inside the VM and no seccomp lift is needed.
  ROOTLESS_SECOPT=()
  if [ -f "/run/user/$(id -u)/containerd-rootless/child_pid" ]; then
    ROOTLESS_SECOPT=(--security-opt seccomp=unconfined)
  fi

  _cidfile="$LEERIE_STATE_HOST_DIR/.cidfile-$$"
  rm -f "$_cidfile"

  # Fix D (DESIGN §6 *container boundary's hidden precondition*): kill the
  # container if the launcher is interrupted, so a Ctrl-C / SIGTERM to this
  # process tears the container down instead of orphaning it (an orphaned,
  # still-Up container keeps holding the run-dir flock and wedges --resume).
  # nerdctl run -i normally forwards the signal to PID 1, but this is the
  # backstop for signals that don't get forwarded across the Colima VM
  # boundary or that arrive before/after nerdctl owns the tty.
  #   Limitation, by design: SIGKILL (signal 9, what OOM delivers) is
  #   uncatchable — this trap never runs in the OOM case. The stale-container
  #   reaper on the next --resume (Fix E) is the backstop for that.
  # The EXIT arm reorders vs the outer host-scratch trap (set earlier) so the
  # kill happens BEFORE the cidfile is removed; it then chains the original
  # cleanup so $STAGE and the cidfile are still removed.
  _kill_container_from_cidfile() {
    if [ -f "${_cidfile:-}" ]; then
      local _cid
      _cid="$(cat "$_cidfile" 2>/dev/null)"
      [ -n "$_cid" ] && nerdctl kill "$_cid" >/dev/null 2>&1 || true
    fi
  }
  trap '_kill_container_from_cidfile; rm -rf "$STAGE"; rm -f "${_cidfile:-}" 2>/dev/null' EXIT
  trap '_kill_container_from_cidfile; exit 130' INT
  trap '_kill_container_from_cidfile; exit 143' TERM

  nerdctl run \
    --rm $TTY_FLAGS \
    --name "leerie-$(date +%s)-$$" \
    --label "leerie.launcher_pid=$$" \
    --cidfile "$_cidfile" \
    -v "$_cidfile:/run/leerie-cidfile:ro" \
    -e LEERIE_INSPECT_DIRS= \
    -e LEERIE_STATE_DIR=/leerie-state \
    ${CGROUP_MOUNT_ARG[@]+"${CGROUP_MOUNT_ARG[@]}"} \
    --cgroupns=host \
    ${ROOTLESS_SECOPT[@]+"${ROOTLESS_SECOPT[@]}"} \
    -v "$USER_REPO:/work" \
    -v "$LEERIE_REPO:/opt/leerie-image:ro" \
    -v "$LEERIE_STATE_HOST_DIR:/leerie-state" \
    ${AUTH_MOUNTS[@]+"${AUTH_MOUNTS[@]}"} \
    ${CACHE_MOUNTS[@]+"${CACHE_MOUNTS[@]}"} \
    ${INSPECT_MOUNTS[@]+"${INSPECT_MOUNTS[@]}"} \
    -w /work \
    "${REPO_IMAGE_TAG:-$IMAGE_TAG}" ${REWRITTEN_ARGS[@]+"${REWRITTEN_ARGS[@]}"} || container_rc=$?
fi

# --- host-side finalize (push + PR) -------------------------------------
# DESIGN §6 *Finalization*: the container's phase_finalize writes
# `finished_at` to .leerie/runs/<run-id>/run.json and exits 0. The
# launcher takes over from here, doing `git push` + `gh pr create` on
# the HOST so the host's working auth state (gh token, ssh-agent,
# Keychain) is what authenticates — no in-container forwarding required.
#
# **Local runtime only.** On the Fly path the run dir is NOT yet on the
# host when we reach this block — the stream-back happens inside
# `decide_teardown` (an EXIT trap in scripts/remote/provision.sh) that
# fires *after* this code returns. If we let this block run on Fly it
# always finds nothing (LATEST_RUN_DIR is empty, exits 0), then the
# trap syncs and destroys the machine without ever pushing. So: on
# Fly, finalize happens inside `decide_teardown` (it sources the same
# scripts/host-finalize.sh and calls host_finalize directly). On
# local, finalize happens here.
#
# Skip if:
#   - container exited non-zero (run failed; nothing to push)
#   - --no-push set (the user explicitly opted out)
#   - the structured-exit code (EXIT_NEEDS_ANSWERS=10) — the launcher's
#     plugin re-runs leerie with --answers after the user responds.
if [ "$container_rc" -ne 0 ] || [ "$NO_PUSH" = "true" ]; then
  if [ "$container_rc" -ne 0 ]; then
    echo "[leerie] finalize: skipped — container exited with code $container_rc" >&2
  fi
  exit "$container_rc"
fi

if [ "$RUNTIME" != "fly" ]; then
  # Locate the most-recent run dir under .leerie/runs/ that has a run.json
  # with finished_at set. The orchestrator writes run.json at finalize.
  # `find` + sort isn't portable with -printf; iterate and pick newest.
  LATEST_RUN_DIR=""
  LATEST_RUN_MTIME=0
  if [ -d "$LEERIE_STATE_HOST_DIR/runs" ]; then
    for run_json in "$LEERIE_STATE_HOST_DIR"/runs/*/run.json; do
      [ -f "$run_json" ] || continue
      # finished_at must be present and non-null.
      if [ "$(jq -r '.finished_at // ""' "$run_json")" = "" ]; then
        continue
      fi
      # pushed_at must be absent or null — otherwise this run was already
      # pushed (e.g. on a previous launcher invocation).
      if [ "$(jq -r '.pushed_at // ""' "$run_json")" != "" ]; then
        continue
      fi
      # branch and working_branch must both be present — a run.json
      # without them was created by the die() handler before
      # phase_classify completed (orchestrator/leerie.py:15116); it
      # cannot be finalized.
      if [ "$(jq -r '.branch // ""' "$run_json")" = "" ] || \
         [ "$(jq -r '.working_branch // ""' "$run_json")" = "" ]; then
        continue
      fi
      # Use mtime of run.json as the recency proxy.
      mtime="$(stat -c %Y "$run_json" 2>/dev/null || stat -f %m "$run_json" 2>/dev/null || echo 0)"
      if [ "$mtime" -gt "$LATEST_RUN_MTIME" ]; then
        LATEST_RUN_MTIME=$mtime
        LATEST_RUN_DIR="$(dirname "$run_json")"
      fi
    done
  fi

  if [ -z "$LATEST_RUN_DIR" ]; then
    echo "[leerie] finalize: no unpushed finished run found under $LEERIE_STATE_HOST_DIR/runs/" >&2
    exit 0
  fi

  # NO_VERIFY_PUSH was parsed + exported up at the top of the script
  # (before provision_machine registers its EXIT trap), so the Fly clean-
  # exit auto-finalize sees it. It's still in scope here for the local-
  # runtime path.

  # Push + PR creation are shared with the `leerie --finalize <run-id>`
  # fast-path; both source scripts/host-finalize.sh and call host_finalize.
  # shellcheck disable=SC1091
  . "$LEERIE_REPO/scripts/host-finalize.sh"
  host_finalize "$LATEST_RUN_DIR" || exit $?
fi
# Fly path: decide_teardown's EXIT trap will source host-finalize.sh and
# call host_finalize after fetch_branch. Nothing else to do here.
