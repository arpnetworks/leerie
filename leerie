  # leerie itself into $HOME/.leerie/, and the default state-dir key is
  # just the basename — so a user repo named `docs` running under that
  # install resolves to $HOME/.leerie/docs/, which IS the installer's
  # own docs subtree. None of the top-level markers above fire (the
  # .git/ and leerie executable are one level up, in $HOME/.leerie/),
  # so the empty-claim branch below would silently corrupt the install.
  local _parent _basename
  _parent="$(dirname "$dir")"
  _basename="$(basename "$dir")"
  if [ -d "$_parent/.git" ] && [ -x "$_parent/leerie" ]; then
    case "$_basename" in
      chain|commands|docs|orchestrator|prompts|scripts|skills|tests|.claude-plugin|.github)
        echo "leerie: state-dir target $dir is a subdirectory of the leerie install dir at $_parent" >&2
        echo "  (running leerie on a repo named '$_basename' would corrupt the installer clone)." >&2
        echo "refusing to write run state here. pick a different path with one of:" >&2
        echo "  --state-dir /some/path" >&2
        echo "  LEERIE_STATE_DIR=/some/path" >&2
        echo "  leerie.toml: state_dir = \"/some/path\"" >&2
        exit 1
        ;;
    esac
  fi
  # Empty or unrelated dir; claim it.
  printf '%s\n' "$USER_REPO" > "$dir/.owner"
  return 0
}

