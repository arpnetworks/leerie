#!/usr/bin/env bash
# leerie — entry point for the Leerie orchestrator.
# After install: `leerie "your task description"` from any git repo.
# Direct git-clone: `/path/to/leerie/leerie "your task description"`,
# or symlink this file onto your PATH manually.
#
# leerie runs inside a container — see docs/IMPLEMENTATION.md §0.5
# "Container shape" and docs/DESIGN.md §6. This launcher:
#   1. Resolves its own location (walking symlinks).
#   2. Fast path: `--version` answers without a container so the installer's
#      smoke test runs the moment the symlink is in place.
#   3. Per-OS preflight: verifies a working container runtime.
#   4. Builds the leerie image once per version, reuses thereafter.
#   5. Translates --inspect-dir paths into bind-mounts.
#   6. Execs nerdctl run with the full mount table, adapting TTY flags
#      ([-it] vs [-i]) to whether the launcher itself has a TTY.
set -euo pipefail

# --- resolve symlinks ----------------------------------------------------
# The curl|bash installer symlinks this script into ~/.local/bin/leerie, but
# the Dockerfile + orchestrator source live alongside the real launcher under
# $LEERIE_HOME (default ~/.leerie). readlink -f isn't portable to BSD/macOS, so
# walk by hand. (Same loop as the pre-container launcher — contract preserved.)
SRC="${BASH_SOURCE[0]}"
hops=0
while [ -L "$SRC" ]; do
  hops=$((hops + 1))
  if [ "$hops" -gt 20 ]; then
    echo "leerie: refusing to resolve symlink chain deeper than 20 hops at $SRC" >&2
    exit 1
  fi
  TARGET="$(readlink "$SRC")"
  case "$TARGET" in
    /*) SRC="$TARGET" ;;
    *)  SRC="$(cd -P "$(dirname "$SRC")" && pwd)/$TARGET" ;;
  esac
done
LEERIE_REPO="$(cd -P "$(dirname "$SRC")" && pwd)"
USER_REPO="$(pwd -P)"

# Bring remote_log into scope before any further stderr emit so every
# leerie-tagged line carries the HH:MM:SS [leerie] [<repo>] prefix.
# The line-29 emit above (symlink-loop fatal) stays bare because the
# chase that resolves LEERIE_REPO hasn't completed at that point.
# shellcheck disable=SC1091
. "$LEERIE_REPO/scripts/remote/_log.sh"

# Image tag = leerie:<version>. Version comes from plugin.json (single source of
# truth — same one `leerie --version` reads). The launcher only needs the value
# for tagging, so a minimal extractor avoids needing python/jq at this stage.
LEERIE_VERSION="$(awk -F'"' '/"version"/ {print $4; exit}' \
                  "$LEERIE_REPO/.claude-plugin/plugin.json" 2>/dev/null || echo dev)"
IMAGE_TAG="leerie:$LEERIE_VERSION"

# --- fast paths that don't need the container ----------------------------
# `leerie --version` should answer immediately without spinning up a container
# — used by the installer's end-to-end smoke test and by anyone who just
# wants to check what's installed.
#
# `--help` is NOT short-circuited: forwarding it through the container makes
# the orchestrator's argparse render the full flag list (worker model
# overrides, telemetry knobs, etc.), which a launcher-side summary would
# silently truncate. The first --help pays a one-time image-build cost; every
# subsequent invocation reuses the cached image and starts in ~2s.

# --- _resolve_fly_machine_id_from_run_dir -------------------------------
# Read fly_machine_id from a run's host-side sidecar. Tries
# fly-machine.json first, then run.json — mirrors the resolution order
# in scripts/remote/attach.sh so the `--stop`/`--kill`/`--finalize`
# fast-paths also work during the in-flight bootstrap window (when the
# host has fly-machine.json but no run.json yet — DESIGN §6 Detached
# orchestrator (remote mode)).
#
# Echoes the machine id to stdout, empty string on miss. Used by
# `_kill_bootstrap_minimal_run_json` and the verbs below.
_resolve_fly_machine_id_from_run_dir() {
  local run_dir="$1"
  local candidate
  for candidate in "$run_dir/fly-machine.json" "$run_dir/run.json"; do
    if [ -f "$candidate" ]; then
      python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    mid = d.get("fly_machine_id")
    print(mid if mid else "")
except Exception:
    pass
' "$candidate"
      return 0
    fi
  done
  return 0
}

# Mirror of _resolve_fly_machine_id_from_run_dir for the per-machine Fly
# volume created when FLY_VM_DISK_GB is set. provision.sh persists
# volume_id into both fly-machine.json (bootstrap window) and run.json
# (post-classify). --kill consults this so the volume is reaped
# alongside the machine instead of orphaning.
_resolve_volume_id_from_run_dir() {
  local run_dir="$1"
  local candidate
  for candidate in "$run_dir/fly-machine.json" "$run_dir/run.json"; do
    if [ -f "$candidate" ]; then
      python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    vid = d.get("volume_id")
    print(vid if vid else "")
except Exception:
    pass
' "$candidate"
      return 0
    fi
  done
  return 0
}

# --- _ensure_run_json --------------------------------------------------
# If run_dir has fly-machine.json but no run.json, bootstrap a minimal
# run.json so subsequent `update_run_json` writes (paused_at,
# killed_at, etc.) have a file to merge into. Idempotent.
_ensure_run_json() {
  local run_dir="$1"
  local sidecar="$run_dir/run.json"
  if [ -f "$sidecar" ]; then
    return 0
  fi
  local fmj="$run_dir/fly-machine.json"
  if [ ! -f "$fmj" ]; then
    return 1
  fi
  python3 -c '
import json, sys
fmj = sys.argv[1]
sidecar = sys.argv[2]
try:
    d = json.load(open(fmj))
except Exception:
    d = {}
out = {
    "fly_machine_id": d.get("fly_machine_id"),
}
with open(sidecar, "w") as f:
    json.dump(out, f, indent=2)
    f.write("\n")
' "$fmj" "$sidecar"
}

# --- host-side per-repo state directory ----------------------------------
# Resolves LEERIE_STATE_HOST_DIR: the host path for this repo's leerie run
# state (runs/, worktrees/, etc.). Lives under $HOME so Colima auto-shares
# it; keyed by repo basename so the dir is browsable without a lookup table.
#
# Precedence (lowest → highest):
#   default ($HOME/.leerie/<basename>)
#   → leerie.toml `state_dir = ...`
#   → LEERIE_STATE_DIR env var
#   → --state-dir CLI flag
#
# The default key is just the repo basename. Cross-repo basename collisions
# (two different abs_paths sharing the same basename) are caught at
# _validate_state_ownership time via the .owner sidecar — see below.
#
# Resolved early (before the verb dispatch) so --stop/--kill/--finalize
# and other fast-path verbs can use it without the full launcher startup.
_state_dir_default() {
  local basename
  basename="$(python3 -c "import os,sys; print(os.path.basename(sys.argv[1].rstrip('/')))" "$USER_REPO")"
  echo "$HOME/.leerie/$basename"
}

LEERIE_STATE_HOST_DIR="$(_state_dir_default)"

# TOML override: state_dir = /some/path
if [ -f "$USER_REPO/leerie.toml" ]; then
  _toml_state_dir="$( { grep -E '^[[:space:]]*state_dir[[:space:]]*=' \
                            "$USER_REPO/leerie.toml" 2>/dev/null \
                        || true; } \
                      | head -1 \
                      | sed -E 's/^[[:space:]]*state_dir[[:space:]]*=[[:space:]]*//;
                                s/[[:space:]]*$//;
                                s/^"(.*)"$/\1/;
                                s/^'"'"'(.*)'"'"'$/\1/')"
  if [ -n "$_toml_state_dir" ]; then
    # Expand leading ~ so relative-home paths work as TOML values.
    case "$_toml_state_dir" in
      "~")   _toml_state_dir="$HOME" ;;
      "~/"*) _toml_state_dir="$HOME/${_toml_state_dir#"~/"}" ;;
    esac
    LEERIE_STATE_HOST_DIR="$_toml_state_dir"
  fi
  unset _toml_state_dir
fi

# Env override: LEERIE_STATE_DIR
if [ -n "${LEERIE_STATE_DIR:-}" ]; then
  LEERIE_STATE_HOST_DIR="$LEERIE_STATE_DIR"
fi

# CLI override: --state-dir /path or --state-dir=/path
_cli_state_dir=""
_prev_was_state_dir=false
for arg in "$@"; do
  if $_prev_was_state_dir; then
    _cli_state_dir="$arg"
    _prev_was_state_dir=false
    continue
  fi
  case "$arg" in
    --state-dir=*) _cli_state_dir="${arg#--state-dir=}" ;;
    --state-dir)   _prev_was_state_dir=true ;;
  esac
done
if [ -n "$_cli_state_dir" ]; then
  LEERIE_STATE_HOST_DIR="$_cli_state_dir"
fi
unset _cli_state_dir _prev_was_state_dir

# Expand leading ~ in the final resolved value.
case "$LEERIE_STATE_HOST_DIR" in
  "~")   LEERIE_STATE_HOST_DIR="$HOME" ;;
  "~/"*) LEERIE_STATE_HOST_DIR="$HOME/${LEERIE_STATE_HOST_DIR#"~/"}" ;;
esac

export LEERIE_STATE_HOST_DIR

# .owner sidecar: claims this state dir for USER_REPO so two different
# repos sharing a basename cannot silently write into the same tree.
# Also catches the case where the resolved path is the leerie install
# dir itself (a real risk now that the default key is just the basename
# — e.g. running leerie on /tmp/leerie would resolve to $HOME/.leerie/leerie).
#
# Called once after resolution and again from verb arms that need it
# (skipped for --version, which exits before doing any I/O on the state
# dir). On any anomaly: die() with an actionable message naming the
# --state-dir / LEERIE_STATE_DIR / leerie.toml overrides.
_validate_state_ownership() {
  local dir="$LEERIE_STATE_HOST_DIR"
  if [ ! -e "$dir" ]; then
    if ! mkdir -p "$dir"; then
      echo "leerie: could not create state dir $dir" >&2
      exit 1
    fi
    printf '%s\n' "$USER_REPO" > "$dir/.owner"
    return 0
  fi
  # A file (not a dir) at the target. Happens when the basename-only
  # default key collides with a FILE inside the installer's clone —
  # e.g. running leerie on a user repo named Dockerfile / LICENSE /
  # leerie.toml resolves to $HOME/.leerie/<basename>, which is one of
  # the installer's tracked top-level files. Catch this before the
  # write below would crash with bash's "Not a directory" error.
  if [ ! -d "$dir" ]; then
    echo "leerie: state-dir target $dir exists but is not a directory" >&2
    echo "  (probably an installer-clone file colliding with a same-named user repo)." >&2
    echo "refusing to write run state here. pick a different path with one of:" >&2
    echo "  --state-dir /some/path" >&2
    echo "  LEERIE_STATE_DIR=/some/path" >&2
    echo "  leerie.toml: state_dir = \"/some/path\"" >&2
    exit 1
  fi
  if [ -f "$dir/.owner" ]; then
    local recorded
    recorded="$(head -1 "$dir/.owner" 2>/dev/null || true)"
    if [ "$recorded" = "$USER_REPO" ]; then
      return 0
    fi
    echo "leerie: state-dir collision at $dir" >&2
    echo "  owner on file: $recorded" >&2
    echo "  current repo:  $USER_REPO" >&2
    echo "two repos share a basename. pick a different path with one of:" >&2
    echo "  --state-dir /some/path" >&2
    echo "  LEERIE_STATE_DIR=/some/path" >&2
    echo "  leerie.toml: state_dir = \"/some/path\"" >&2
    exit 1
  fi
  # No .owner sidecar. Distinguish a legitimate state dir (one with
  # the canonical state-root markers — runs/ or worktrees/) from an
  # installer-dir mistake (.git/ or a leerie executable at top level
  # with no runs/). On the former, backfill .owner; on the latter, die.
  if [ -d "$dir/runs" ] || [ -d "$dir/worktrees" ]; then
    printf '%s\n' "$USER_REPO" > "$dir/.owner"
    return 0
  fi
  if [ -d "$dir/.git" ] || [ -x "$dir/leerie" ]; then
    echo "leerie: state-dir target $dir looks like the leerie install directory" >&2
    echo "  (contains .git/ or a leerie executable, and has no runs/ subdir)." >&2
    echo "refusing to write run state here. pick a different path with one of:" >&2
    echo "  --state-dir /some/path" >&2
    echo "  LEERIE_STATE_DIR=/some/path" >&2
    echo "  leerie.toml: state_dir = \"/some/path\"" >&2
    exit 1
  fi
  # Installer-subtree detect. The installer (scripts/install.sh) clones
  # leerie itself into $HOME/.leerie/, and the default state-dir key is
  # just the basename — so a user repo named `docs` running under that
  # install resolves to $HOME/.leerie/docs/, which IS the installer's
  # own docs subtree. None of the top-level markers above fire (the
  # .git/ and leerie executable are one level up, in $HOME/.leerie/),
  # so the empty-claim branch below would silently corrupt the install.
  local _parent _basename
  _parent="$(dirname "$dir")"
  _basename="$(basename "$dir")"
  if [ -d "$_parent/.git" ] && [ -x "$_parent/leerie" ]; then
    case "$_basename" in
      chain|commands|docs|orchestrator|prompts|scripts|skills|tests|.claude-plugin|.github)
        echo "leerie: state-dir target $dir is a subdirectory of the leerie install dir at $_parent" >&2
        echo "  (running leerie on a repo named '$_basename' would corrupt the installer clone)." >&2
        echo "refusing to write run state here. pick a different path with one of:" >&2
        echo "  --state-dir /some/path" >&2
        echo "  LEERIE_STATE_DIR=/some/path" >&2
        echo "  leerie.toml: state_dir = \"/some/path\"" >&2
        exit 1
        ;;
    esac
  fi
  # Empty or unrelated dir; claim it.
  printf '%s\n' "$USER_REPO" > "$dir/.owner"
  return 0
}

# Verbs that don't touch the local state dir short-circuit the
# ownership check: --version reports version only; the --chain-* verbs
# route to the chain Fly app over HTTP and may be invoked from any
# directory (including non-repo dirs where claiming the basename is
# undesirable).
case "${1:-}" in
  --version|--chain-submit|--chain-status|--list-chains|--chain-kill|--chain-attach) ;;
  *) _validate_state_ownership ;;
esac

case "${1:-}" in
  --version)
    echo "leerie $LEERIE_VERSION"
    exit 0
    ;;
  --list)
    # `--list --runtime fly` is a runtime-aware view: query Fly directly
    # for every machine under FLY_APP, then best-effort cross-reference
    # `$LEERIE_STATE_HOST_DIR/runs/*/{fly-machine.json,run.json}` for the
    # current repo to fill in run-id columns. Without --runtime fly, this arm restores
    # the original argv and lets execution continue past the case block;
    # the orchestrator's argparse handles plain `--list`.
    _list_runtime=""
    _list_rest=("$@")
    shift
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --runtime) _list_runtime="${2:-}"; shift 2 ;;
        --runtime=*) _list_runtime="${1#--runtime=}"; shift ;;
        *) shift ;;
      esac
    done
    if [ "$_list_runtime" = "fly" ] || [ "${LEERIE_RUNTIME:-}" = "fly" ]; then
      FLY_APP="${LEERIE_FLY_APP:-leerie}"
      USER_REPO="${USER_REPO:-$PWD}"
      if ! command -v flyctl >/dev/null 2>&1; then
        echo "leerie: --list --runtime fly: flyctl not found on PATH; falling back to local sidecars." >&2
        set -- "${_list_rest[@]}"
      elif ! _list_json="$(flyctl machines list --app "$FLY_APP" --json 2>&1)"; then
        echo "leerie: --list --runtime fly: flyctl machines list failed:" >&2
        echo "$_list_json" >&2
        echo "  Falling back to local sidecars." >&2
        set -- "${_list_rest[@]}"
      else
        LEERIE_LIST_FLY_JSON="$_list_json" python3 - "$USER_REPO" "$FLY_APP" "$LEERIE_STATE_HOST_DIR" <<'PY'
import json, os, sys
from pathlib import Path

repo = Path(sys.argv[1])
app = sys.argv[2]
state_dir = Path(sys.argv[3])
raw = os.environ.get("LEERIE_LIST_FLY_JSON", "")
try:
    machines = json.loads(raw) if raw.strip() else []
except ValueError as e:
    print(f"leerie: --list --runtime fly: could not parse flyctl JSON: {e}", file=sys.stderr)
    sys.exit(1)

m2r: dict[str, str] = {}
runs_dir = state_dir / "runs"
if runs_dir.is_dir():
    for run_dir in runs_dir.iterdir():
        if not run_dir.is_dir():
            continue
        for sidecar in (run_dir / "fly-machine.json", run_dir / "run.json"):
            if not sidecar.is_file():
                continue
            try:
                d = json.loads(sidecar.read_text())
            except (OSError, ValueError):
                continue
            if isinstance(d, dict):
                mid = d.get("fly_machine_id")
                if mid and mid not in m2r:
                    m2r[mid] = run_dir.name
                    break

if not machines:
    print(f"(no machines on Fly app '{app}')")
    sys.exit(0)

rows = []
for m in machines:
    if not isinstance(m, dict):
        continue
    mid = m.get("id") or ""
    state = m.get("state") or ""
    region = m.get("region") or ""
    created = m.get("created_at") or ""
    run_id = m2r.get(mid, "?")
    rows.append((mid, state, region, created, run_id))

headers = ("machine_id", "state", "region", "created_at", "run_id (local)")
widths = [max(len(h), *(len(r[i]) for r in rows)) for i, h in enumerate(headers)]
fmt = "  ".join(f"{{:<{w}}}" for w in widths)
print(fmt.format(*headers))
print(fmt.format(*("-" * w for w in widths)))
for r in rows:
    print(fmt.format(*r))
print()
print(f"app: {app}   (run_id '?' = sidecar not in {state_dir}/runs/)")
PY
        exit 0
      fi
    else
      set -- "${_list_rest[@]}"
    fi
    ;;
  --attach)
    # Fast-path: open a PTY into a running/paused Fly Machine.
    # (DESIGN §6 *Interactive attach over PTY in remote mode*.)
    # Routed before any runtime preflight — attach doesn't need a
    # local container, only flyctl + WireGuard reachability.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    exec "$LEERIE_REPO/scripts/remote/attach.sh" "$@"
    ;;
  --re-seed)
    # Fast-path: re-rsync the host's working tree into a paused/running
    # Fly Machine. (Phase 4: mid-run re-rsync correction.) Runs before
    # runtime preflight since it doesn't need a local container.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    _re_seed_run_id=""
    _re_seed_force=0
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --force) _re_seed_force=1; shift ;;
        --*) remote_log "unknown --re-seed flag: $1"; exit 1 ;;
        *)
          if [ -z "$_re_seed_run_id" ]; then _re_seed_run_id="$1"; shift
          else remote_log "unexpected --re-seed arg: $1"; exit 1
          fi
          ;;
      esac
    done
    if [ -z "$_re_seed_run_id" ]; then
      remote_log "--re-seed requires a <run-id>"
      echo "  Usage: leerie --re-seed <run-id> [--force]" >&2
      exit 1
    fi
    export LEERIE_RUN_ID="$_re_seed_run_id"
    [ "$_re_seed_force" = "1" ] && export LEERIE_RE_SEED_FORCE=1
    # shellcheck disable=SC1091
    . "$LEERIE_REPO/scripts/remote/provision.sh"
    # shellcheck disable=SC1091
    . "$LEERIE_REPO/scripts/remote/seed-repo.sh"
    # shellcheck disable=SC1091
    . "$LEERIE_REPO/scripts/remote/re-seed.sh"
    re_seed
    exit $?
    ;;
  --stop)
    # Fast-path: explicit pause of a remote run (DESIGN §6 *The user-
    # visible verb surface*). Reads fly_machine_id from the run sidecar
    # and calls stop_machine. Resumable via --resume.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    _stop_run_id=""
    _stop_runtime=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --runtime) _stop_runtime="${2:-}"; shift 2 ;;
        --runtime=*) _stop_runtime="${1#--runtime=}"; shift ;;
        --*) remote_log "unknown --stop flag: $1"; exit 1 ;;
        *)
          if [ -z "$_stop_run_id" ]; then _stop_run_id="$1"; shift
          else remote_log "unexpected --stop arg: $1"; exit 1
          fi
          ;;
      esac
    done
    if [ -n "$_stop_runtime" ] && [ "$_stop_runtime" != "fly" ] && [ "$_stop_runtime" != "local" ]; then
      remote_log "--stop: --runtime must be 'local' or 'fly' (got '$_stop_runtime')"
      exit 1
    fi
    if [ "$_stop_runtime" = "local" ]; then
      remote_log "--stop --runtime local: no local-runtime equivalent yet (local runs run synchronously)."
      exit 1
    fi
    if [ -z "$_stop_run_id" ]; then
      remote_log "--stop requires a <run-id>"
      echo "  Usage: leerie --stop <run-id> [--runtime fly]" >&2
      exit 1
    fi
    _stop_run_dir="$LEERIE_STATE_HOST_DIR/runs/$_stop_run_id"
    if [ ! -d "$_stop_run_dir" ]; then
      remote_log "--stop: no run dir at $_stop_run_dir"
      echo "  Check 'leerie --list' for active runs." >&2
      exit 1
    fi
    # Source provision.sh FIRST — it resets LEERIE_MACHINE_ID="" at
    # load time (intended for provision_machine's create flow). Sourcing
    # after setting LEERIE_MACHINE_ID would clobber our resolver result.
    FLY_APP="${LEERIE_FLY_APP:-leerie}"
    export FLY_APP
    export LEERIE_RUN_ID="$_stop_run_id"
    # shellcheck disable=SC1091
    . "$LEERIE_REPO/scripts/remote/provision.sh"
    require_flyctl || exit 1
    # Try fly-machine.json first (in-flight bootstrap case), then
    # run.json — matches scripts/remote/attach.sh's resolution order.
    LEERIE_MACHINE_ID="$(_resolve_fly_machine_id_from_run_dir "$_stop_run_dir")"
    if [ -z "$LEERIE_MACHINE_ID" ]; then
      remote_log "--stop: $_stop_run_id has no fly_machine_id (was it a local run?)"
      exit 1
    fi
    export LEERIE_MACHINE_ID
    # Bootstrap a minimal run.json if only fly-machine.json exists, so
    # update_run_json has a file to merge paused_at into.
    _ensure_run_json "$_stop_run_dir" || true
    _stop_sidecar="$_stop_run_dir/run.json"
    remote_log "--stop: pausing machine $LEERIE_MACHINE_ID (run $LEERIE_RUN_ID)"
    stop_machine
    update_run_json "$_stop_sidecar" \
      paused_at "$(iso_now)" \
      pause_reason "user-requested" \
      fly_machine_id "$LEERIE_MACHINE_ID" || true
    remote_log "--stop: paused. Resume via: leerie --resume --run-id $LEERIE_RUN_ID --runtime fly"
    exit 0
    ;;
  --kill)
    # Fast-path: explicit destroy of a remote run's machine (DESIGN §6
    # *The user-visible verb surface*). Confirmation prompt unless --force.
    # NOT resumable afterwards — sets killed_at on the sidecar.
    shift
    USER_REPO="${USER_REPO:-$PWD}"
    export USER_REPO
    _kill_run_id=""
    _kill_machine_id=""
    _kill_force=0
    _kill_app=""
    _kill_runtime=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --force) _kill_force=1; shift ;;
        --machine-id) _kill_machine_id="$2"; shift 2 ;;
        --machine-id=*) _kill_machine_id="${1#--machine-id=}"; shift ;;
        --app) _kill_app="$2"; shift 2 ;;
        --app=*) _kill_app="${1#--app=}"; shift ;;
        --runtime) _kill_runtime="${2:-}"; shift 2 ;;
        --runtime=*) _kill_runtime="${1#--runtime=}"; shift ;;
        --*) remote_log "unknown --kill flag: $1"; exit 1 ;;
        *)
          if [ -z "$_kill_run_id" ]; then _kill_run_id="$1"; shift
          else remote_log "unexpected --kill arg: $1"; exit 1
          fi
          ;;
      esac
    done
    if [ -n "$_kill_runtime" ] && [ "$_kill_runtime" != "fly" ] && [ "$_kill_runtime" != "local" ]; then
      remote_log "--kill: --runtime must be 'local' or 'fly' (got '$_kill_runtime')"
      exit 1
    fi
    if [ "$_kill_runtime" = "local" ]; then
      remote_log "--kill --runtime local: no local-runtime equivalent yet (local runs are not persistently running)."
      exit 1
    fi
