# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# macOS
.DS_Store

# Editors
.idea/
.vscode/
*.swp
*.swo

# Leerie run artifacts — created per-run in target repos, never tracked.
.leerie/
# Top-level log when the CLI is teed (`./leerie "..." | tee leerie.log`).
leerie.log

# Local Claude Code settings / cache — per-machine, never tracked.
.claude/

# Working notes — kept locally as a reference, not a deliverable.
foo.txt

# Environment files — never tracked. May hold secrets (API keys,
# tokens, DB credentials). The `.env.example` template form is
# allowed through explicitly so projects can commit a documented stub.
.env
.env.*
!.env.example

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
